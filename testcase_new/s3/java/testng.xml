<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!--this xml is for ci, please don't modify it -->
<!--testcase for function test, which can be excuted concurrently -->
<suite name="driver" verbose="1" preserve-order="true"> 
  <parameter name="HOSTNAME" value="${HOSTNAME}" />  
   <parameter name="SVCNAME" value="${SVCNAME}" />
   <parameter name="S3HOSTNAME" value="${S3HOSTNAME}" />
   <parameter name="S3PORT" value="${S3SVCNAME}" />
   <parameter name="CHANGEDPREFIX" value="newstory_java_test" />
   <parameter name="RSRVPORTBEGIN" value="26000" />
   <parameter name="RSRVPORTEND" value="27000" />
   <parameter name="RSRVNODEDIR" value="/opt/sequoiadb/database/" />
   <parameter name="WORKDIR" value="/tmp/javatest" />
   <parameter name="S3USERNAME" value="administrator" />
   <parameter name="S3ACCESSKEYID" value="ABCDEFGHIJKLMNOPQRST" />
   <parameter name="CONFTOOL" value="/tmp/ci/testcase/tools/changeConf.js" />
   <listeners> 
          <listener class-name = "com.sequoias3.testcommon.TimePrinterListener"/>
   </listeners>
   
   
   
   <test name="javadriver" parallel="classes" thread-count="5">  
      <packages>    
               <package name="com.sequoias3.bucket" /> 
               <package name="com.sequoias3.object" />
               <package name="com.sequoias3.object.concurrent" />
               <package name="com.sequoias3.head" />
               <package name="com.sequoias3.user" />
               <package name="com.sequoias3.delimiter" /> 
               <package name="com.sequoias3.delimiter.concurrent" /> 
      </packages>
   </test> 
   
   <!-- 串行运行用例 -->
   <test name="largeobjects">  
      <packages> 
         <package name="com.sequoias3.region" />
         <package name="com.sequoias3.region.concurrent" />
         <package name="com.sequoias3.object.serial" /> 
         <package name="com.sequoias3.delimiter.serial" /> 
      </packages>
   </test>
   
   <!-- 检测数据残留的用例 -->
   <test name="check">  
      <classes> 
         <class name="com.sequoias3.testcommon.TestResidualData" /> 
      </classes>
   </test>  
</suite>