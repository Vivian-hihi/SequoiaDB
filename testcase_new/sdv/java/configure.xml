<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!--this xml is for ci, please don't modify it-->
<!--testcase which should configure node -->

<suite name="sdv" verbose="1"> 
   <parameter name="HOSTNAME"       value="${HOSTNAME}" />
   <parameter name="SVCNAME"        value="${SVCNAME}" />
   <parameter name="CHANGEDPREFIX"  value="story_java_test" />
   <parameter name="RSRVPORTBEGIN"  value="26000" />
   <parameter name="RSRVPORTEND"    value="27000" />
   <parameter name="RSRVNODEDIR"    value="/opt/sequoiadb/database/" />
   <parameter name="WORKDIR"        value="/tmp/javatest" />
   <parameter name="CONFTOOL"       value="trunk/misc/ci_new/src/test/exec_testcase/changeConf.js" />
   
   <listeners>
      <listener class-name="com.sequoiadb.testcommon.TimePrinterListener"/>
   </listeners>
   
   <!--The testcases of different configure should be placed in different <test> -->
   <test name="lzwtransaction">
      <packages>
          <package name="com.sequoiadb.lzwtransaction"/>
          <package name="com.sequoiadb.transaction"/>
      </packages>
   </test>

   <test name="transaction_sync">
      <classes>
          <class name="com.sequoiadb.transactionsync.SplitToDiffDataRG11901"/>
      </classes>
   </test>
</suite>
   