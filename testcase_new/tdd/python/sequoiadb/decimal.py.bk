from bson.json_util import loads 
from bson.json_util import dumps

import sys,getopt
import traceback

hostname=None
service=None

# parase the args
def parse_option():

   if len( sys.argv ) < 2:
      usage()
      sys.exit(1)
   
   try:  
      opts, args = getopt.getopt( sys.argv[1:], 'hH:p:', ['help'] )
   except getopt.GetoptError as err:
      print( str( err ) )
      usage()
      sys.exit(1)
   
   global hostname, service
   for op, value in opts:
      if op == '-H':
         hostname = value
      elif op == '-p':
         service = int(value)
      elif op in ('-h', '--help'):
         usage()
         sys.exit()
      else:
         print( 'arguments error' )
         usage()
         sys.exit(1)
         
def usage():
   print( 'Command options:' )
   print( '-h,--help  help' )
   print( '-H   arg   hostname' )
   print( '-p   arg   coord_port' )

def createCL( cs_name, cl_name):
   print( '---begin to create cs cl' )
   cs = db.create_collection_space(cs_name)     
   cl = cs.create_collection(cl_name, {"ReplSize":0})
   return cl

def clean( cs_name ):
   print( '---begin to drop cs' )
   try:
      db.drop_collection_space(cs_name)
   except SDBBaseError as e:
      if ( -34 != e.code ): 
         pysequoiadb._print(e.detail)
         raise e
      
def insert_decimal( cl, data ):
   print( '---begin to insert data' )
   try:
      cl.insert( data )
   except SDBBaseError as e:
      pysequoiadb._print("insert decimal:%s failed" % data)
      
def check_Result( cl, condition, obj, doc ):
   print( '---begin to check data' )
   cnt = cl.get_count(condition=condition)
   rec = cl.query( condition=condition).next()
   
   if( cnt != 1 ):
      print( 'get_count, expect: %d, actual: %d' % ( countNum, cnt ) )
      raise  Exception( 'COUNT_ERROR' )
   
   if( rec['a'].compare(obj) != 0 ):
      print( 'rec["a"], expect: %s, actual: %s' % ( obj, rec['a'] ) )    
      raise  Exception( 'CHECK_VALUE_ERROR' )
   
   
   if( dumps(rec.pop('_id')) != dumps(doc.pop('_id')) ):
      print( 'dumps(rec), expect: %s, actual: %s' % ( dumps(doc), dumps(rec) ) )
      raise  Exception( 'CHECK_JSON_ERROR' )
      
def check_InvalidValueArg_Result( data, precision, scale ):  
   try:
      obj = Decimal( data , precision, scale)
      print( 'need throw e' )
      raise Exception( 'NEED_THROW_E' )
   except Exception as err : 
      if ( 'invalid parameter, code: -6' == str(err) ): 
         print('check result pass')
      else:
         print( 'check result failed,except:invalid parameter, code: -6, actual:',err )
         raise Exception( 'ERROR_NOT_CORRECT' )
         
def check_InvalidTypeArg_Result( data, precision, scale ):  
   try:
      obj = Decimal( data , precision, scale)
      print( 'need throw e' )
      raise Exception( 'NEED_THROW_E' )
   except Exception as err : 
      if ( 'precision must be an instance of int' == str(err) ): 
         print('check result pass')
      else:
         print( 'check result failed,except:precision must be an instance of int, actual:',err )
         raise Exception( 'ERROR_NOT_CORRECT' )
           
