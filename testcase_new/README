#story/java testcase readme
#1. set sequoiadb project's root path
export PROJECT_ROOT_PATH=/opt/svn/sequoiadb/

#2. package java driver(sequoiadb-driver-3.2-SNAPSHOT.jar)
cd $PROJECT_ROOT_PATH/trunk/driver/java
mvn clean package -Dmaven.test.skip=true

#3. run story sdv testcase
cd $PROJECT_ROOT_PATH/trunk/testcase_new/story/java/
mvn surefire-report:report -DxmlFileName=testng.xml -Dsdbdriver=3.2-SNAPSHOT -DsdbdriverDir=$PROJECT_ROOT_PATH/trunk/driver/java/target/ -DthreadexecutorDir=$PROJECT_ROOT_PATH/trunk/testcase_new/tools/ -DreportDir=$PROJECT_ROOT_PATH/trunk/testcase_new/story/java/report -DHOSTNAME=192.168.20.56 -DSVCNAME=50000

#4. run sdv java testcase
cd $PROJECT_ROOT_PATH/trunk/testcase_new/sdv/java/
mvn surefire-report:report -DxmlFileName=testng.xml -Dsdbdriver=3.2-SNAPSHOT -DsdbdriverDir=$PROJECT_ROOT_PATH/trunk/driver/java/target/ -DthreadexecutorDir=$PROJECT_ROOT_PATH/trunk/testcase_new/tools/ -DreportDir=$PROJECT_ROOT_PATH/trunk/testcase_new/sdv/java/report -DHOSTNAME=192.168.20.56 -DSVCNAME=50000

#5. run driver java testcase
cd $PROJECT_ROOT_PATH/trunk/testcase_new/driver/java/
mvn surefire-report:report -DxmlFileName=testng.xml -Dsdbdriver=3.2-SNAPSHOT -DsdbdriverDir=$PROJECT_ROOT_PATH/trunk/driver/java/target/ -DthreadexecutorDir=$PROJECT_ROOT_PATH/trunk/testcase_new/tools/ -DreportDir=$PROJECT_ROOT_PATH/trunk/testcase_new/driver/java/report -DHOSTNAME=192.168.20.56 -DSVCNAME=50000

#6. run s3 java testcase
# start s3 process
cd $PROJECT_ROOT_PATH/trunk/testcase_new/driver/java/
mvn surefire-report:report -DxmlFileName=testng.xml -Dsdbdriver=3.2-SNAPSHOT -DsdbdriverDir=$PROJECT_ROOT_PATH/trunk/driver/java/target/ -DthreadexecutorDir=$PROJECT_ROOT_PATH/trunk/testcase_new/tools/ -DreportDir=$PROJECT_ROOT_PATH/trunk/testcase_new/s3/java/report -DHOSTNAME=192.168.20.56 -DSVCNAME=50000 -DS3HOSTNAME=192.168.20.56 -DS3SVCNAME=8002
