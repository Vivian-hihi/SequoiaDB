<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!--This xml is for ci. -->
<!--Testcases for reliability test, except disk-full testcases. -->

<suite name="reliability" verbose="1" stop-all-when-occur-failure="true">
	<parameter name="HOSTNAME"       value="localhost" />
	<parameter name="SVCNAME"        value="11810" />
	<parameter name="CHANGEDPREFIX"  value="reliability_test" />
	<parameter name="RSRVPORTBEGIN"  value="26000" />
	<parameter name="RSRVPORTEND"    value="27000" />
	<parameter name="RSRVNODEDIR"    value="/data/sequoiadb/cidatabase" />
	<parameter name="WORKDIR"        value="/tmp/ci_reliability" />
	<parameter name="ROOTPASSWD"     value="jenkins" />
	<parameter name="REMOTEUSER"     value="sdbadmin" />
	<parameter name="REMOTEPASSWD"   value="sdbadmin" />
   <parameter name="SCRIPTDIR"       value="/trunk/testcase_new/reliability/script" />
   
	<test name="reliability">
		<packages>
			<package name="com.sequoiadb.subcl.brokennetwork" />
			<package name="com.sequoiadb.subcl.killnode"></package>
			<package name="com.sequoiadb.subcl.restartnode"></package>
		
			<package name="com.sequoiadb.clsmgr.brokennetwork"></package>
			<package name="com.sequoiadb.split.killnode"></package>
			<package name="com.sequoiadb.split.restartnode"></package>
			<package name="com.sequoiadb.split.brokennetwork"/>
		</packages>
	</test>


</suite>
   