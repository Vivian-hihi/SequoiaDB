   "../../../../../SequoiaDB/engine/gtest/src/gtest-all.cc" 
]

testMainFile = [
   "./common/testMain.cpp"
]

testCommonFiles = [ 
   "./common/testcommon.cpp",
   "./common/impWorker.cpp",
   "./common/arguments.cpp",
   "./common/testBase.cpp"
]

testFiles = [ 
   [ "./datasource/DS_connTest9505.cpp" ],
   [ "./datasource/DS_invalidArgTest9524.cpp" ],
   [ "./datasource/DS_invalidConnTest9528.cpp" ],
   [ "./datasource/DS_invalidUsrTest9522.cpp" ],  # sync
   [ "./datasource/DS_threadTest9535.cpp", "./datasource/DS_thread.cpp" ],
   [ "./datasource/DS_timeTest9499.cpp" ],  # sync
   [ "./meta/domain12510_12658.cpp" ], # sync
   [ "./meta/domain12657.cpp" ], # sync
   [ "./meta/cs12511_12659.cpp" ],
   [ "./meta/cl12512_12747.cpp" ],
