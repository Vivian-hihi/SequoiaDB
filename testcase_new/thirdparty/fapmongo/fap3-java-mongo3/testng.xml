<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!--this xml is for ci, please don't modify it-->
<!--testcase for function test, which can be excuted concurrently-->

<suite name="driver" verbose="1" preserve-order="true">

    <listeners>
        <listener class-name="com.mongodb.utils.TimePrinterListener"/>
    </listeners>

    <test name="javatest" parallel="classes" thread-count="5">
        <packages>
            <package name="com.mongodb.java"/>
            <package name="com.mongodb.java.concurrent"/>
        </packages>
    </test>

    <test name="springtest" parallel="classes" thread-count="5">
        <packages>
            <package name="com.mongodb.springdata"/>
        </packages>
    </test>

    <test name="javatest-serial" parallel="classes" thread-count="1">
        <packages>
            <package name="com.mongodb.java.serial"/>
        </packages>
    </test>

    <test name="springtest-serial" parallel="classes" thread-count="1">
        <packages>
            <package name="com.mongodb.springdata.serial"/>
        </packages>
    </test>

</suite>
   