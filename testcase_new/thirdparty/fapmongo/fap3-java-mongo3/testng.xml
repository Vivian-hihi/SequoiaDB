<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<!--this xml is for ci, please don't modify it-->
<!--testcase for function test, which can be excuted concurrently-->

<suite name="driver" verbose="10" parallel="classes" thread-count="1">

    <listeners>
        <listener class-name="com.mongodb.utils.TimePrinterListener"/>
    </listeners>

    <test name="javatest" parallel="classes" thread-count="5">

        <packages>
            <package name="com.mongodb.javatestv3"/>
        </packages>

    </test>

    <test name="springtest" parallel="classes" thread-count="5">

        <packages>
            <package name="com.mongodb.springtest"/>
        </packages>

    </test>

</suite>
   