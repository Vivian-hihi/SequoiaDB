<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>com.sequoiadb</groupId>
    <artifactId>mongodb3test</artifactId>
    <packaging>pom</packaging>
    <version>1.0-SNAPSHOT</version>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <jars.dir>${basedir}/jars-3</jars.dir>

        <log4j.version>1.2.16</log4j.version>
        <org.slf4j.version>1.7.1</org.slf4j.version>
        <commons-codec.version>1.10</commons-codec.version>
        <commons-logging.version>1.2</commons-logging.version>

        <org.springframework.version>4.3.13.RELEASE
        </org.springframework.version>
        <spring.tx.version>4.3.14.RELEASE</spring.tx.version>
        <spring-data-mongodb.version>1.10.10.RELEASE
        </spring-data-mongodb.version>
        <spring-data-commons.version>1.13.10.RELEASE
        </spring-data-commons.version>
        <mongo-java-driver.version>3.4.3</mongo-java-driver.version>
        <lombok.version>1.16.18</lombok.version>

        <!-- jars properties -->
        <testng.version>6.13.1</testng.version>
        <jcommander.version>1.72</jcommander.version>
        <compiler-plugin.version>3.6.0</compiler-plugin.version>

        <!-- compiler settings properties -->
        <java_source_version>1.7</java_source_version>
        <java_target_version>1.7</java_target_version>
        <file_encoding>UTF-8</file_encoding>

        <!-- surefire properties -->
        <surefire-plugin.version>2.20.1</surefire-plugin.version>
        <slf4j-api.version>1.7.5</slf4j-api.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-jdk14</artifactId>
            <version>${org.slf4j.version}</version>
            <scope>system</scope>
            <systemPath>
                ${jars.dir}/slf4j-jdk14-${org.slf4j.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <version>${org.slf4j.version}</version>
            <scope>system</scope>
            <systemPath>
                ${jars.dir}/slf4j-api-${org.slf4j.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>log4j</groupId>
            <artifactId>log4j</artifactId>
            <version>${log4j.version}</version>
        </dependency>

        <!-- spring framework -->
        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-context-support</artifactId>
            <version>${org.springframework.version}</version>
            <scope>system</scope>
            <systemPath>
                ${jars.dir}/spring-context-support-${org.springframework.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-beans</artifactId>
            <scope>system</scope>
            <version>${org.springframework.version}</version>
            <systemPath>
                ${jars.dir}/spring-beans-${org.springframework.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-aop</artifactId>
            <scope>system</scope>
            <version>${org.springframework.version}</version>
            <systemPath>
                ${jars.dir}/spring-aop-${org.springframework.version}.jar
            </systemPath>
        </dependency>


        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-context</artifactId>
            <scope>system</scope>
            <version>${org.springframework.version}</version>
            <systemPath>
                ${jars.dir}/spring-context-${org.springframework.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-core</artifactId>
            <scope>system</scope>
            <version>${org.springframework.version}</version>
            <systemPath>
                ${jars.dir}/spring-core-${org.springframework.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-expression</artifactId>
            <scope>system</scope>
            <version>${org.springframework.version}</version>
            <systemPath>
                ${jars.dir}/spring-expression-${org.springframework.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-tx</artifactId>
            <scope>system</scope>
            <version>${spring.tx.version}</version>
            <systemPath>
                ${jars.dir}/spring-tx-${spring.tx.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-test</artifactId>
            <scope>system</scope>
            <version>${org.springframework.version}</version>
            <systemPath>
                ${jars.dir}/spring-test-${org.springframework.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.springframework.data</groupId>
            <artifactId>spring-data-commons</artifactId>
            <scope>system</scope>
            <version>${spring-data-commons.version}</version>
            <systemPath>
                ${jars.dir}/spring-data-commons-${spring-data-commons.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.springframework.data</groupId>
            <artifactId>spring-data-mongodb</artifactId>
            <scope>system</scope>
            <version>${spring-data-mongodb.version}</version>
            <systemPath>
                ${jars.dir}/spring-data-mongodb-${spring-data-mongodb.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.mongodb</groupId>
            <artifactId>mongo-java-driver</artifactId>
            <scope>system</scope>
            <version>${mongo-java-driver.version}</version>
            <systemPath>
                ${jars.dir}/mongo-java-driver-${mongo-java-driver.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>system</scope>
            <version>${lombok.version}</version>
            <systemPath>${jars.dir}/lombok-${lombok.version}.jar</systemPath>
        </dependency>

        <dependency>
            <groupId>apache</groupId>
            <artifactId>commons-codec</artifactId>
            <scope>system</scope>
            <version>${commons-codec.version}</version>
            <systemPath>${jars.dir}/commons-codec-${commons-codec.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>apache</groupId>
            <artifactId>commons-logging</artifactId>
            <scope>system</scope>
            <version>${commons-codec.version}</version>
            <systemPath>${jars.dir}/commons-codec-${commons-codec.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>apache</groupId>
            <artifactId>commons-logging</artifactId>
            <scope>system</scope>
            <version>${commons-logging.version}</version>
            <systemPath>
                ${jars.dir}/commons-logging-${commons-logging.version}.jar
            </systemPath>
        </dependency>

        <dependency>
            <groupId>org.testng</groupId>
            <artifactId>testng</artifactId>
            <version>${testng.version}</version>
        </dependency>

        <dependency>
            <groupId>com.sequoiadb</groupId>
            <artifactId>threadexecutor</artifactId>
            <version>1.0.0-SNAPSHOT</version>
            <scope>system</scope>
            <systemPath>${jars.dir}/threadexecutor-1.0.0-SNAPSHOT.jar
            </systemPath>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>${surefire-plugin.version}</version>
                <configuration>
                    <reportsDirectory>${reportDir}</reportsDirectory>
                    <suiteXmlFiles>
                        <file>${xmlFileName}</file>
                    </suiteXmlFiles>
                    <forkMode>pertest</forkMode>
                    <argLine>-Xms1024m -Xmx1024m -Xss1m</argLine>
                </configuration>
            </plugin>

            <plugin>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>2.3.2</version>
                <configuration>
                    <source>1.7</source>
                    <target>1.7</target>
                    <encoding>UTF-8</encoding>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>