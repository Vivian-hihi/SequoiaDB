  } elsif ( $rc2 == 0 ) {
    $features->{'target_wint_t_is_unsigned'} = 1;
  }
}

sub check_size_t_type
{
  my ( $compiler, $features ) = @_;
  
  # gcc defines __SIZE_TYPE__ to give us the type directly.
  # xlc also defines it, but they do it wrong.
  # So, do this first, and let the typedef check that comes
  # after win.

  my $macros =
    expand_macros( $compiler, [ '__SIZE_TYPE__' ], [ 'stddef.h' ] );
  
  if ( exists $macros->{'__SIZE_TYPE__'} ) {
    $features->{'target_size_t_int_kind'} = $macros->{'__SIZE_TYPE__'};
  }
  
  # Try to get the type by either pre-processing stddef.h
  # and looking for the typedef for size_t.
  
  my $source = include_headers( 'stddef.h' );
  
  my ( $rc, $output ) = preprocess_source( $compiler, $source );

  if ( $rc == 0 ) {
    if ( $output =~ /\btypedef\s+(.*?)\s+size_t\s*;/ ) {
      my $type = $1;
      $type =~ s/\s+/ /g; # compress whitespace
      $features->{'target_size_t_int_kind'} = $type;
    }
  }
  
  # Try to figure out the size of size_t, in case we can't get
  # the type directly. This will help us guess later, if we need
  # to.
  
  my $size = compiler_sizeof( $compiler, 'size_t', [ 'stddef.h' ] );
  
  if ( defined $size ) {
    $features->{'target_sizeof_size_t'} = $size;
  }
}

sub check_ptrdiff_t_type
{
  my ( $compiler, $features ) = @_;
  
  # gcc defines __PTRDIFF_TYPE__ to give us the type directly.
  # So, do this first, and let the typedef check that comes
  # after win.

  my $macros =
    expand_macros( $compiler, [ '__PTRDIFF_TYPE__' ], [ 'stddef.h' ] );
  
  if ( exists $macros->{'__PTRDIFF_TYPE__'} ) {
    $features->{'target_ptrdiff_t_int_kind'} = $macros->{'__PTRDIFF_TYPE__'};
  }
  
  # Try to get the type by either pre-processing stddef.h
  # and looking for the typedef for ptrdiff_t.
  
  my $source = include_headers( 'stddef.h' );
  
  my ( $rc, $output ) = preprocess_source( $compiler, $source );

  if ( $rc == 0 ) {
    if ( $output =~ /\btypedef\s+(.*?)\s+ptrdiff_t\s*;/ ) {
      my $type = $1;
      $type =~ s/\s+/ /g; # compress whitespace
      $features->{'target_ptrdiff_t_int_kind'} = $type;
    }
  }
  
  # Try to figure out the size of ptrdiff_t, in case we can't get
  # the type directly. This will help us guess later, if we need
  # to.
  
  my $size = compiler_sizeof( $compiler, 'ptrdiff_t', [ 'stddef.h' ] );
  
  if ( defined $size ) {
    $features->{'target_sizeof_ptrdiff_t'} = $size;
  }
}

sub check_builtin_va_list_base_type
{
  my ( $compiler, $features ) = @_;
  my ( $source, $rc, $output, $errout, $type);

  verbose 2, "Checking for base type of __builtin_va_list";

  $source = builtin_va_list_base_type_source();
  
  ( $rc, $output, $errout ) = compile_source( $compiler, $source );

  if ($rc != 0) {
    if ($errout =~ /error: cannot convert [`']([^']*)'/) {
      $type = $1;
      $type =~ s/[ \*]+//;
      $features->{'target_builtin_va_list_base_type'} = "$type";
      return;
    }
  }

# Could not figure it out. Assume it's OK and be silent about it. It wasn't
# an issue with older GCC versions and only showed up recently. Issuing a 
# warning here would only confuse people.
}

sub check_misc_features
{
  my ( $compiler, $features ) = @_;

  my ( $rc, $output );
  
  # Check for misc features

  verbose 2, "Checking for misc feature: plain int bitfields are unsigned";
  
  my $source = plain_int_bitfield_source();

  ( $rc, $output ) =
    compile_source_and_run( $compiler, $source );
  
  if ( $rc == 0 ) {
    if ( $output =~ /target_plain_int_bit_field_is_unsigned=(\d+)/ ) {
      $features->{'target_plain_int_bit_field_is_unsigned'} = $1;
    } else {
      verbose 2, "- Unknown plain int bitfields (unexpected output)";
    }
  }
  
  ####################
  
  verbose 2, "Checking for misc feature: enums in bitfields";
  
  $source = enum_bitfield_source();

  ( $rc, $output ) =
    compile_source_and_run( $compiler, $source );
  
  if ( $rc == 0 ) {
    if ( $output =~ /target_enum_bit_fields_are_always_unsigned=(\d+)/ ) {
      $features->{'target_enum_bit_fields_are_always_unsigned'} = $1;
    } else {
      verbose 2, "- Unknown enums in bitfields (unexpected output)";
    }
  }

  ##########
  
  verbose 2, "Checking for misc feature: friend injection";

  $source = friend_injection_source();
  
  ( $rc ) = compile_source( $compiler, $source );
  
  if ( $rc == 0 ) {
    $features->{'language_friend_injection_enabled'} = 1;
  }

  ##########

  verbose 2, "Checking for misc feature: old for scope";
  
  $source = old_for_scope_source();
  
  ( $rc ) = compile_source( $compiler, $source );
  
  if ( $rc == 0 ) {
    $features->{'language_use_nonstandard_for_init_scope'} = 1;
  }
  
  ##########
  
#  verbose 2, "Checking for misc feature: enums can be smaller than int";
#  
#  $source = small_enum_source();
#  
#  ( $rc, $output ) =
#    compile_source_and_run( $compiler, $source );
#  
#  if ( $rc == 0 ) {
#    if ( $output =~ /target_enum_types_can_be_smaller_than_int=(\d+)/ ) {
#      $features->{'target_enum_types_can_be_smaller_than_int'} = $1;
#    }
#  }
  
  ####################
  
  verbose 2, "Checking if string literals are const";
  
  $source = const_string_source();
  
  ( $rc ) = compile_source( $compiler, $source );
  
  if ( $rc == 0 ) {
    $features->{'language_string_literals_are_const'} = 0;
  }
  
  ####################
  
  verbose 2, "Checking if string literals are readonly";
  
  $source = readonly_string_source();
  
  ( $rc, $output ) =
    compile_source_and_run( $compiler, $source );
  
  if ( $rc != 0 || $output eq "1" ) {
    $features->{'target_string_literals_are_readonly'} = 1;
  } else {
    $features->{'target_string_literals_are_readonly'} = 0;
  }
  
  ####################
  
  verbose 2, "Checking if dollars are allowed in identifiers";
  
  $source = dollar_in_ids_source();
 
  ( $rc ) = compile_source( $compiler, $source );
  
  if ( $rc != 0 ) {
    $features->{'language_allow_dollar_in_id_chars'} = 0;
  }

  ####################
  
  if ( $compiler->{'lang'} eq 'c' ) {
    verbose 2, "Checking if end-of-line comments are allowed in C code";
    
    $source = end_of_line_comments_source();
    
    ( $rc ) = compile_source( $compiler, $source );
    
    if ( $rc != 0 ) {
      $features->{'language_end_of_line_comments_allowed'} = 0;
    }
  }
 
  ####################
  
  verbose 2, "Checking if leading/trailing spaces are allowed in include directives";
  
  my $name = write_temp_file("int a;", "h");
  $name = fn_path_to_ext( $name );
  
  $source = spaces_in_include_directive($name);

  ( $rc ) = compile_source( $compiler, $source );
  
  if ( $rc == 0 ) {
    $features->{'language_allow_spaces_in_include_directive'} = 1;
  }

  ####################
  
  verbose 2, "Checking if the restrict keyword is allowed by default";
  
  $source = restrict_keyword_source();
  
  ( $rc ) = compile_source( $compiler, $source );
  
  if ( $rc == 0 ) {
    $features->{'language_restrict_keyword_enabled'} = 1;
  }

  ####################
  
  if ( $compiler->{'lang'} eq 'c' ) {
    verbose 2, "Checking if anonymous unions are accepted";
  
    $source = anonymous_union_source();
  
    ( $rc ) = compile_source( $compiler, $source );
  
    if ( $rc != 0 ) {
      $features->{'language_allow_nonstandard_anonymous_unions'} = 0;
    }
  }

  ####################
  
  verbose 2, "Checking if trigraphs are recognized and converted";
  
  $source = trigraph_source();
  
  ( $rc, $output ) = preprocess_source( $compiler, $source );
  
  # If any of the two suspect character sequences has been changed we
  # take that as "trigraphs are supported". This is to better support
  # busted compilers like "cc" on USS which can handle trigraphs outside
  # character strings only.
  if ( $rc == 0 ) {
    if ( $output =~ /\"\?\?\=\"/ && $output =~ /\?\?\!/ ) {
      # Not supported
      $features->{'language_trigraphs_allowed'} = 0;
    } else {
      # Supported - "??=" was converted to "#"
      $features->{'language_trigraphs_allowed'} = 1;
    }
  }

  ####################
  
  if ( exists $features->{'xlc'} ||
       exists $features->{'vac'} ||
       exists $features->{'vacwin'} ) {
    foreach my $key ( @decl_keywords ) {
      verbose 2, "Checking whether $key is accepted";
  
      $source = decl_keyword_source($key);
  
      ( $rc ) = compile_source( $compiler, $source );
  
      if ( $rc == 0 ) {
        $features->{$key} = "1";
      }
    }
  }

  ####################
  
  verbose 2, "Checking for standard predefined macros";
  my $defined_macros = {};
  my $macro_list = $standard_predefined_macros{$compiler->{'lang'}};

  expand_macros_preproc( $compiler, $defined_macros, $macro_list, [] );

  my %actually_defined = %$defined_macros;
  my $undefs = "";
  foreach my $macro ( @$macro_list ) {
    if ( ! exists $actually_defined{$macro} ) {
      $undefs .= " $macro";
    }
  }
  if ($undefs ne "") {
    $features->{'undefined_standard_macros'} = $undefs;
  }

  ####################

  foreach my $name ( @predefined_function_names ) {
    verbose 2, "Checking whether compiler defines $name";
  
    $source = function_name_defined( $name );

    ( $rc ) = compile_source( $compiler, $source );
  
    if ( $rc == 0 ) {
      $source = function_name_is_string_literal( $name );
      ( $rc ) = compile_source( $compiler, $source );
      if ( $rc == 0 ) {
        $features->{"function_name_is_string_literal($name)"} = "1";
      } else {
        $features->{"function_name_is_string_literal($name)"} = "0";
      }
    } else {
        $features->{"function_name_is_string_literal($name)"} = "undef";
    }
  }
}

####################

sub find_macros
{
  my ( $compiler, @dirs ) = @_;
  
  my $macros = {};
  my $before;
  my $num;

  verbose 1, "Looking for predefined macros (this may take a while)...";
  
  # Search for macros in two ways

  # - First, try the compiler support for spitting out
  #   macro definitions
  
  verbose 2, "- Searching for macros with the compiler flags";
  
  $before = scalar( keys %$macros );
  
  compiler_macros( $compiler, $macros );
  
  $num = scalar( keys %$macros ) - $before;
  
  verbose 2, "- Found $num macro(s) with the compiler flags";
  
  # - Second, look in all header files in @dirs for identifiers
  #   and expand them all

  my $dirnum = scalar @dirs;
  
  verbose 2, "- Searching $dirnum directories for headers containing macros";
  
  $before = scalar( keys %$macros );
  
  header_macros( $compiler, $macros, @dirs );
  
  $num = scalar( keys %$macros ) - $before;
  
  verbose 2, "- Found $num macro(s) by searching header files";
  
  $num = scalar( keys %$macros );
  verbose 1, "- Found $num predefined macro(s)";
  
  if ( $num == 0 ) {
    print STDERR "\n";
    print STDERR "Warning: No predefined macros were found. You will\n";
    print STDERR "         need to add them to the configuration file manually.\n";
  }

  return $macros;
}

####################

# Return a string for setting the var to the val in the
# language's namespace.
sub set_var
{
  my( $lang, $var, $val ) = @_;

  return "set beam::compiler::${lang}::${var} $val\n";
}

# Return a string for setting the var to the val in the
# language's namespace. The value is quoted. The width
# is optional, and if given, will be the minimum space
# taken up by the variable's name.
sub set_qvar
{
  my( $lang, $var, $val, $width ) = @_;

  $width = 0 unless defined $width;
  
  $var = sprintf("%-${width}s", $var);
  
  if ( $val =~ /\"/ ) {
    $val = "{$val}";
  } else {
    $val = qq{"$val"};
  }
  
  return set_var($lang, $var, $val);
}

sub write_template_config_file
{
  my ( $lang, $file ) = @_;

  if ( $lang eq "c" || $lang eq "cpp" ) {
    write_c_cpp_template_config_file( $lang, $file );
  } elsif ( $lang eq "java" ) {
    write_java_template_config_file( $file );
  } else {
    die "Internal Error: unknown language $lang\n";
  }
}

sub write_c_cpp_template_config_file
{
  my ( $lang, $file ) = @_;
  
  # Write out a C or C++ template config file that can be filled in
  # by the user.

  my $template_config = {
    TEMPL_NS                    => "beam::compiler::$lang",
    TEMPL_VERSION               => $version,
    TEMPL_COMPILER_PATH         => 'Template Configuration File',
    TEMPL_CONFIGURE_INVOCATION  => 'Template Configuration File',
    TEMPL_GENERATED             => q[],
    TEMPL_CC                    => set_qvar($lang, "cc", "default"),
    TEMPL_GNU_MODE              => q[],
    TEMPL_MSVC_MODE             => q[],
    TEMPL_LANGUAGE_MISC         => q[],
    TEMPL_SYSTEM_INCLUDE_PATH   => q[],
    TEMPL_TARG_FEATURES         => q[],
    TEMPL_PREDEFINED_MACROS     => q[],
    TEMPL_STANDARD_EXCEPTIONS   => q[],
    TEMPL_EXTERN                => q[],
    TEMPL_FUNCTION_NAME         => q[],
  };

  my $text = translate_template( $template_c_cpp_config_file,
                                 $template_config );

  write_file( $file, $text );
  
  printf( "Template %s configuration written to '%s'\n",
          $lang eq 'c' ? 'C' : 'C++', $file );
}

sub write_java_template_config_file
{
  my ( $file ) = @_;
  
  # Write out a Java template config file that can be filled in
  # by the user.
  
  my $template_config = {
    TEMPL_VERSION               => $version,
    TEMPL_COMPILER_PATH         => 'Template Configuration File',
    TEMPL_CONFIGURE_INVOCATION  => 'Template Configuration File',
    TEMPL_GENERATED             => q[],
    TEMPL_CC                    => set_qvar("java", "cc", "default"),
    TEMPL_LANGUAGE_SOURCE_LEVEL => set_var("java", "language_source_level", "1.4"),
    TEMPL_LANGUAGE_ENCODING     => q[],
    TEMPL_SYSTEM_ENDORSED_DIRS  => q[],
    TEMPL_SYSTEM_BOOT_CLASSPATH => q[],
    TEMPL_SYSTEM_EXT_DIRS       => q[],
  };

  my $text = translate_template( $template_java_config_file,
                                 $template_config );
  
  write_file( $file, $text );
  
  print( "Template Java configuration written to '$file'\n" );
}

sub write_c_cpp_config_file
{
  my ( $file, $dirs, $features, $macros ) = @_;

  # Set up the template configuration and translate the template.
  # The, write the config file out.

  my $template_config = {};
  
  my $lang = $features->{'lang'};
  my $ns = "beam::compiler::${lang}";
  
  # Set up the version
  
  $template_config->{'TEMPL_VERSION'} = $version;
  
  # Set up the template namespace

  $template_config->{'TEMPL_NS'} = $ns;

  # Set up our invocation
  
  $template_config->{'TEMPL_CONFIGURE_INVOCATION'} = $invocation;
  
  # Set up the compiler's full path
  
  if ( $features->{'testing_mode'} ) {
    $template_config->{'TEMPL_COMPILER_PATH'} = 'testing mode';
  } else {
    $template_config->{'TEMPL_COMPILER_PATH'} =
      fn_path_to_ext( $features->{'compiler_path'} );
  }
  
  # Indicate that this file was generated
  $template_config->{'TEMPL_GENERATED'} = set_qvar($lang, "generated_by_beam_configure", $version);
  
  # Set up the compiler, if it is known
  
  my $cc = "default";
  
  foreach my $try ( qw(gcc xlc vac msvc vacwin icc zosvac) ) {
    if ( exists $features->{$try} ) {
      $cc = $try;
      last;
    }
  }
  
  $template_config->{'TEMPL_CC'} = set_qvar($lang, "cc", $cc);
  
  # Set up the language mode - gnu?
  
  $template_config->{'TEMPL_GNU_MODE'} = '';
  
  if ( exists $features->{'gnu_mode'} ) {
    
    # Ensure a minimum of 30200
    my $ver = $features->{'gnu_mode'};
    
    if ( $ver < 30200 ) {
      print STDERR "\n";
      print STDERR "Warning: GNU version '$ver' is smaller than the minimum\n";
      print STDERR "         supported version of '30200'. '30200' will be used,\n";
      print STDERR "         and may work with your compiler's headers, but\n";
      print STDERR "         this configuration may cause problems.\n";
      
      $ver = 30200;
    }
    
    $template_config->{'TEMPL_GNU_MODE'} = set_var($lang, "gnu_mode", $ver);
  }
  
  # msvc?
  
  $template_config->{'TEMPL_MSVC_MODE'} = '';

  if ( exists $features->{'msvc'} ) {
    
    # Ensure a minimum of 700
    my $ver = $features->{'msvc'};
    
    if ( $ver < 700 ) {
      print STDERR "\n";
      print STDERR "Warning: MSVC version '$ver' is smaller than the minimum\n";
      print STDERR "         supported version of '700'. '700' will be used,\n";
      print STDERR "         and may work with your compiler's headers, but\n";
      print STDERR "         this configuration may cause problems.\n";
      
      $ver = 700;
    }
    
    $template_config->{'TEMPL_MSVC_MODE'} = set_var($lang, "msvc_mode", $ver);
  }
  
  # VisualAge for Windows requires a msvc_mode of 1400
  
  if ( exists $features->{'vacwin'} ) {
    $template_config->{'TEMPL_MSVC_MODE'} = set_var($lang, "msvc_mode", "1400");
  }  

  # Miscellaneous language features
  
  my $lang_feature_string = "";
  
  foreach my $feat ( sort keys %$features ) {
    # Only look at language_* features for this section
    next unless $feat =~ /^language_/;
    
    $lang_feature_string .= set_qvar($lang,
                                     $feat,
                                     $features->{$feat},
                                     50);
  }
  
  $template_config->{'TEMPL_LANGUAGE_MISC'} = $lang_feature_string;
  
  
  # Set up the sys include path. Translate these to external paths.
  
  my $system_include_path_string = "";
  
  if ( exists $features->{'msvc'} || exists $features->{'vacwin'} ) {
    # These rely solely on the environment variable INCLUDE for the system include path
    $system_include_path_string = env_system_include_path($lang);
  } else {
    foreach my $dir ( @$dirs ) {
      # xlC sometimes finds headers in /usr/include/sys, which is bad - skip that dir
      if ( $dir ne "/usr/include/sys" ) {
        $dir = fn_path_to_ext( $dir );
        $system_include_path_string .=
          "lappend ${ns}::system_include_path {$dir}\n";
      }
    }
  }
    
  $template_config->{'TEMPL_SYSTEM_INCLUDE_PATH'} = $system_include_path_string;
  
  # Set up the features
  
  my $feature_string = "";
  
  foreach my $feat ( sort keys %$features ) {
    # Only look at target_* features for this section
    next unless $feat =~ /^target_/;

    $feature_string .= set_qvar($lang,
                                $feat,
                                $features->{$feat},
                                50);
  }
  
  $template_config->{'TEMPL_TARG_FEATURES'} = $feature_string;
  
  # Set up the predefined macros
  
  my @predefined_macros;

  # For MSVC, ignore __pragma - it's nasty and doesn't expand right. It's
  # not a macro, so we can toss it.
  
  if ( exists $features->{'msvc'} ) {
    delete $macros->{'__pragma'};
  }
  
  foreach my $macro ( sort keys %$macros ) {    
    push @predefined_macros, predefined_macro_text( $lang,
                                                    $macro,
                                                    $macros->{$macro} );
  }

  # For all GCC versions, treat __builtin_expect to just expand
  # to its first argument. This is so BEAM knows that the value
  # returned is the same as the value given.
  
  if ( exists $features->{'gcc'} ) {
    push @predefined_macros, predefined_macro_text( $lang,
                                                    '__builtin_expect(_x,_y)',
                                                    '(_x)' );
  }

  # For vac or xlc, define __offsetof(type, member) because it is built-in
  # to the compiler. Also define __vastart(arg), which is also built-in.
  
  if ( exists $features->{'xlc'} || exists $features->{'vac'} ) {
    push @predefined_macros,
      predefined_macro_text( $lang,
                             '__offsetof(_t,_m)',
                             '__INTADDR__(&(((_t *)0)->_m))' ),
      predefined_macro_text( $lang,
                             '__vastart(_a)',
                             '((va_list)(&(_a)))' );
  }
  
  # For zosvac, define __offsetof(type, member) because it is built-in
  # to the compiler. Also define misc other macros to define away certain
  # keywords which we're too lazy to test for explicitly.
  
  if ( exists $features->{'zosvac'} ) {
    push @predefined_macros,
      predefined_macro_text( $lang,
                             '__offsetof(_t,_m)',
                             '(__SIZE_TYPE__)&(((_t *)0)->_m)' );
    foreach my $key ( @zosvac_keywords ) {
      push @predefined_macros,
        predefined_macro_text( $lang,
                               $key,
                               ' ' x length($key) );
    }
  }

  # Add in any decl keywords that were discovered
  
  foreach my $key ( @decl_keywords ) {
    if ( exists $features->{$key} ) {
      push @predefined_macros,
        predefined_macro_text( $lang,
                               $key,
                               ' ' x length($key) );
    }
  }
  
  # For vac 7 and higher, define __BUILD_RT__, which according to
  # the v7 headers, removes constructs that we can't handle, like
  # _ExternStaticBuiltin decl...
  
  if ( exists $features->{'vac'} && $features->{'vac'} >= 0x0700 ) {
    push @predefined_macros, predefined_macro_text( $lang,
                                                    '__BUILD_RT__',
                                                    '1' );
  }
  
  # Add all the macros to the template
  
  $template_config->{'TEMPL_PREDEFINED_MACROS'} =
    join( '', @predefined_macros );

  # Add standard exceptions
  
  $template_config->{'TEMPL_STANDARD_EXCEPTIONS'} = '';

  if ( exists $features->{'undefined_standard_macros'} ) {
    my $macros = $features->{'undefined_standard_macros'};
    $template_config->{'TEMPL_STANDARD_EXCEPTIONS'} =
      set_var($lang, "standard_predefined_macros", qq{"* - $macros"});
  }

  # Set up the extern for xlc and vac
  
  $template_config->{'TEMPL_EXTERN'} = "";
  
  if ( exists $features->{'vac'} ||
       exists $features->{'xlc'} ||
       exists $features->{'vacwin'} ) {
    $template_config->{'TEMPL_EXTERN'} = set_qvar($lang, "extern(builtin)", "C");
  }

  # Set up the extern for zosvac
  if ( exists $features->{'zosvac'} ) {
    foreach my $name ( qw(builtin OS os PLI) ) {
      $template_config->{'TEMPL_EXTERN'} .= set_qvar($lang, "extern($name)", "C");
    }
  }
  
  # Set up predefined function_names

  $template_config->{'TEMPL_FUNCTION_NAME'} = "";
  foreach my $name ( @predefined_function_names ) {
    my $var = "function_name_is_string_literal($name)";
    my $val = $features->{$var};

    if ( "$val" ne "undef" ) {
      $template_config->{'TEMPL_FUNCTION_NAME'} .= set_var($lang, $var, $val);
    }
  }

  # Done - write the config file
  
  my $text = translate_template( $template_c_cpp_config_file,
                                 $template_config );

  write_file( $file, $text );
  
  print "Configuration written to '$file'\n";
}

sub write_java_config_file
{
  my ( $file, $properties ) = @_;

  # Set up the template configuration and translate the template.
  # Then, write the config file out.
  
  my $template_config = {};
  
  my $ns = "beam::compiler::java";
  
  my $value;
  my @items;
  
  # Set up the version
  
  $template_config->{'TEMPL_VERSION'} = $version;
  
  # Set up our invocation
  
  $template_config->{'TEMPL_CONFIGURE_INVOCATION'} = $invocation;
  
  # Set up the compiler's full path
  
  $template_config->{'TEMPL_COMPILER_PATH'} =
    fn_path_to_ext( $properties->{'compiler_path'} );

  # Indicate that this file was generated
  $template_config->{'TEMPL_GENERATED'} = set_qvar("java", "generated_by_beam_configure", $version);
  
  # Set up the compiler
  
  # FIXME: Detect IBM and Sun JVMs here?
  
  $template_config->{'TEMPL_CC'} = set_qvar("java", "cc", "javac");
  
  # Set up the language source level

  $value = "";
  
  if ( exists $properties->{'language_source_level'} ) {
    $value = set_qvar("java",
                      "language_source_level",
                      $properties->{'language_source_level'});
  }

  $template_config->{'TEMPL_LANGUAGE_SOURCE_LEVEL'} = $value;  

  # Set up the language encoding

  $value = "";
  
  if ( exists $properties->{'language_encoding'} ) {
    $value = set_qvar("java",
                      "language_encoding", 
                      $properties->{'language_encoding'} );
  }
  
  $template_config->{'TEMPL_LANGUAGE_ENCODING'} = $value;

  # Set up the endorsed directories
  # These are straight from Java, so they are external already.

  @items = ();
  
  foreach my $dir ( @{ $properties->{'system_endorsed_dirs'} } ) {
    push @items,
      sprintf( "lappend ${ns}::system_endorsed_dirs {%s}\n", $dir );
  }
  
  $template_config->{'TEMPL_SYSTEM_ENDORSED_DIRS'} = join '', @items;

  # Set up the boot classpath
  # This is straight from Java, so they are external already.  

  @items = ();
  
  foreach my $path ( @{ $properties->{'system_boot_classpath'} } ) {
    push @items, sprintf( "lappend ${ns}::system_boot_classpath {%s}\n", $path );
  }
  
  $template_config->{'TEMPL_SYSTEM_BOOT_CLASSPATH'} =
    join '', @items;
  
  # Set up the extension directories
  # These are straight from Java, so they are external already.

  @items = ();

  foreach my $dir ( @{ $properties->{'system_ext_dirs'} } ) {
    push @items, sprintf( "lappend ${ns}::system_ext_dirs {%s}\n", $dir );
  }
  
  $template_config->{'TEMPL_SYSTEM_EXT_DIRS'} = join '', @items;
  
  # Done - write the config file
  
  my $text = translate_template( $template_java_config_file,
                                 $template_config );

  write_file( $file, $text );
  
  print "Configuration written to '$file'\n";
}

####################
# Template translation

sub translate_template
{
  my ( $template, $config ) = @_;

  # Take each key in $config and replace that text in the template
  # with the value in the config hash.
  
  foreach my $opt ( keys %$config ) {
    my $val = $config->{$opt};
    
    $template =~ s/\Q$opt\E/$val/g;
  }
  
  return $template;
}
    
####################
# Macro utilities

sub predefined_macro_text
{
  my ( $lang, $macro, $value ) = @_;
  
  # Create the text for defining a macro in the config file
  
  my $varname = sprintf( "beam::compiler::${lang}::predefined_macro(%s)", $macro );
  
  my $text    = sprintf( "set %-55s {%s}\n", $varname, $value );
  
  return $text;
}

sub expand_macros
{
  my ( $compiler, $macro_list, $include_list ) = @_;
  
  # Try to expand the macros using both the preprocessor and
  # native executables to be thorough. Return a hash that
  # contains the macros that were expanded.

  my $num = scalar( @$macro_list );
  verbose 2, "Trying to expand $num macros any way we can";
  
  my $macros = {}; # This will be filled in
  
  expand_macros_preproc( $compiler, $macros, $macro_list, $include_list );
  expand_macros_binary( $compiler, $macros, $macro_list, $include_list );

  $num = scalar( keys %$macros );
  verbose 2, "- Expanded $num macros";
  
  return $macros;
}

sub expand_macros_preproc
{
  my ( $compiler, $macros, $macro_list, $include_list ) = @_;

  # Use the preprocessor to expand the macros

  verbose 2, "Trying macro expansions with the preprocessor";

  # Default to an empty list to ease logic
  $macro_list = [] unless defined $macro_list;
  
  # Since there may be many identifiers to try, they should
  # be done in chunks. This is because building up the source
  # file in memory, then getting the output from the preprocessor,
  # might amount to a couple of pretty large strings.
  
  my $num_macros = scalar( @$macro_list );
  my $i = 0;
  
  while ( $i < $num_macros ) {
    my $source = "";

    $source .= include_headers( @$include_list );
  
    # Add one line for each macro. The string is so
    # that portion isn't expanded and we can find it
    # in the pre-processing output. The beam_end is
    # so we can find multi-line macros.

    # Walk up the part of the list between $i and $i + 2000,
    # making sure not to go off the end
    
    my $next_i = $i + 2000;
    
    for ( ; $i < $num_macros && $i < $next_i; $i++ ) {
      $source .= macro_preproc_expansion_source( $macro_list->[$i] );
    }

    my ( $rc, $output ) = preprocess_source( $compiler, $source );
  
    # Search the output for the expanded macros
  
    if ( $rc == 0 ) {
      gather_macro_expansions( $output, $macros );
    }
  }
}

sub expand_macros_binary
{
  my ( $compiler, $macros, $macro_list, $include_list ) = @_;
  
  # Compile a binary to expand the macros

  verbose 2, "Trying macro expansions with a native binary";
  
  # Since there may be many identifiers to try, they should
  # be done in chunks. This is because building up the source
  # file in memory, then getting the output from the preprocessor,
  # might amount to a couple of pretty large strings.
  
  my $num_macros = scalar( @$macro_list );
  my $i = 0;
  
  while ( $i < $num_macros ) {
    my $source = "";
  
    $source .= include_headers( @$include_list );

    # Add our magic expansion macros that use a double-expansion
    # trick to get the stringified expansion of things
    #
    # The problem with the obvious:
    #
    #   #define str(x) #x
    #   printf("#define foo %s\n", str(foo));
    #
    # is that it prints:
    #
    #   #define foo foo
    #
    # i.e. you get the stringification before expansion. This trick
    # gets around that:
    #
    #   #define str1(x) #x
    #   #define str(x) str1(x)
    #   printf("#define foo %s\n", str(foo));
    #
    # This header also adds the first part of main()

    $source .= macro_header_source();

    # Walk up the part of the list between $i and $i + 2000,
    # making sure not to go off the end. Add a line for
    # each macro we want to test.
    
    my $next_i = $i + 2000;
    
    for ( ; $i < $num_macros && $i < $next_i; $i++ ) {
      $source .= macro_test_source( $macro_list->[$i] );
    }
   
    # End the main()
    $source .= macro_footer_source();

    # Compile the source and run the binary

    my ( $rc, $output ) =
      compile_source_and_run( $compiler, $source );
  
    if ( $rc == 0 ) {
      gather_macro_expansions( $output, $macros );
    }
  }
}

sub gather_macro_expansions
{
  my ( $output, $macros ) = @_;
  
  # Search through the output for the format we use
  # to delimit macro expansions and set them up 
  # in the hash ref
  
  while ( $output =~ /\s*"beam_macro ($identifier_re)"(.*?)"beam_end"/ogs ) {
    my $id = $1;
    my $exp = $2;
    
    # Trim whitespace
    $exp =~ s/^\s+//;
    $exp =~ s/\s+$//;

    # Make sure it expanded
    if ( $id ne $exp ) {
      # If it has already been expanded, make sure the expansions match
      if ( exists $macros->{$id} ) {
        if ( $macros->{$id} ne $exp ) {
          print STDERR "\n";
          print STDERR "Warning: Expansion of macro '$id' has changed...\n";
	  print STDERR "         This is very odd...\n";
        }
      }
      
      # Save this expansion
      $macros->{$id} = $exp;
      
      verbose 2, "- Macro '$id' expanded to '$exp'";
    }
  }
}

sub compiler_macros
{
  my ( $compiler, $macros ) = @_;
  
  # Run the compiler macro flags, and get the output.
  # Search through the output for macro definitions.
  
  my ( $rc, $output ) = compile_get_macros( $compiler );
  
  if ( $rc == 0 ) {
    # Search through output for macros, filtering out the ones
    # we should be ignoring

    # Look for '#define id value'
    while ( $output =~ /^[ \t]*#[ \t]*define[ \t]+($identifier_re)[ \t]*([^\r\n]*)\r?$/gom ) {
      if ( ! exists $macros_to_ignore{$1} ) {
        $macros->{$1} = $2;
        verbose 2, "- Compiler Macro '$1' expands to '$2'";
      }
    }
  }
}

sub header_macros
{
  my ( $compiler, $macros, @dirs ) = @_;
  
  # Search for headers in each directory in @dirs. For each
  # header found, search in the header for identifiers that
  # could be macro names. Try to expand each of those, and
  # place the ones that do expand into %$macros.
  
  my @headers = find_header_files( @dirs );
  
  my @to_expand_before = find_identifiers( @headers );

  # Filter-out unwanted macros

  my @to_expand;
  
  foreach my $m ( @to_expand_before ) {
    if ( ! exists $macros_to_ignore{$m} ) {
      push @to_expand, $m;
    }
  }
  
  # Add in additional macros
  
  push @to_expand, @macros_to_try;
  
  # Expand what's left...
  
  my $expanded_macros = expand_macros( $compiler, \@to_expand );
  
  # Copy the macros into $macros
  
  foreach my $m ( keys %$expanded_macros ) {
    $macros->{$m} = $expanded_macros->{$m};
  }
}
  
####################
# Sizeof and alignof utilities

sub compiler_sizeof
{
  my ( $compiler, $type, $header_list ) = @_;
  
  # Try to determine the type's size in two ways:
  #
  # - If we can compile native binaries, we can simply
  #   print out the size using sizeof()
  #
  # - If we can't compile native binaries, we can try
  #   a trick with constant expressions:
  #
  #     int array[ (sizeof(type) == 4) ? 1 : -1 ];
  #
  #   Most compilers will succeed compiling that if
  #   the size is 4, and fail otherwise, because the
  #   array will be declared with a bound of -1. We
  #   can try this with 2, 4, 8, 12, 16, 20, 24... slow,
  #   but better than nothing.

  verbose 2, "Determining sizeof($type) with a native binary";
  
  my $source = "";
  
  $source .= include_headers( @$header_list );
  $source .= runtime_sizeof_source( $type );
    
  my ( $rc, $output ) =
    compile_source_and_run( $compiler, $source );
  
  if ( $rc == 0 ) {
    if ( $output =~ /(\d+)/ ) {
      verbose 2, "- Native binary says sizeof($type) == $1";
      return $1;
    } else {
      verbose 2, "- Native binary sizeof failed (unexpected output)";
    }
  }
  
  # Try with slow magic... replace BEAM_SIZE in the template
  # with some sizes and see if it ever compiles successfully.
  # If it does, the size should be right.
  #
  # Note: If the compiler doesn't support this trick, I won't
  # waste my time
  
  if ( defined $compiler->{'constant_expression_trick'} &&
       $compiler->{'constant_expression_trick'} eq 'yes' ) {
    # Give it a try
  } else {
    verbose 2, "- Size could not be determined for type";
    verbose 2, "   (skipping constant expression trick)";
    return undef;
  }
  
  verbose 2, "Determining sizeof($type) with a constant expression trick";
  
  $source = "";
  
  $source .= include_headers( @$header_list );
  $source .= template_sizeof_source( $type );
    
  foreach my $num ( qw(2 4 8 12 16 20 24) ) {
    my $tmpsource = $source;
    $tmpsource =~ s/\bBEAM_SIZE\b/$num/;
    
    ( $rc ) = compile_source( $compiler, $tmpsource );
    
    if ( $rc == 0 ) {
      verbose 2, "- Constant expression magic worked for $num";
      return $num;
    } else {
      verbose 2, "- Constant expression trick failed for $num";
    }
  }
  
  verbose 2, "- Size could not be determined for type '$type'";
  return undef;
}

sub compiler_alignof
{
  my ( $compiler, $type ) = @_;
  
  # Try to determine the alignment in two ways:
  #
  # - If we can compile native binaries, we can simply
  #   print out the alignment using a macro that tests
  #   the offset in a structure
  #
  # - If we cacn't compile native binaries, we can simply
  #   use a trick with constant expressions (see compiler_sizeof)
  
  verbose 2, "Determining alignof($type) with a native binary";
  
  my $source = "";
  
  $source .= runtime_alignof_source( $type );
    
  my ( $rc, $output ) =
    compile_source_and_run( $compiler, $source );
  
  if ( $rc == 0 ) {
    if ( $output =~ /(\d+)/ ) {
      verbose 2, "- Native binary says alignof($type) == $1";
      return $1;
    } else {
      verbose 2, "- Native binary alignof failed (unexpected output)";
    }
  }

  # Try with slow magic... replace BEAM_ALIGN in the template
  # with some sizes and see if it ever compiles successfully.
  # If it does, the alignment should be right.
  #
  # Note: If the compiler doesn't support this trick, I won't
  # waste my time
  
  if ( defined $compiler->{'constant_expression_trick'} &&
       $compiler->{'constant_expression_trick'} eq 'yes' ) {
    # Give it a try
  } else {
    verbose 2, "- Alignment could not be determined for type";
    verbose 2, "   (skipping constant expression trick)";
    return undef;
  }
  
  verbose 2, "Determining alignof($type) with a constant expression trick";
  
  $source = "";
  
  $source .= template_alignof_source( $type );
    
  foreach my $num ( qw(2 4 8 12 16 20 24) ) {
    my $tmpsource = $source;
    $tmpsource =~ s/\bBEAM_ALIGN\b/$num/;
    
    ( $rc ) = compile_source( $compiler, $tmpsource );
    
    if ( $rc == 0 ) {
      verbose 2, "- Constant expression magic worked for $num";
      return $num;
    } else {
      verbose 2, "- Constant expression trick failed for $num";
    }
  }
  
  verbose 2, "- Alignment could not be determined for type '$type'";
  return undef;
}

