# Pass a value of type __builtin_va_list to a float *. That should cause
# a parse error when compiled as C++.
sub builtin_va_list_base_type_source
{
  my $source = <<"EBUILTINVALISTBASETYPE";

  void bar(float *);
  void foo(char *fmt, ...)
  {
    __builtin_va_list __args;
    __builtin_va_start(__args, fmt);

    bar(__args);

    __builtin_va_end(__args);
  }
  
EBUILTINVALISTBASETYPE
    
  return $source;
}

####################
# Compiler Utilities

sub c_value
{
  my ( $str ) = @_;
  
  # This tries to turn a C expression that should be a number
  # into a Perl number (as opposed to a Perl string) by doing
  # some things like stripping off the parenthesis (some
  # compilers like to define things to be "(n)" instead of "n").
  #
  # This also detects "X - Y" and "X + Y" and does the evaluation,
  # for defines like
  #
  #   #define CHAR_MIN (-127 - 1)
  
  # Detect simple arithmetic and evaluate the result.
  # Simple arithmetic only contains:
  #
  #  - Numbers and hex digits
  #  - Parenthesis, with no identifier in front of them (No functions)
  #  - Decimal points
  #  - Hex literal prefixes ("0x")
  #  - Operations (*, /, +, -)
  
  if ( $str =~ m|^[0-9abcdefx\(\) .*/+-]+$|i &&
       $str !~ m|$identifier_re\s*\(| ) {
    # Evaluate the number.
    my $num = do {
      local $SIG{__DIE__} = sub {};
      local $SIG{__WARN__} = sub {};
      eval $str;
    };

    # If the eval succeeded, use the result.
    return $num unless ( $@ );
  }

  # Nothing worked so far. Just return it as a string...
  # and hope the caller knows what to do with it.

  verbose 1, "Warning: Couldn't convert '$str' into a c_value";
  
  return $str;
}

sub cv_run_tests
{
  # Run some c_value tests and return 0 if successful.
  # Return non-zero on failure.

  my $tests = [
    # String, Result
    [ "", "" ],
    [ "123", 123 ],
    [ "(123)", 123 ],
    [ "0123", 0123 ],
    [ "0xcafebabe", 0xcafebabe ],
    [ "1.23E-4", 1.23e-4 ],
    [ "3.2e5 + 1.1e6", 3.2e5 + 1.1e6 ],
    [ "(1 + 2) * 3", (1 + 2) * 3 ],
    [ "(2 2 3)", "(2 2 3)" ],
    [ "(2 + 3", "(2 + 3" ],
    [ "3 * x(2)", "3 * x(2)" ]
  ];
  
  my $rc = 0;
  
  foreach my $test ( @$tests ) {
    my $str = $test->[0];
    my $exp = $test->[1];
    
    my $act = c_value( $str );
    
    if ( $exp ne "$act" ) {
      print STDERR "Error: c_value( $str ) test failed.\n";
      print STDERR "  Expected '$exp', got '$act'\n";
      $rc = 1;
    }
  }
  
  return $rc;
}

sub compile_get_macros
{
  my ( $compiler ) = @_;
  
  # Try to run the compiler and get the macro output

  my @cmd = @{ $compiler->{'cmd'} };
  push @cmd, @{ $compiler->{'macro_flag'} };
  
  my $ext = $compiler->{'ext'};
  
  my $srcnam = write_temp_file( '', $ext );
  
  push @cmd, fn_path_to_ext( $srcnam );
  
  return run_command( @cmd );
}

sub preprocess_command
{
  my ( $compiler ) = @_;
  
  my @cmd = @{ $compiler->{'cmd'} };
  push @cmd, @{ $compiler->{'preproc_flag'} };

  if ( wantarray ) {
    return @cmd;
  } else {
    return join( " ", @cmd );
  }
}

sub preprocess_source
{
  my ( $compiler, $source ) = @_;
  
  # Set up the options and preprocess the source text as a file.

  my @cmd = preprocess_command( $compiler );
  
  my $ext = $compiler->{'ext'};
  
  return run_compiler_on_source( $source, $ext, @cmd );
}

sub compile_command
{
  my ( $compiler ) = @_;
  
  my @cmd = @{ $compiler->{'cmd'} };
  push @cmd, @{ $compiler->{'compile_flag'} };
  
  if ( wantarray ) {
    return @cmd;
  } else {
    return join( " ", @cmd );
  }  
}

sub compile_source
{
  my ( $compiler, $source ) = @_;
  
  # Set up the options and compile the source text as a file
  
  my @cmd = compile_command( $compiler );
  
  my $ext = $compiler->{'ext'};
  
  return run_compiler_on_source( $source, $ext, @cmd );
}

sub compile_source_to_binary
{
  my ( $compiler, $source ) = @_;
  
  # Set up the options and compile the source to a native binary.
  # Return a 4 item array of $rc, $output, $error, $binary_name.
  
  my $binnam = write_temp_file( '', 'bin' );
  my $extbin = fn_path_to_ext( $binnam );
  
  my @cmd = @{ $compiler->{'cmd'} };

  my @bin_flags = @{ $compiler->{'bin_flag'} };
  
  # All "%s" in @bin_flags is replaced with $extbin.
  map { s|%s|$extbin| } @bin_flags;
  
  push @cmd, @bin_flags;
  
  my $ext = $compiler->{'ext'};
  
  my ( $rc, $output, $error ) =
    run_compiler_on_source( $source, $ext, @cmd );

  if ( $rc == 0 ) {
    # Make sure it is executable, since we created the temp
    # file with 0600 permissions initially...
    chmod( 0700, $binnam );
  }

  return ( $rc, $output, $error, $binnam );
}

sub compile_source_and_run
{
  my ( $compiler, $source ) = @_;

  # Compile the source to a native binary, run it, and return
  # the rc and output. The rc may be of either the compiler
  # or the command.
  
  my ( $rc, $output, $error, $binary )
    = compile_source_to_binary( $compiler, $source );

  if ( $rc != 0 ) {
    verbose 2, "- Compiler failed creating a native binary";
    return ( $rc, $output, $error );
  }
  
  ( $rc, $output, $error ) = run_command( $binary );
 
  if ( $rc != 0 ) {
    verbose 2, "- Native binary failed";
  }
    
  return ( $rc, $output, $error );
}  

sub compile_source_to_class
{
  my ( $compiler, $source ) = @_;
  
  # Set up the options and compile the source to a class file.
  # Return a 4 item array of $rc, $output, $error, $classdir.
  
  my $dirname = $global_temp_dir;
  
  my @cmd = @{ $compiler->{'cmd'} };
  push @cmd, '-d', fn_path_to_ext( $dirname );
  
  my $ext = $compiler->{'ext'};
  
  my ( $rc, $output, $error ) =
    run_compiler_on_source( $source, $ext, @cmd );

  return ( $rc, $output, $error, $dirname );
}

sub run_class_file
{
  my ( $compiler, $name, $classdir ) = @_;
  
  # Using $compiler to find the java runtime,
  # run the class file named by $name in the
  # $classdir directory.
  #
  # Returns $rc, $stdout, and $stderr.
  
  my @cmd = @{ $compiler->{'java_cmd'} };
  push @cmd, '-classpath', fn_path_to_ext( $classdir );
  push @cmd, $name;
  
  return run_command( @cmd );
}

sub compile_source_and_run_java
{
  my ( $compiler, $name, $source ) = @_;

  # Compile the source to a class file (the source
  # should have a "class $name" in it) run it with java,
  # and return the rc and output. The rc may be of either
  # the compiler or the command.
  
  my ( $rc, $output, $error, $classdir )
    = compile_source_to_class( $compiler, $source );

  if ( $rc != 0 ) {
    verbose 2, "- Compiler failed creating class file";
    return ( $rc, $output, $error );
  }
  
  ( $rc, $output, $error ) =
    run_class_file( $compiler, $name, $classdir );
  
  if ( $rc != 0 ) {
    verbose 2, "- Executing class file failed";
  }
    
  return ( $rc, $output, $error );
}  

sub run_compiler_on_source
{
  my ( $source, $ext, @cmd ) = @_;
  
  # Write out a temporary source file with the given extension,
  # run the command over it, and return the results

  my $srcnam = write_temp_file( $source, $ext );
  
  push @cmd, fn_path_to_ext( $srcnam );
  
  verbose 2, "Running the compiler on '$srcnam'";
  
  if ( $verbose > 2 ) {
    print "* Source file contents of '$srcnam':\n";
    print $source;
    print "* End source file '$srcnam'\n";
  }
  
  return run_command( @cmd );
}

####################
# Misc utilities

sub get_output_file_name
{
  my ( $output, $lang, $force, $def_name ) = @_;
 
  my $file_name;
  
  # Figure out the output file name.
    
  if ( defined $output ) {
    # If $output was given, use that.
    $file_name = $output;
  } else {
    # Otherwise, generate a name from def_name.
    die "Internal Error: \$def_name is undefined\n" unless defined $def_name;

    $file_name = output_file_name( $def_name, $lang );
  }
  
  # Ensure the file doesn't exist, or --force was given.
  if ( -e $file_name && ! $force ) {
    die "Error: Output file '$file_name' exists; use '--force' to overwrite\n";    
  }

  # All is well.

  return $file_name;
}

sub output_file_name
{
  my ( $name, $lang ) = @_;
  
  # Build the output file name based on name and lang
  
  return "${original_dir}/${name}_${lang}_config.tcl";
}

sub find_exe
{
  my ( $prog ) = @_;

  # Return an absolute path to $prog.
  #
  # Don't use full_pathify because we want all symlinks
  # to be preserved. Some places rely on the compiler
  # being invoked through a symlink, for example.

  if ( fn_is_bare( $prog ) ) {
    my $found = find_in_path( $prog );
    
    if ( defined $found ) {
      $prog = $found;
    }
  } else {

    if ( $^O =~ /mswin32/i ) {
      # In Windows, the PATHEXT stuff applies to full paths
      my $found = find_prog_with_pathext( $prog );
      
      if ( defined $found ) {
        $prog = $found;
      }
    }
    
    # $prog is a relative or absolute path name. If relative,
    # prepend the absolute path of ".".
    
    if ( ! fn_is_absolute( $prog ) ) {
      $prog = fn_full_pathify(".") . "/" . $prog;
    }
  }
  
  return $prog;
}

sub find_in_path
{
  my( $prog ) = @_;
  
  # If $prog is a bare name, search for it on the $PATH.
    
  my @path = split( /$fn_pathsep_re/, $ENV{'PATH'} );
    
  if ( $^O =~ /mswin32/i ) {
    # Windows implicitly searches "." first
    unshift @path, ".";
  }
  
  foreach my $dir ( @path ) {
    if ( -f "$dir/$prog" ) {
      return "$dir/$prog";
    }
      
    if ( $^O =~ /mswin32/i ) {
      # Windows can also find binaries by appending PATHEXT extensions
      # on to the names it tries.
      my $found = find_prog_with_pathext( "$dir/$prog" );
        
      if ( defined $found ) {
        return $found;
      }
    }
  }
  
  # Not found
  return undef;
}

sub find_prog_with_pathext
{
  my ( $prog ) = @_;
  
  # This routine should only do things on Windows
  return unless $^O =~ /mswin32/i;
  
  # Search for $prog, first as a bare name, and then once with each
  # extension in the environment variable PATHEXT.
  # 
  # If PATHEXT is unset, the Windows 2000 and Windows XP defaults
  # seem to be ".COM;.EXE;.BAT;.CMD;.VBS;.JS;.WS". These were
  # found by inspection.
  
  my @pathext;
  
  if ( exists $ENV{'PATHEXT'} && $ENV{'PATHEXT'} ne "" ) {
    @pathext = split( /$fn_pathsep_re/, $ENV{'PATHEXT'} );
  } else {
    @pathext = split( /;/, ".COM;.EXE;.BAT;.CMD;.VBS;.JS;.WS" );
  }
  
  # Push the empty string on the front so we test just plain $prog
  # first.
  
  unshift @pathext, "";
  
  foreach my $ext ( @pathext ) {
    if ( -f "$prog$ext" ) {
      return "$prog$ext";
    }
  }

  # Not found in this location with any known extension
  return undef;
}

sub change_to_temp_dir
{
  chdir( $global_temp_dir )
    or die "Error: Can't change directories to '$global_temp_dir': $!\n";
  
  verbose 1, "Changed directories to '$global_temp_dir'";
}

sub make_unique
{
  my ( @list ) = @_;
  
  # Remove duplicate entries from @list without
  # changing the order
  
  my %hash;
  my @result;
  
  foreach my $item ( @list ) {
    if ( ! exists $hash{$item} ) {
      $hash{$item} = 1;
      push @result, $item;
    }
  }

  return @result;
}

sub find_header_files
{
  my ( @dirs ) = @_;
  
  # Find all header files in the directories
  # and return a listing of full paths to them
  
  my @headers;
  my $dirfh = gensym();
  
  foreach my $dir ( @dirs ) {
    verbose 2, "- Searching '$dir' for header files";
    
    if ( opendir( $dirfh, $dir ) ) {
      # Read all files, prepend $dir as they pass, and test for -T
      # all on one pipeline

      push @headers, grep { -f && -T } map { "$dir/$_" } readdir( $dirfh );
      
      closedir( $dirfh );
    }
  }
  
  my $num = scalar @headers;
  verbose 2, "- Found $num header file(s)";
  
  return @headers;
}

sub find_identifiers
{
  my ( @files ) = @_;
  
  # Search through each file for possible macro names, and return
  # a list of them

  verbose 2, "Searching headers for macro identifiers (this may take a while)";
  
  my %macros;
  
  my $fh = gensym();
  
  foreach my $file ( @files ) {
    # Open the file and search for macro identifiers
    if ( open( $fh, $file ) ) {
            
      my $line;
      
      while ( defined( $line = <$fh> ) ) {
                    
        # There could be many on each line...
        # According to C99 6.2.4.1, this is close enough -
        #  it won't catch universal identifiers though
        while ( $line =~ /\b($identifier_re)\b/go ) {
          $macros{$1} = 1;
        }
      }
      
      close( $fh );
    }
  }
  
  return keys %macros;
}

####################
# Low level utilities

sub run_command
{
  my ( @cmd ) = @_;

  verbose 2, "+ @cmd";
  
  my ( $rc, $stdout, $stderr, $sig ) = cmd_capture( @cmd );
  
  # In verbose mode, print the rc and any error output if the rc failed

  verbose 2, "+ rc = $rc";
  verbose 2, "+ sig = $sig";
  
  if ( $verbose > 2 ) {
    if ( $rc != 0 ) {
      print "+ Command STDOUT:\n";
      print $stdout;
      print "+ Command STDERR:\n";
      print $stderr;
      print "+ End Command Output\n";
    }
  }
  
  return ( $rc, $stdout, $stderr, $sig );
}

sub read_file
{
  my ( $name ) = @_;
    
  if ( ! open( FILE, "<$name" ) ) {
    die "Can't open $name: $!\n";
  }
    
  local $/ = undef;
  my $data = <FILE>;
    
  if ( ! close( FILE ) ) {
    die "Can't close $name: $!\n";
  }
    
  return $data;
}

sub make_dir_for_file
{
  my ( $file ) = @_;

  # Ensure that the parent directory for $file
  # exists, so that $file may be written.

  my $dir = fn_full_pathify( $file );

  $dir = fn_dirname( $dir );
  
  verbose 2, "Creating directory '$dir' to write '$file'";
  
  mkpath( $dir );
}

sub write_file
{
  my ( $file, $text ) = @_;

  make_dir_for_file( $file );
  
  my $fh = gensym();
  
  if ( open( $fh, ">$file" ) ) {
    print $fh $text;
    close( $fh ) or die "Error: Can't write to '$file': $!\n";
  } else {
    die "Error: Can't write to '$file': $!\n";
  }
}

sub write_temp_file
{
  my ( $text, $ext ) = @_;
  
  # Write the text to a temp file and return the file's
  # name. Dies if there are problems.
  
  my ( $tmpfh, $tmpnam ) = get_temp_file( $ext );
  
  print $tmpfh $text;
  
  close( $tmpfh ) or die "Error: Can't write '$tmpnam': $!\n";
 
  # All is good
  return $tmpnam;
}

sub get_temp_file
{
  my $ext = shift;
  
  if ( ! -d $global_temp_dir ) {
    die "Error: Internal Error: Temporary Directory doesn't exist! " .
        "Notify Developer\n";
  }
  
  return tmp_file_in( $global_temp_dir, $ext );
}

