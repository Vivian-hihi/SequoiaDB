sub env_system_include_path
{
  my ($lang) = @_;
  my $ns = "beam::compiler::${lang}";
  my $str = <<"EENVSYSTEMINCLUDEPATH" ;

if { [::info exists ::env(INCLUDE)] } {
  set old_include_path {}
  if { [::info exists ${ns}::system_include_path] } {
    set old_include_path \$${ns}::system_include_path
  }
  set ${ns}::system_include_path [concat \$old_include_path \\
                                   [split \$::env(INCLUDE) \$::beam::pathsep]]
}

EENVSYSTEMINCLUDEPATH

  return $str;
}

