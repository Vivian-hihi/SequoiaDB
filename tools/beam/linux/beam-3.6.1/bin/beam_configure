    $features->{'target_sizeof_char32_t'} = $size;
  }
}

sub check_bool_is_keyword
{
  my( $compiler, $features ) = @_;
  
  # See if bool is a keyword in C++

  if ( $compiler->{'lang'} eq 'cpp' ) {
  
    verbose 2, "Checking if bool is a keyword in C++";
  
    my $source = bool_keyword_source();
  
    my( $rc ) = compile_source( $compiler, $source );
  
    if ( $rc != 0 ) {
      $features->{'language_bool_is_keyword'} = 0;
      verbose 2, "- bool is not a keyword";
    }  
  }
}

sub check_wchar_t_is_keyword
{
  my( $compiler, $features ) = @_;
  
  # See if wchar_t is a keyword in C++

  if ( $compiler->{'lang'} eq 'cpp' ) {
  
    verbose 2, "Checking if wchar_t is a keyword in C++";
  
    my $source = wchar_keyword_source();
  
    my( $rc ) = compile_source( $compiler, $source );
  
    if ( $rc != 0 ) {
      $features->{'language_wchar_t_is_keyword'} = 0;
      verbose 2, "- wchar_t is not a keyword";
    }  
  }
}

sub check_wchar_t_type
{
  my ( $compiler, $features ) = @_;
  
  # Try to get the type directly, by either pre-processing
  # stddef.h (works for C), or looking at __WCHAR_TYPE__
  # (works for GCC). I could not come up with a good way
  # to determine the underlying type for C++, even WITH
  # native binaries. Nothing worked reliably...

  my $source = include_headers( 'stddef.h' );
  
  my ( $rc, $output ) = preprocess_source( $compiler, $source );
  
  if ( $rc == 0 ) {
    if ( $output =~ /\btypedef\s+(.*?)\s+wchar_t\s*;/ ) {
      my $type = $1;
      $type =~ s/\s+/ /g; # Compress whitespace
      $features->{'target_wchar_t_int_kind'} = $type;
    }
  }
  
  # gcc defines __WCHAR_TYPE__ to give us the type directly
  
  my $macros =
    expand_macros( $compiler, [ '__WCHAR_TYPE__' ], [ 'stddef.h' ] );
  
  if ( exists $macros->{'__WCHAR_TYPE__'} ) {
    $features->{'target_wchar_t_int_kind'} = $macros->{'__WCHAR_TYPE__'};
  }
  
  
  # Try to figure out the size of wchar_t, in case we can't get
  # the type directly. This will help us guess later, if we need
  # to.

  my $size = compiler_sizeof( $compiler, 'wchar_t', [ 'stddef.h' ] );
  
  if ( defined $size ) {
    $features->{'target_sizeof_wchar_t'} = $size;
  }

  # Try to get the sign too - if we need to guess the type, this
  # will help guess signed or unsigned. We try to get the sign
  # with a native binary and with a constant expression trick.
  
  $source = wchar_sign_source();
  
  ( $rc, $output )
    = compile_source_and_run( $compiler, $source );
  
  if ( $rc == 0 ) {
    if ( $output =~ /target_wchar_t_is_unsigned=(\d+)/ ) {
      $features->{'target_wchar_t_is_unsigned'} = $1;
    }
  }
  
  # constant expression trick
  
  my $source1 = signed_wchar_source();
  my $source2 = unsigned_wchar_source();
    
  my ( $rc1 ) = compile_source( $compiler, $source1 );
  my ( $rc2 ) = compile_source( $compiler, $source2 );
    
  if ( $rc1 == 0 ) {
    $features->{'target_wchar_t_is_unsigned'} = 0;
  } elsif ( $rc2 == 0 ) {
    $features->{'target_wchar_t_is_unsigned'} = 1;
  }
}

sub check_wint_t_type
{
  my ( $compiler, $features ) = @_;
  
  # Try to get the type directly, by either pre-processing
  # stddef.h (works for C), or looking at __WINT_TYPE__
  # (works for GCC). I could not come up with a good way
  # to determine the underlying type for C++, even WITH
  # native binaries. Nothing worked reliably...

  my $source = include_headers( 'stddef.h' );
  
  my ( $rc, $output ) = preprocess_source( $compiler, $source );
  
