      printf("target_enum_types_can_be_smaller_than_int=1\n");
    } else {
      printf("target_enum_types_can_be_smaller_than_int=0\n");
    }
    
    return 0;
  }
  
ESMALLENUM
  
  return $source;
}

# In this testcase we try to modify a string literal by indexing
# directly into the literal itself. This will get caught at compile time
# if the compiler considers string literals to be const.
sub const_string_source
{
  my $source = <<'ECONSTSTRING' ;
  
  int main() {
    "abc"[1] = 'z';
    return 0;
  }
  
ECONSTSTRING
    
  return $source;
}

# Hardwire the windows case - segfaults on Windows pop up an annoying
# window, which we don't want the user to have to deal with.
# Note, that the compilability of "abc"[1] = 'x' makes no statement
# about whether string literals can be modified at runtime.
# So we really need to see the abnormal termination.
sub readonly_string_source
{
  my $source = <<'EREADONLYSTRING' ;
  
  #include <stdio.h>

  char *foo = "testing";
  
  int main() {
#if defined(__WIN32__) || defined(_WIN32)
    printf("1\n");  /* readonly */
#else
    /* This will usually segfault if string literals are in read only memory */
    foo[2] = 'x';
    /* Paranoia. */
    if ( foo[2] == 'x' )
      printf("0\n");  /* not readonly */
    else 
      printf("1\n");  /* readonly */
    return 0;
#endif
  }
  
EREADONLYSTRING
    
  return $source;
}

