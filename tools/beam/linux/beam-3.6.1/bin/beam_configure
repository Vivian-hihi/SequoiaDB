sub macro_header_source
{
  # Note: We don't use stdio.h here because it might introduce
  # extra macros that we aren't testing for. In some cases,
  # when we test for predefined macros, we want a "clean" environment.
  
  my $source = <<'EMACROHEADER' ;

#ifdef __cplusplus
extern "C"
#endif
  int printf(const char *, ...);
  

#define str1(x) #x
#define str(x)  str1(x)

  int main() {

EMACROHEADER

  return $source;
}
  
sub macro_test_source
{
  my ( $macro ) = @_;
  
  # This source should match macro_preproc_expansion_source and
  # gather_macro_expansions's regexp
  
  my $source = <<"EMACROTEST" ;

#ifdef $macro
    printf("\\\"beam_macro $macro\\\" %s \\\"beam_end\\\"\\n", str($macro));
#endif

EMACROTEST

  return $source;
}

