# Require perl 5.004
use 5.004;

use strict;

# AFS Hack. Compressed.
BEGIN {
  require Cwd;
  if ( $^O !~ /msys/i && $^O !~ /mswin32/i ) {
    my $alias = sub { my ( $old, $new ) = @_;
                      local *oldproc = $old;
                      if ( defined &oldproc ) {
                        local $SIG{'__WARN__'} = sub { };
                        *oldproc = $new;
                      } };
    $alias->(*Cwd::getcwd,       \&Cwd::cwd);
    $alias->(*Cwd::fastcwd,      \&Cwd::cwd);
    $alias->(*Cwd::fastgetcwd,   \&Cwd::cwd);
    $alias->(*Cwd::abs_path,     \&Cwd::fast_abs_path);
    $alias->(*Cwd::realpath,     \&Cwd::fast_abs_path);
    $alias->(*Cwd::realpath,     \&Cwd::fast_abs_path); # Suppress warning
    $alias->(*Cwd::fast_realpath,\&Cwd::fast_abs_path);
    $alias->(*Cwd::fast_realpath,\&Cwd::fast_abs_path); # Suppress warning
  }
  import Cwd qw(getcwd);
};
# End AFS Hack.

use FindBin qw($RealBin);
use lib "$RealBin/../pm";

use Getopt::Long;
use Symbol qw(gensym);  # For anonymous file handles
use File::Path; # mkpath()

use BEAM::FileNames qw(:all);
use BEAM::Temporary qw(tmp_file_in tmp_dir);
use BEAM::Commands  qw(cmd_capture);

# Try to find the signal number for SIGINT. On old perls,
# default to '2'.

my $sigint = 2;

eval {
  use POSIX qw(SIGINT);
  $sigint = SIGINT;
};

# Enable warnings portably
BEGIN { $^W = 1; }

# Enable auto-flush to keep stdout and stderr in sync as
# much as possible (-v -v -v gets pretty verbose)
$| = 1;

#################### Globals ####################

# History:
#  4.0: Fully qualified variable names:  April 2008
#  3.0: Windows support:                 April 2007
#  2.0: Java Support:                    May   2006
#  1.1: C and C++ Support:               June  2005
#
# Update the version when you change the script.
my $version = '4.0';

my @default_c_headers = qw(limits.h math.h float.h stddef.h stdio.h string.h);
my @default_cpp_headers = qw(bits/c++config.h cstddef string vector algorithm new.h);

my $verbose = 0;

my $invocation;

my $original_dir = getcwd();

my $global_temp_dir = tmp_dir();

# These are filled in at the end of the file
my $template_c_cpp_config_file = "";
my $template_java_config_file = "";

# This is the regexp for an identifier. This should be:
#
#   [A-Za-z_][A-Za-z0-9_]*
#
# or even
#
#   [[:alpha:]_][[:alnum]_]*
#
# but Perl 5.004 doesn't support the latter, and the former matches
# crap like "\" and "}" on EBCDIC systems!!!
#
my $up_letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
my $low_letters = lc( $up_letters );
my $identifier_re = "[${up_letters}${low_letters}_]\\w*";

# When searching for macros, ignore these.
# Some of these aren't macros, but they
# are easy to filter out this way. They
# are identifiers that look like macros.
#
# The reason some of these are filtered
# out and not simply left for testing is
# that '#ifdef ifdef', etc,  is invalid and
# the preprocessor will fail. Others are
# simply defined by EDG and so they don't
# need to be found here.
#
# The hash values aren't important; this
# is simply a lookup table with exists().
my %macros_to_ignore = (
  "define"         => 1,
  "defined"        => 1,
  "ifdef"          => 1,
  "ifndef"         => 1,
  "if"             => 1,
  "elif"           => 1,
  "else"           => 1,
  "endif"          => 1,
  "and"            => 1,
  "and_eq"         => 1,
  "or"             => 1,
  "or_eq"          => 1,
  "not"            => 1,
  "not_eq"         => 1,
  "xor"            => 1,
  "xor_eq"         => 1,
  "bitor"          => 1,
  "bitand"         => 1,
  "compl"          => 1,
  "__FUNCTION__"   => 1,
  "__func__"       => 1,
  
  # Skip these because they are EDG builtins
  "__DATE__"         => 1,
  "__FILE__"         => 1,
  "__LINE__"         => 1,
  "__TIME__"         => 1,
  "__STDC__"         => 1,
  "__STDC_VERSION__" => 1,
  "__STDC_HOSTED__"  => 1,
  "__cplusplus"      => 1,
  
  # Skip these on AIX because they switch to builtins that we
  # don't model in EDG. Things compile fine without them, as
  # far as our limited testing has shown.
  "__STR__"    => 1,
  "__XLC121__" => 1,
  "__XLC13__"  => 1,
  
  # Skip these on AIX - they should come from /etc/vac.cfg
  "_AIX"   => 1,
  "_AIX32" => 1,
  "_AIX41" => 1,
  "_AIX43" => 1,
  "_AIX50" => 1,
  "_AIX51" => 1,
  "_IBMR2" => 1,
  "_POWER" => 1,
);

# This is a list of macros to try in addition to the identifiers
# that we can find in user header files. Most of these are here
# because xlc/vac doesn't have a nice -dM switch to figure them
# out, and the system headers don't test for them, so there's
# no good way to detect them besides listing them and testing them.

my @macros_to_try = qw(
  __32BIT__
  __370__
  __64BIT__
  __ALIGN
  __ANSI__
  __BOOL__
  _ARCH_COM
  __C99_CPLUSCMT
  _CHAR_UNSIGNED
  __CHAR_UNSIGNED__
  __CODESET__
  __COMPILER_VER__
  _CPPRTTI
  __DBCS__
  __FENCE
  __GNUC__
  __GNUC_MINOR__
  __GNUC_PATCHLEVEL__
  __HHW_370__
  __HHW_BIG_ENDIAN__
  __HHW_INTEL__
  __HHW_RS6000__
  __HOS_AIX__
  __HOS_MVS__
  __HOS_WIN__
  _ILP32
  __IBMC__
  __IBMCPP__
  __LIBREL__
  __LOCALE__
  _LONG_LONG
  __LONGDOUBLE80
  _M_I386
  _M_IX86
  _M_IX86_FP
  __MATH__
  __SIZE_TYPE__
  _STDCALL_SUPPORTED
  __TARGET_LIB__
  __THW_370__
  __THW_BIG_ENDIAN__
  __THW_INTEL__
  __THW_RS6000__
  __TOS_AIX__
  __TOS_MVS__
  __TOS_WIN__
  __TUNE__
  _WCHAR_T
  _WIN32
  __WINDOWS__
  __xlc__
  __xlC__
  __XLC121__
  __XLC13__
  __XPLINK_CALLBACK__
);

my @predefined_function_names = qw(
  __func__
  __FUNCTION__
  __PRETTY_FUNCTION__
  __FUNCDNAME__
  __FUNCSIG__
);

# List of keywords that should be tested for IBM's xlc and vac compilers
my @decl_keywords = qw(
  __cdecl
  __export
  __far16
  __far32
  __fastcall
  __import
  __inline
  __optlink
  __packed
  __pascal
  __seg16
  __stdcall
  __system
  __unaligned
  _Builtin
  _Cdecl
  _Export
  _Far16
  _Far32
  _Fastcall
  _Import
  _Inline
  _Optlink
  _Packed
  _Pascal
  _Seg16
  _Stdcall
  _System
  _Unaligned
);

# List of keywords that should be tested for IBM's USS compilers
my @zosvac_keywords = qw(
  __ptr32
  __ptr64
  __attribute__(x)
  __const__
  __extension__
  __inline__
  __label__
  __restrict__
  __restrict
  __signed__
  __volatile__
  _Packed
);

# __FILE__ and __LINE__ are ommitted as they are dynamic
my %standard_predefined_macros = (
  "c" =>   [
	    "__DATE__",
	    "__TIME__",
	    "__STDC__",
	    "__STDC_VERSION__",
	    "__STDC_HOSTED__"
           ],
  "cpp" => [
	    "__DATE__",
	    "__TIME__",
	    "__STDC__",
	    "__STDC_VERSION__",
	    "__STDC_HOSTED__",
	    "__cplusplus"
           ]
);

#################### Routines ####################

sub usage
{
  my ( $str ) = @_;

  print STDERR <<"USAGE" ;

  beam_configure version $version
  
  Usage:
    
    beam_configure [ options ] compiler [ -- <compiler flags> ]
    
  Description:
    
    beam_configure will examine your compiler and
    produce a configuration file that will help
    BEAM emulate its features and options. The
    resulting configuration file may need some
    manual editing, depending on how much information
    beam_configure can automatically detect.
    
    The options are shown below. For detailed
    help, please see:
    
      install_dir/www/beam_configure.html
      install_dir/www/compiler_configuration.html
    
  Example:
    
    \$ beam_configure --cpp g++
    
  Output file name:
    
    If a template file is being written ("--template"),
    the file name defaults to "template_*lang*_config.tcl",
    where "*lang*" is the language given on the command line.
    
    Otherwise, the default file name is "compiler_*lang*_config.tcl".
    
    To specify a different file name, see the "--output" option.


  Required Options:
    
    <compiler>               The compiler must be given on the command line
                             unless "--template" is being used. The compiler
                             will be searched for in the \$PATH. You may also
                             specify an absolute path name.


  One of the following language options is required:
    
    --c                      Treat the compiler as a C compiler, or generate
                             a C template file (if given with "--template").
    
    --cpp                    Treat the compiler as a C++ compiler, or generate
                             a C++ template file (if given with "--template").
    
    --java                   Treat the compiler as a Java compiler, or generate
                             a Java template file (if given with "--template").


  C and C++ options:

    --headers <hdr1,hdr2...> Additional, non-standard header files to look for.
                             This may require additional "-I" options to
                             be passed to the native compiler. If the header file is
                             found the corresponding directory will be added to the
                             search path for system headers.
                             The flag can be specified any number of times.
  
    --macros <m1,m2...>      Additional macros to try during the predefined macro
                             detection. Any macro in this comma-separated list
                             that is defined by your compiler proper will be
                             included in the configuration file, with its value.
      
    --preproc_flag=<flag>    This is the flag that needs to be used for
                             preprocessing. Defaults to "-E".
                             Don't forget the "=". To set the flag
                             to nothing, use --preproc_flag=" ".
      
    --macro_flag=<flag>      If your compiler has a command line option that
                             makes it write out its predefined macros you should
                             specify that option here. For GCC that would be
                             "-E -dM", which is also the default setting.
                             Don't forget the <code>"="</code>.

    --compile_flag=<flag>    This is the flag that will make the compiler
                             compile the file, returning error if the
                             compilation was unsuccessful. It defaults to
                             "-c". Don't forget the "=". To set the flag
                             to nothing, use --compile_flag=" ". It is
                             also assumed that the return code of the
                             compiler can be used to determine if
                             compilation was successful or not.

    --bin_flag=<flag>        This is the flag that will make the compiler
                             compile the file, producing an executable.

                             The beam_configure script needs to specify
                             the resulting executable file name when using
                             this flag. To do so, beam_configure will replace
                             the string "%s" with the executable file name
                             that should be written.
  
                             The default is "-o %s", which results in two
                             options to be passed to the compiler: "-o" and
                             the executable file name to write.

                             Another example would be if your compiler only
                             needed one flag, but the file name was part of
                             it. Something like the following would work
                             for you.

                               --bin_flag="/o:%s"

                             When specifying this option, don't forget the "=".
                             To set the flag to nothing, use --bin_flag=" ".
                             It is also assumed that the return code of the
                             compiler can be used to determine if compilation
                             was successful or not.


  Java Options:
  
     --javabin <file>        Override the Java executable to use when running
                             compiled class files. By default, the "java" binary
                             is found by looking in the same directory where the
                             given compiler is located.


  Additional Options:

    -t | --template          Skip detection and write a template configuration
                             file. See the note above about output file names.
  
    -o | --output <file>     Write the configuration to this file instead of the
                             default location. See the note above about output
                             file names.
      
    -f | --force             Overwrite the output file if it exists. By default,
                             beam_configure won't overwrite existing files.

    -k | --keeptemp          Keep temporary files around. Useful for
                             troubleshooting problems.
    
    -v | --verbose           Verbose output about what is being run, etc.
                             If specified more than once, even more
                             information will be displayed. This can be
                             specified up to 3 times.
  
    --                       Anything after this option will be passed
                             directly to the compiler during every invocation.

    --version                Show beam_configure's version and exit.

    --help                   Show this information screen.


USAGE

  if ( $str ) {
    print STDERR "\nError: $str\n";
  }
  
  exit( 1 );
}

sub verbose
{
  my ( $level, $msg ) = @_;
  
  print STDERR "$msg\n" if ( $verbose >= $level );
}

# Main is called from the end of the script
sub main
{
  my $c = 0;
  my $cpp = 0;
  my $java = 0;
  
  my ( $template, $output, $force, @headers,
       @try_macros, $javabin, $xtesting,
       $xcvtesting, $help );
  
  # Options with defaults
  my $preproc_flag = '-E';
  my $macro_flag   = '-E -dM';
  my $compile_flag = '-c';
  my $bin_flag     = '-o %s';
  
  usage() unless @ARGV; # At least one option or compiler is required
  
  # Save off our invocation
  $invocation = join( ' ', map { "'$_'" } ( fn_path_to_ext( $0 ), @ARGV ) );
  
  # Note: --x*testing flags are undocumented testing-only flags.

  # Don't auto-abbreviate. We do it manually to avoid collisions.
  Getopt::Long::config( 'no_auto_abbrev' );
  
  GetOptions( "c"              => \$c,
              "cpp"            => \$cpp,
              "java"           => \$java,
              "template|t"     => \$template,
              "output|o=s"     => \$output,
              "force|f"        => \$force,
              "headers=s@"     => \@headers,
              "macros=s@"      => \@try_macros,
              "preproc_flag=s" => \$preproc_flag,
              "macro_flag=s"   => \$macro_flag,
              "compile_flag=s" => \$compile_flag,
              "bin_flag=s"     => \$bin_flag,
              "javabin=s"      => \$javabin,
              "keeptemp|k"     => sub { $BEAM::Temporary::do_cleanup = 0; },
              "xtesting"       => \$xtesting,
              "xcvtesting"     => \$xcvtesting,
              "verbose|v"      => sub { $verbose++ },
              "version"        => sub {
                                    print "beam_configure $version\n";
                                    exit 1;
                                  },
              "help"           => \$help ) or usage();
  
  # Check the options
  
  usage() if $help;

  # Run tests if requested
  
  if ( $xcvtesting ) {
    my $rc = cv_run_tests();
    exit $rc;
  }
  
  # Detect some errors early
  
  if ( $c + $cpp + $java == 0 ) {
    usage( "A language option is required" );
  }
  
  if ( $c + $cpp + $java > 1 ) {
    usage( "Only one language option is allowed" );
  }
  
  # Set up $lang for convenience

  my $lang;
  
  if ( $c ) {
    $lang = "c";
  } elsif ( $cpp ) {
    $lang = "cpp";
  } elsif ( $java ) {
    $lang = "java";
  } else {
    die "Internal Error: unknown language $lang\n";
  }
    
  # The template option should be processed early, because it skips almost
  # everything and doesn't require extra options

  if ( $template ) {
    $output = get_output_file_name( $output, $lang, $force, "template" );

    write_template_config_file( $lang, $output );

    exit( 0 );
  }

  # Since the template option wasn't given,
  # set up the compiler and start testing it out
  
  usage("You must specify a compiler") if $#ARGV == -1;

  # Locate the command. This is because we chdir(),
  # and want to be able to find ./bin/cc later.
  
  $ARGV[0] = find_exe( $ARGV[0] );

  # Set up as much about the compiler as we know
  
  my $compiler;

  $compiler->{'cmd'} = [ @ARGV ];
  $compiler->{'compiler_path'} = $ARGV[0];
  
  if ( $c || $cpp ) {
    # Consolidate the comma-separated list options
    # This turns ( 'a.h,b.h', 'c.h', 'd.h,e.h' ) into
    # ( 'a.h', 'b.h', 'c.h', 'd.h', 'e.h' ) for example
  
    @headers    = split( /,/, join( ',', @headers ) ) if $#headers != -1;
    @try_macros =  split( /,/, join( ',', @try_macros ) ) if $#try_macros != -1;
  
    push @macros_to_try, @try_macros;

    # These options are set as arrays in case they contain
    # multiple flags: '-E -dM' => ( '-E', '-dM' )
  
    $compiler->{'preproc_flag'} = [ split /\s+/, $preproc_flag ];
    $compiler->{'macro_flag'}   = [ split /\s+/, $macro_flag ];
    $compiler->{'compile_flag'} = [ split /\s+/, $compile_flag ];
    $compiler->{'bin_flag'}     = [ split /\s+/, $bin_flag ];
  } else {
    # For Java, there is no compile flag.
    $compiler->{'compile_flag'} = [];
    
    # Java requires a "java" binary in addition to the compiler.
    # Look for one near the Java compiler.
    if ( ! $javabin ) {
      $javabin = $compiler->{'compiler_path'};
      $javabin = fn_dirname( $javabin );
      $javabin .= "/java";

      if ( $^O =~ /mswin32/i ) {
        my $found = find_prog_with_pathext( $javabin );
        
        if ( defined $found ) {
          $javabin = $found;
        }
      }
      
      if ( ! -x $javabin ) {
        print STDERR "\n";
        print STDERR "Error: Java requires a Java executable, and\n";
        print STDERR "       '$javabin' doesn't exist or isn't\n";
        print STDERR "       executable. Please use the '--javabin' option.\n";
        exit( 1 );
      }
    }
    
    $compiler->{'java_cmd'} = [ $javabin ];
  }

  # Full-pathify $output if it was given so that once
  # we change directories, the file name is still right
  
  if ( defined $output ) {
    $output = fn_full_pathify( $output );
  }
  
  # Generate the file name early to detect whether -force is needed.

  $output = get_output_file_name( $output, $lang, $force, "compiler" );

  # Change directories to keep temp files in one place that may
  # be generated
  
  change_to_temp_dir();
  
  # In testing mode, kill a few informational things that end up in the
  # output. This is because they have absoute paths and for testing,
  # we want deterministic results.

  if ( $xtesting ) {
    $invocation = 'testing mode';
    $compiler->{'testing_mode'} = 1;
  }
  
  # Check if the compiler works for the intended configurations.
  # This will also help detect a usable file extension.

  if ( $c ) {
    print "Testing compiler for C support...\n";
    
    $compiler->{'lang'} = 'c' if $xtesting;
    $compiler->{'ext'} = 'c' if $xtesting;
    
    if ( $xtesting || test_c_compiler( $compiler ) ) {
      print "Detecting C compiler features (this may take some time)...\n";
      @headers = ( @default_c_headers, @headers );
      configure_c_cpp_compiler( $compiler, \@headers, $output );
    } else {
      print STDERR "\n";
      print STDERR "Error: C compiler doesn't seem to work.\n";
      print STDERR "       Re-run with different options or '--verbose'.\n";
      exit( 2 );
    }
  }
  
  if ( $cpp ) {
    print "Testing compiler for C++ support...\n";
    
    $compiler->{'lang'} = 'cpp' if $xtesting;
    $compiler->{'ext'} = 'cpp' if $xtesting;
    
    if ( $xtesting || test_cpp_compiler( $compiler ) ) {
      print "Detecting C++ compiler features (this may take some time)...\n";
      @headers = ( @default_cpp_headers, @default_c_headers, @headers );
      configure_c_cpp_compiler( $compiler, \@headers, $output );
    } else {
      print STDERR "\n";
      print STDERR "Error: C++ compiler doesn't seem to work.\n";
      print STDERR "       Re-run with different options or '--verbose'.\n";
      exit( 2 );
    }
  }
  
  if ( $java ) {
    print "Testing compiler for Java support...\n";
    
    $compiler->{'lang'} = 'java' if $xtesting;
    $compiler->{'ext'} = 'java' if $xtesting;
    
    if ( $xtesting || test_java_compiler( $compiler ) ) {
      print "Detecting Java compiler features...\n";
      configure_java_compiler( $compiler, $output );
    } else {
      print STDERR "\n";
      print STDERR "Error: Java compiler doesn't seem to work.\n";
      print STDERR "       Re-run with different options or '--verbose'.\n";
      exit( 2 );
    }
  }
  
  exit( 0 );
}

####################
# Primary routines

sub configure_c_cpp_compiler
{
  my ( $compiler, $headers, $file ) = @_;
  
  # Try to find header locations
  
  my @dirs = find_headers( $compiler, @$headers );
  
  # Try to find target features and compiler type/version
  
  my $features = find_options( $compiler );

  # Try to find predefined macros
  
  my $macros = find_macros( $compiler, @dirs );

  # Write the config file
  
  write_c_cpp_config_file( $file, \@dirs, $features, $macros );
}

sub configure_java_compiler
{
  my( $compiler, $file ) = @_;
  
  # Try to find system properties
  
  my $properties = find_java_properties( $compiler );
  
  # Write the config file
  
  write_java_config_file( $file, $properties );
}

sub test_c_compiler
{
  my ( $compiler ) = @_;
  
  $compiler->{'lang'} = 'c';
  $compiler->{'ext'}  = 'c';

  my $preproc_source = test_preproc_c_source();
  my $preproc_re     = q/int\s+x\s+=\s+42/;
  my $good_source    = test_compiler_c_source();
  my $bad_source     = test_compiler_bad_source();

  my $rc = test_c_cpp_compiler( $compiler, $preproc_source, $preproc_re,
                                $good_source, $bad_source );

  return $rc;
}

sub test_cpp_compiler
{
  my ( $compiler ) = @_;
  
  $compiler->{'lang'} = 'cpp';
  
  my $preproc_source = test_preproc_cpp_source();
  my $preproc_re     = q/int\s+x\s+=\s+42/;
  my $good_source    = test_compiler_cpp_source();
  my $bad_source     = test_compiler_bad_source();
  
  foreach my $ext ( qw(cpp cxx CC C) ) {
    $compiler->{'ext'} = $ext;
    
    my $rc = test_c_cpp_compiler( $compiler, $preproc_source, $preproc_re,
                                  $good_source, $bad_source );

    if ( $rc ) {
      return 1;
    }
  }
  
  return 0;  
}

sub test_java_compiler
{
  my( $compiler ) = @_;

  $compiler->{'lang'} = 'java';
  $compiler->{'ext'} = 'java';

  # See if the compiler is executable and useful.

  my $compile_ok = 0;
  
  my $good_source = test_compiler_java_source();
  my $bad_source  = test_compiler_bad_source();
  
  verbose 1, "Testing java compiler...";
  
  my ( $rc, $output, $error ) = compile_source( $compiler, $good_source );

  if ( $rc == 0 ) {
    # Make sure bad source gets a bad rc
    
    verbose 2, "* This next command should fail...";
    
    ( $rc, $output, $error ) = compile_source( $compiler, $bad_source );
    
    if ( $rc != 0 ) {
      # Good
      $compile_ok = 1;
      verbose 1, "- Compiler seems to work";
    } else {
      my $cmd = compile_command( $compiler );
      
      show_warning( "compiler", $cmd, $compiler->{'ext'}, $output, $error,
                    "It did not fail when given bad code." );
    }
  } else {
    my $cmd = compile_command( $compiler );
    show_warning( "compiler", $cmd, $compiler->{'ext'}, $output, $error,
                  "It failed to run (rc = $rc)." );
  }

  return $compile_ok;
}

sub show_warning
{
  my ( $thing, $cmd, $ext, $output, $error, $msg ) = @_;
 
  # Prints out a lengthy message about why the
  # $thing failed

  if ( $verbose >= 1 ) {
    print STDERR "\n";
    print STDERR "Warning: The $thing doesn't seem to work.\n";
    print STDERR "         $msg\n" if defined $msg;
    print STDERR "\n";
    print STDERR "Command: $cmd <file>.$ext\n";
    print STDERR "\n";
    print STDERR "====== Standard Output: ======\n";
    print STDERR "$output\n";
    print STDERR "====== Standard Error: ======\n";
    print STDERR "$error\n";
    print STDERR "====== End of Output ======\n";
    print STDERR "\n";      
    print STDERR "Warning: Some options may not be detectable without the $thing.\n";
    print STDERR "         Continuing anyway...\n";
  }
}

sub test_c_cpp_compiler
{
  my ( $compiler, $preproc_source, $preproc_re, 
       $good_compile_source, $bad_compile_source ) = @_;
  
  # See if the compiler is executable and useful. If it
  # doesn't support the preprocessor flag or the compile
  # flag, it is completely useless to us.
  
  my ( $preproc_ok, $compile_ok ) = ( 0, 0 );
  
  # It supports the preprocessor flag if it returns 0,
  # and it produces macro-expanded output

  verbose 1, "Testing preprocessor...";
  
  my ( $rc, $output, $error ) = 
    preprocess_source( $compiler, $preproc_source );
  
  if ( $rc == 0 ) {
    if ( $output =~ /$preproc_re/ ) {
      $preproc_ok = 1;
      verbose 1, "- Preprocessor seems to work";
    } else {
      my $cmd = preprocess_command( $compiler );
      show_warning( "pre-processor", $cmd, $compiler->{'ext'}, $output, $error,
                    "It did not expand macros to produce the expected output." );
    }
  } else {
    my $cmd = preprocess_command( $compiler );
    show_warning( "pre-processor", $cmd, $compiler->{'ext'}, $output, $error, 
                  "It failed to run (rc = $rc)." );
  }

  # It supports the compile flag if it returns 0 on valid C/C++
  # code and non-zero on invalid C/C++ code.
  
  verbose 1, "Testing C/C++ compiler...";
  
  ( $rc, $output, $error ) =
    compile_source( $compiler, $good_compile_source );
  
  if ( $rc == 0 ) {
    # Make sure bad source gets a bad rc
    verbose 2, "* This next command should fail...";
    
    ( $rc, $output, $error ) =
      compile_source( $compiler, $bad_compile_source );
    
    if ( $rc != 0 ) {
      $compile_ok = 1;
      verbose 1, "- Compiler seems to work";
    } else {
      my $cmd = compile_command( $compiler );
      show_warning( "compiler", $cmd, $compiler->{'ext'}, $output, $error,
                    "It did not fail when given bad code." );
    }
  } else {
      my $cmd = compile_command( $compiler );
      show_warning( "compiler", $cmd, $compiler->{'ext'}, $output, $error,
                    "It failed to run (rc = $rc)." );
  }

  # Hopefully one of those things worked... if not, I don't think we can do
  # anything with this compiler
  
  if ( ! $preproc_ok && ! $compile_ok ) {
    verbose 1, "- All compiler tests failed... bad compiler/lang/ext set";
    return 0;
  }
  
  # Test for other features
  
  verbose 1, "Testing misc compiler features...";
  
  # Does the compiler support the constant expression trick?
  # - The trick is described in compiler_sizeof below, but basically,
  #   if the compiler supports this trick, it will accept this:
  #
  #     int global_array[ (1 == 1) ? 1 : -1 ];
  #
  #   but reject this:
  #
  #     int global_array[ (2 == 1) ? 1 : -1 ];

  $compiler->{'constant_expression_trick'} = 'no';
  
  my $const_expr = const_expr_source();
  my $const_expr_fail = const_expr_fail_source();
    
  # The first should succeed and the second should fail
  ( $rc ) = compile_source( $compiler, $const_expr );
  
  if ( $rc == 0 ) {
    verbose 2, "* This next command should fail...";
    ( $rc ) = compile_source( $compiler, $const_expr_fail );
    
    if ( $rc != 0 ) {
      verbose 1, "- Compiler supports the constant expression trick";
      $compiler->{'constant_expression_trick'} = 'yes';
    } else {
      verbose 1, "- Compiler doesn't support the constant expression trick";
      verbose 1, "  (accepts bad code)";
    }
  }
  
  return 1;
}

####################

sub find_java_properties
{
  my ( $compiler ) = @_;
  
  verbose 1, "Determining Java properties...";

  my $properties = {};

  # Save off the full path to the compiler and the testing mode
  
  $properties->{'compiler_path'} = $compiler->{'compiler_path'};
  $properties->{'testing_mode'}  = $compiler->{'testing_mode'};
  
  # Find Java run-time properties.
  #
  # This list of hashes is what is looked for in the source.
  #
  # This list:
  # - Is used to generate the source file that prints out the values
  # - Is used to grep through the output looking for the values
  # - Is used to decide if required entries are not given so a message
  #   can be shown
  # - Is used to decide what type the value is
  #   - path is colon- or semi-colon-separated, and will be set in $properties as a list
  #   - string is verbatim and will be set in $properties as-is
  # - Is used to decide what key of $properties to set with what value
  
  my $to_find = [
    {
      name => "java.endorsed.dirs",
      type => "path",
      key  => "system_endorsed_dirs",
    },
    {
      name => "sun.boot.class.path",
      type => "path",
      key  => "system_boot_classpath",
      required => 1,
    },
    {
      name => "java.ext.dirs",
      type => "path",
      key  => "system_ext_dirs",
      required => 1,
    },
    {
      name => "java.specification.version",
      type => "string",
      key  => "language_source_level",
      required => 1,
    },
    {
      name => "file.encoding",
      type => "string",
      key  => "language_encoding",
    }
  ];
  
  # Get some source that prints out the properties we need

  my @props = map { $_->{'name'} } @$to_find;
  
  my $source = java_property_source( "PropertyPrinter", @props );
  
  # Compile the source and run it
  
  my ( $rc, $output, $error ) =
    compile_source_and_run_java( $compiler, "PropertyPrinter", $source );
  
  if ( $rc == 0 ) {
    # Find each item from above in the output and set it in properties
    foreach my $item ( @$to_find ) {
      my $name     = $item->{'name'};
      my $type     = $item->{'type'};
      my $key      = $item->{'key'};
      my $required = $item->{'required'};
      
      if ( $output =~ /$name: beam_property (.*?) beam_end/ ) {
        my $value = $1;
        verbose 2, "$name is $value ($type)";

        if ( $type eq "path" ) {
          $value = [ split /$fn_javasep_re/, $value ];
        }

        $properties->{$key} = $value;
      } elsif( $required ) {
        print STDERR "\n";
        print STDERR "Warning: The Java Runtime Property '$name' was not\n";
        print STDERR "         found. You may need to add it to your configuration\n";
        print STDERR "         file manually (as '$key').\n";
      }
    }
  }
  
  return $properties;
}

sub find_headers
{
  my ( $compiler, @headers ) = @_;
  
  my @dirs;
  
  # Try to preprocess a simple file that includes the target
  # header(s), and find the '#line "/path/to/include" that
  # the preprocessor produces
  
  # For each header file we are interested in, generate
  # a source file that includes it, and try to preprocess it.
  # Use the extension passed in.
  
  verbose 1, "Searching for header locations...";
  
HEADER:
  foreach my $header ( @headers ) {

    verbose 2, "- Looking for '$header'";
    
    my $source = include_headers( $header );
    
    my ( $rc, $output ) = preprocess_source( $compiler, $source );
    
    if ( $rc == 0 ) {
      my @lines = split '\n', $output;
      
      foreach my $line ( @lines ) {
        if ( $line =~ m|^\s*#.*?\"(.*?)[\\/]\Q$header\E\"| ) {
          my $dir = fn_path_to_int( $1 );
          
          verbose 2, "- Found '$header' in '$dir'";
          
          push @dirs, fn_full_pathify( $dir );
          next HEADER;
        }
      }
    }
  }

  @dirs = make_unique( @dirs );
  
  my $num = scalar( @dirs );
  
  verbose 1, "- Found $num unique header location(s)";
  
  if ( $num == 0 ) {
    print STDERR "\n";
    print STDERR "Warning: No header locations were found. You will need\n";
    print STDERR "         to add them to the config file manually.\n";
    if ($^O eq "os390") {
      my $var;
      if ($compiler->{lang} eq "c") {
        $var = "_C89_ELINES";
      } else {
        $var = "_CXX_ELINES";
      }
      print STDERR "         Try one of the following:\n";
      print STDERR "         (1) Define environment variable $var=1 and rerun.\n";
      print STDERR "         (2) Rerun beam_configure, adding --preproc_flag=-qpponly=lines\n";
      print STDERR "             to its command line\n";
    }
  }
  
  return @dirs;
}
  
####################

sub find_options
{
  my ( $compiler ) = @_;

  # This hash ref will be passed around and filled in by the
  # utility routines
  
  my $features = {};
  
  verbose 1, "Checking for runtime environment configuration...";

  # There are a few ways to find the features we are interested in.
  #
  # Creating a native binary is more accurate, and can find things
  # that simple preprocessing may not find (endianness on some
  # machines that don't have friendly headers)
  #
  # Second, if that is not an option, we can resort to trying to
  # compile some things (for long long, long double, and
  # enum bitfield support), and we can preprocess for others
  # (limits.h can give us signed chars and sizes of types, and
  # float.h can give us floating point characteristics, and...)
  
  # We are interested in many features:
  #
  # - The compiler (if it is one we support, we can map the flags
  #   automatically)
  
  check_known_compiler( $compiler, $features );
  
  # - Stuff describing the target environment (from EDG's targ_def.h):
  #   - Big or little endian (320)
  
  check_endianness( $compiler, $features );
  
  #   - Char bit (329) plus target_host_string_char_bit (340)
  #   - Signed or unsigned chars (352)
  
  check_char_traits( $compiler, $features );
  
  #   - Sizes of built-in types
  #     - short, int, long, long long (396)
  #     - float, double, long double (1343)
  #     - pointer (1198)
  
  check_sizes( $compiler, $features );
  
  #   - Alignments of built-in types
  #     - short, int, long, long long (396)
  #     - float, double, long double (1343)
  #     - pointer (1198)
  
  check_alignments( $compiler, $features );

  #   - Special types
  #     - wchar_t size and kind (1134)
  #     - size_t max and kind (1296)
  #     - char16_t size and kind
  #     - char32_t size and kind
  #     - ptrdiff_t min, max, and kind
  
  check_special_types( $compiler, $features );
  
  #   - Floating point characteristics
  #     - Min and max exp, mantissa, etc (1455)
  
  check_float_traits( $compiler, $features );
  
  #   - Misc stuff
  #     - plain int bitfield is signed or unsigned (977)
  #     - enum bitfield can be signed (1014)
  #     - enum types can be smaller than int (1902)
  #     - scope of for loop decls (lang_feat.h)
  #     - friend injection (lang_feat.h)
  #     - literal strings are const (lang_feat.h)
  #     - etc...

  check_misc_features( $compiler, $features );

  # Also, we add the compiler language
  # because it will be needed in the configuration file
  
  $features->{'lang'} = $compiler->{'lang'};

  # And the full path to the compiler and the testing mode
  
  $features->{'compiler_path'} = $compiler->{'compiler_path'};
  $features->{'testing_mode'}  = $compiler->{'testing_mode'};
  
  if ( exists $features->{'xlc'} || exists $features->{'vac'} ) {
    # For xlc and vac C code, alloca is a builtin
    # So is __assert1 and __assert2
    if ( $features->{'lang'} eq 'c' ) {
      $features->{'language_needs_builtin_alloca'} = 1;
      $features->{'language_needs_builtin_assert1'} = 1;
      $features->{'language_needs_builtin_assert2'} = 1;
    }
    # FIXME: For xlc and vac C++ code, for now, we use gpp_dependent_name_lookup
    #        because I can't get names to be found like xlc does it without this
    if ( $features->{'lang'} eq 'cpp' ) {
      $features->{'target_gpp_dependent_name_lookup'} = 1;
    }
  }

  # Done
  
  my $num = scalar( keys %$features );
  verbose 1, "- Found $num runtime configuration option(s)";

  if ( $num == 0 ) {
    
    print STDERR "\n";
    print STDERR "Warning: No target options were found.\n";
    print STDERR "         You will need to add them to the config file manually.\n";
  
  } elsif ( $num < 15 ) {
    
    # 15 options includes all sizes and alignments. We should
    # have found at least that many to be considered successful
    
    print STDERR "\n";
    print STDERR "Warning: Very few ($num) target options were found.\n";
    print STDERR "         You will need to add them to the config file manually.\n";
  }
  
  return $features;
}

# Runtime utilities

sub check_known_compiler
{
  my ( $compiler, $features ) = @_;
  
  # See if this is a compiler we support automatically
  # Try to detect common predefined macros for gcc, vac, etc

  verbose 2, "Checking for known compiler";
  
  my @to_expand = qw(
    __GNUC__
    __GNUC_MINOR__
    __GNUC_PATCHLEVEL__
    __xlC__
    _MSC_VER
    __ICC
    __INTEL_COMPILER
    __IBMC__
    __IBMCPP__
    __WINDOWS__
    __MVS__
  );

  my $macros = expand_macros( $compiler, \@to_expand );
  
  if ( exists $macros->{'__GNUC__'} ) {
    # EDG wants the version of gcc in a special format
    my $level = c_value( $macros->{'__GNUC__'} ) * 10000 +
                c_value( $macros->{'__GNUC_MINOR__'} ) * 100 +
                c_value( $macros->{'__GNUC_PATCHLEVEL__'} );
    
    $features->{'gnu_mode'} = $level;
    
    if ( exists $macros->{'__ICC'} && exists $macros->{'__INTEL_COMPILER'} ) {
      $features->{'icc'} = c_value( $macros->{'__ICC'} );
      verbose 2, "- Compiler is Intel ICC $features->{icc}";
    } else {
      $features->{'gcc'} = $level;
      verbose 2, "- Compiler is gcc $level";
    }
  }
  
  # xlc and vac set __xlC__ to 0xVVRR (like 0x0403).
  # If the number is 0x0500 or higher, it's VAC, otherwise,
  # it is XLC (older).
  
  if ( exists $macros->{'__xlC__'} ) {
    my $version = c_value( $macros->{'__xlC__'} );
    
    if ( $version >= 0x0500 ) {
      $features->{'vac'} = $version;
      verbose 2, "- Compiler is vac $features->{vac}";
    } else {
      $features->{'xlc'} = $version;
      verbose 2, "- Compiler is xlc $features->{xlc}";
    }      
  }
  
  # Microsoft's cl.exe sets _MSC_VER to a version like 1400
  
  if ( exists $macros->{'_MSC_VER'} ) {
    my $version = c_value( $macros->{'_MSC_VER'} );
    $features->{'msvc'} = $version;
    verbose 2, "- Compiler is msvc $features->{msvc}";
  }
  
  # IBM's VisualAge for Windows sets __IBMC__ or __IBMCPP__
  # to a version like "360".
  
  if ( exists $macros->{'__WINDOWS__'} ) {
    my $version;
    if ( exists $macros->{'__IBMC__'} ) {
      $version = c_value( $macros->{'__IBMC__'} );
    } elsif ( exists $macros->{'__IBMCPP__'} ) {
      $version = c_value( $macros->{'__IBMCPP__'} );
    }
    
    if ( defined $version ) {
      $features->{'vacwin'} = $version;
      verbose 2, "- Compiler is vacwin $version";
    }
  }

  # IBM's compilers for USS
  
  if ( exists $macros->{'__MVS__'} ) {
    my $version;
    if ( exists $macros->{'__IBMC__'} ) {
      $version = c_value( $macros->{'__IBMC__'} );
    } elsif ( exists $macros->{'__IBMCPP__'} ) {
      $version = c_value( $macros->{'__IBMCPP__'} );
    }
    
    if ( defined $version ) {
      $features->{'zosvac'} = $version;
      verbose 2, "- Compiler is zosvac $version";
    }
  }
}

sub check_endianness
{
  my ( $compiler, $features ) = @_;
  
  # There is no standard header that provides endian information.
  #
  # If we can compile a binary, it is easy - compile and run
  # something that will test and display the endianness.
  #
  # If we can't compile a binary, then
  # - On linux, we can try endian.h and
  #   __BYTE_ORDER, __BIG_ENDIAN, and __LITTLE_ENDIAN
  # - On AIX, we can try sys/machine.h and 
  #   BYTE_ORDER and BIG_ENDIAN and LITTLE_ENDIAN
  # - We can try to detect the processor via macros:
  #   - If the system defines __i386__ we are little endian
  #   - If the system defines __s390__ or __s390x__ we are big endian
  #   - If the system defines _POWER or __powerpc__ we are big endian
  #
  # Otherwise, we can't tell. The default for the config is big endian, which
  # should catch most things
  
  verbose 2, "Checking endianness with a native binary";
  
  my $source = endian_test_source();

  my ( $rc, $output )
    = compile_source_and_run( $compiler, $source );
  
  if ( $rc == 0 ) {
    if ( $output =~ /target_little_endian=(\d+)/ ) {
      $features->{'target_little_endian'} = $1;
      verbose 2, "- Endianness is $1";
      return;
    } else {
      verbose 2, "- Unknown endianness (unexpected output)";
    }
  }

  # Running the binary didn't work - try to figure it out from endian.h
  
  verbose 2, "Checking endianness with endian.h and __BYTE_ORDER";
  
  my @to_expand = qw(
    __BYTE_ORDER
    __BIG_ENDIAN
    __LITTLE_ENDIAN
  );
  
  my @to_include = qw( endian.h );
  
  my $macros = expand_macros( $compiler, \@to_expand, \@to_include );
  
  if ( exists $macros->{'__BYTE_ORDER'} ) {
    my $border = c_value( $macros->{'__BYTE_ORDER'} );
    my $bendian = 0;
    my $lendian = 0;
    
    if ( exists $macros->{'__LITTLE_ENDIAN'} ) {
      $lendian = c_value( $macros->{'__LITTLE_ENDIAN'} );
    }
    
    if ( exists $macros->{'__BIG_ENDIAN'} ) {
      $bendian = c_value( $macros->{'__BIG_ENDIAN'} );
    }
    
    if ( $border == $lendian ) {
      $features->{'target_little_endian'} = 1;
      verbose 2, "- Little endian";
      return;
    } elsif ( $border == $bendian ) {
      $features->{'target_little_endian'} = 0;
      verbose 2, "- Big endian";
      return;
    }
  } else {
    verbose 2, "- Can't determine endianness from endian.h (unexpected output)";
  }

  # No endian.h luck... try to figure it out from sys/machine.h
  
  verbose 2, "Checking endianness with sys/machine.h and BYTE_ORDER";
  
  @to_expand = qw(
    BYTE_ORDER
    BIG_ENDIAN
    LITTLE_ENDIAN
  );
  
  @to_include = qw( sys/machine.h );
  
  $macros = expand_macros( $compiler, \@to_expand, \@to_include );
  
  if ( exists $macros->{'BYTE_ORDER'} ) {
    my $border = c_value( $macros->{'BYTE_ORDER'} );
    my $bendian = 0;
    my $lendian = 0;
    
    if ( exists $macros->{'LITTLE_ENDIAN'} ) {
      $lendian = c_value( $macros->{'LITTLE_ENDIAN'} );
    }
    
    if ( exists $macros->{'BIG_ENDIAN'} ) {
      $bendian = c_value( $macros->{'BIG_ENDIAN'} );
    }
    
    if ( $border == $lendian ) {
      $features->{'target_little_endian'} = 1;
      verbose 2, "- Little endian";
      return;
    } elsif ( $border == $bendian ) {
      $features->{'target_little_endian'} = 0;
      verbose 2, "- Big endian";
      return;
    }
  } else {
    verbose 2, "- Can't determine endianness from sys/machine.h";
    verbose 2, "  (unexpected output)";
  }

  # No luck... try to find out what the processor is and get the
  # endianness from that.

  verbose 2, "Checking endianness with processor macros";

  # Map macros to endianness. If the macro is defined to non-zero
  # value, the little endian feature will be set to the integer here.
  my %proc_macros = (
    "__i386__"    => 0,
    "__s390__"    => 1,
    "__s390x__"   => 1,
    "_POWER"      => 1,
    "__powerpc__" => 1,
  );
  
  @to_expand = keys( %proc_macros );
  
  $macros = expand_macros( $compiler, \@to_expand );
  
  foreach my $key ( %proc_macros ) {
    if ( exists $macros->{$key} ) {
      if ( c_value( $macros->{$key} ) != 0 ) {
        $features->{'target_little_endian'} = $proc_macros{$key};
        verbose 2, "- Little endian set to $proc_macros{$key}";
        return;
      }
    }
  }
  
  # Unknown endianness - print a warning
    
  print STDERR "\n";
  print STDERR "Warning: The endianness of the target platform could not be determined.\n";
  print STDERR "         You should set 'target_little_endian' in the config file manually.\n";
}

sub check_char_traits
{
  my ( $compiler, $features ) = @_;
  
  # Try to figure out char_bit and signed chars with
  # macros from limits.h
  
  verbose 2, "Checking char traits";
  
  my @to_expand = qw( CHAR_BIT CHAR_MIN CHAR_MAX );
  
  my @to_include = qw( limits.h );
  
  my $macros = expand_macros( $compiler, \@to_expand, \@to_include );
  
  if ( exists $macros->{'CHAR_BIT'} ) {
    $features->{'target_char_bit'} = c_value( $macros->{'CHAR_BIT'} );
    verbose 2, "- Char bit = $features->{target_char_bit}";
  }

  if ( exists $macros->{'CHAR_MIN'} ) {
    if ( c_value( $macros->{'CHAR_MIN'} ) == 0 ) {
      $features->{'target_plain_char_is_unsigned'} = 1;
    } else {
      $features->{'target_plain_char_is_unsigned'} = 0;
    }
  } else {
    # If we can't figure it out via the macro, try the constant expression trick
    # and try native binaries
    verbose 2, "- Trying to determine signed chars via various methods";
    
    my $source1 = signed_chars_source();
    my $source2 = unsigned_chars_source();
    my $source3 = char_min_source();
    
    my ( $rc1 ) = compile_source( $compiler, $source1 );
    my ( $rc2 ) = compile_source( $compiler, $source2 );
    
    my ( $rc3, $output )
      = compile_source_and_run( $compiler, $source3 );
    
    if ( $rc1 == 0 ) {
      $features->{'target_plain_char_is_unsigned'} = 0;
    } elsif ( $rc2 == 0 ) {
      $features->{'target_plain_char_is_unsigned'} = 1;
    } elsif ( $rc3 == 0 && $output =~ /target_plain_char_is_unsigned=(\d+)/ ) {
      $features->{'target_plain_char_is_unsigned'} = $1;
    }
  }
  
  if ( exists $features->{'target_plain_char_is_unsigned'} ) {
    verbose 2, "- Chars are unsigned = $features->{target_plain_char_is_unsigned}";
  }
}

sub check_sizes
{
  my ( $compiler, $features ) = @_;
  
  # Try to find the sizes of the builtin types
  #
  # - Note: I don't try to find the expansion of
  #   USHRT_MAX and friends to determine sizes because
  #   it is hard to evaluate things like "32768UL * 2UL - 1UL"
  #   in perl accurately...

  my %builtin_types = (
    target_sizeof_short       => 'short',
    target_sizeof_int         => 'int',
    target_sizeof_long        => 'long',
    target_sizeof_long_long   => 'long long',
    target_sizeof_float       => 'float',
    target_sizeof_double      => 'double',
    target_sizeof_long_double => 'long double',
    target_sizeof_pointer     => 'char *'
  );
    
  foreach my $targ ( keys %builtin_types ) {
    my $type  = $builtin_types{$targ};

    my $size = compiler_sizeof( $compiler, $type );
    
    if ( defined $size ) {
      $features->{$targ} = $size;
    }
  }
}

sub check_alignments
{
  my ( $compiler, $features ) = @_;

  # Check the alignments of the built-in types
  
  my %builtin_types = (
    target_alignof_short       => "short",
    target_alignof_int         => "int",
    target_alignof_long        => "long",
    target_alignof_long_long   => "long long",
    target_alignof_float       => "float",
    target_alignof_double      => "double",
    target_alignof_long_double => "long double",
    target_alignof_pointer     => "char *"
  );
  
  foreach my $targ ( keys %builtin_types ) {
    my $type = $builtin_types{$targ};
    
    my $alignment = compiler_alignof( $compiler, $type );
    
    if ( defined $alignment ) {
      $features->{$targ} = $alignment;
    }
  }
}

sub check_float_traits
{
  my ( $compiler, $features ) = @_;
  
  # Using float.h, figure out the sizes of some floating
  # point characteristics that EDG needs (mantissa bits, etc)
  
  verbose 2, "Checking float traits";
 
# Note: Don't set mant_dig, EDG is very particular that it
# lines up with the size of the type, and gcc lines them
# up differently than EDG requires. BEAM will set mant_dig
# based on the size of the type.
  my %set_table = (
#    target_flt_mant_dig  => 'FLT_MANT_DIG',
    target_flt_min_exp   => 'FLT_MIN_EXP',
    target_flt_max_exp   => 'FLT_MAX_EXP',
#    target_dbl_mant_dig  => 'DBL_MANT_DIG',
    target_dbl_min_exp   => 'DBL_MIN_EXP',
    target_dbl_max_exp   => 'DBL_MAX_EXP',
#    target_ldbl_mant_dig => 'LDBL_MANT_DIG',
    target_ldbl_min_exp  => 'LDBL_MIN_EXP',
    target_ldbl_max_exp  => 'LDBL_MAX_EXP'
  );

  my @to_include = qw( float.h );
  
  my $macros = expand_macros( $compiler, [ values %set_table ], \@to_include );

  # Test the macros and set the values

  foreach my $targ ( keys %set_table ) {
    my $m = $set_table{$targ};
    
    if ( exists $macros->{$m} ) {
      verbose 2, "- Found float trait '$m' = '$macros->{$m}'";
      $features->{$targ} = c_value( $macros->{$m} );
    }
  }
}

sub check_special_types
{
  my ( $compiler, $features ) = @_;

  # Check the sizes and types and signedness of some
  # special types

  check_bool_is_keyword( $compiler, $features );
  
  check_wchar_t_is_keyword( $compiler, $features );
  check_wchar_t_type( $compiler, $features );
  
  check_wint_t_type( $compiler, $features );
  
  check_size_t_type( $compiler, $features );
  check_ptrdiff_t_type( $compiler, $features );

  check_char16_t_type( $compiler, $features );
  check_char32_t_type( $compiler, $features );

  if ( exists $features->{'gcc'} ) {
    check_builtin_va_list_base_type( $compiler, $features );
  }
}

sub check_char16_t_type
{
  my ( $compiler, $features ) = @_;
  
  # Try to get the type directly by pre-processing uchar.h (works for C).

  my $source = include_headers( 'uchar.h' );
  
  my ( $rc, $output ) = preprocess_source( $compiler, $source );
  
  if ( $rc == 0 ) {
    if ( $output =~ /\btypedef\s+(.*?)\s+char16_t\s*;/ ) {
      my $type = $1;
      $type =~ s/\s+/ /g; # Compress whitespace
      $features->{'target_char16_t_int_kind'} = $type;
    }
  }
  
  # Try to figure out the size of char16_t, in case we can't get
  # the type directly. This will help us guess later, if we need
  # to.

  my $size = compiler_sizeof( $compiler, 'char16_t', [ 'uchar.h' ] );
  
  if ( defined $size ) {
    $features->{'target_sizeof_char16_t'} = $size;
  }
}

