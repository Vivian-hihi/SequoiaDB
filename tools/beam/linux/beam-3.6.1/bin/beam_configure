### set TEMPL_NS::function_name_is_string_literal(__FUNCTION__) 1
### set TEMPL_NS::function_name_is_string_literal(__FUNCDNAME__) 1
### set TEMPL_NS::function_name_is_string_literal(__func__)     1

TEMPL_FUNCTION_NAME

