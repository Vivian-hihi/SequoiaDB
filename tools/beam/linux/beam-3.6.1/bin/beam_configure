sub test_compiler_bad_source
{
  return q{x! bad code yx++ \\&&&};
}

sub java_property_source
{
  my ( $name, @properties ) = @_;
 
  # Write out a Java source file that will print the value
  # of each of @properties to stdout.
  
  my @prop_lines;
  
  foreach my $p ( @properties ) {
    push @prop_lines, sprintf( "\"%s\",\n", $p );
  }
  
  my $source = <<"EJAVAPROP" ;

  class $name
  {
    public static void main(String [] args)
    {
      String [] keys = {
        @prop_lines
      };

      for ( int i = 0; i < keys.length; i++ ) {
        String key   = keys[i];
        String value = System.getProperty(key);

        if (value != null) {
          System.out.println(key + ": beam_property " + value + " beam_end");
        }
      }
    }
  }
  
EJAVAPROP
  
  return $source;
}

sub include_headers
{
  my ( @headers ) = @_;
  
  # Return source statements that include each of the headers

  my $source = "";
  
  foreach my $i ( @headers ) {
    $source .= qq{#include <$i>\n};
  }

  return $source;
}

