sub plain_int_bitfield_source
{
  my $source = <<'EPLAININTBITFIELD' ;

#include <stdio.h>
  
  struct S { int member : 8; };
  
  int main() {
    struct S str;
    str.member = -1;
    
    if ( str.member < 0 ) {
      printf("target_plain_int_bit_field_is_unsigned=0\n");
    } else {
      printf("target_plain_int_bit_field_is_unsigned=1\n");
    }
    
    return 0;
  }
  
EPLAININTBITFIELD
    
  return $source;
}

sub enum_bitfield_source
{
  my $source = <<'EENUMBITFIELD' ;
  
#include <stdio.h>
  
  enum E { NEG = -1, ZERO = 0, POS = 1 };
  
  struct S { char dummy; enum E member : 8; };
  
  int main() {
    signed int si;
    struct S str;
    
    str.member = NEG;
    si = (signed int)str.member;
    
    if ( si < 0 ) {
      printf("target_enum_bit_fields_are_always_unsigned=0\n");
    } else {
      printf("target_enum_bit_fields_are_always_unsigned=1\n");
    }
    
    return 0;
  }
  
EENUMBITFIELD
  
  return $source;
}

