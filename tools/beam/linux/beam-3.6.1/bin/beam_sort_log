#        Florian Krohm
#
#    DESCRIPTION:
#
#        This script parses a BEAM complaint file. It allows the messages
#        to be sorted in various ways and provides for the removal of
#        duplicated messages. Basic statstics are available as well.
#        
#        
#    MODIFICATIONS:
#
#        Date      UserID   Remark (newest to oldest)
#        --------  -------  ---------------------------------------------------
#        12/04/01  florian  Created

use Getopt::Long;

$prog_name    = "beam_sort_log";
$prog_version = "1.3";
$prog_author  = "Florian Krohm";
$in_file   = undef;
$out_file  = undef;

$opt_by_file = undef;
$opt_by_type = undef;
$opt_uniq    = undef;
$opt_stat    = undef;

$usage=<<EOF;
USAGE

  $prog_name

    [--version]               print version number and exit

    [--by-file]               sort messages by file

    [--by-type]               sort messages by type

    [--uniq]                  remove duplicate messages

    [--stat]                  print statistics to STDOUT

    infile                    input logfile

    outfile                   output logfile

EOF

&main;

sub main {
#
# Check command line 
#
  GetOptions("by-file", "by-type", "uniq", "stat", "version") || die $usage;

  if($opt_version) {
    print STDOUT "$prog_name $prog_version\n";
    exit(0);
  }

  $num_arg = $#ARGV + 1;

  if ($num_arg == 0) {
    die $usage;
  }

  if($opt_by_file && $opt_by_type) {
    die $usage;
  }

  $in_file  = $ARGV[0];
  open(IN,  "$in_file")   || print_fatal("Cannot open `$in_file'\n");
  if ($num_arg == 1) {
    $FP = STDOUT;
  } else {
    $out_file = $ARGV[1];
    open(OUT, ">$out_file") || print_fatal("Cannot open `$out_file'\n");
    $FP = OUT;
  }

  %msg_by_file = ();
  %msg_by_type = ();
  %msg_count   = ();  # number of messages of a given kind
  @msgs  = ();        # all messages found in input file
  $total = 0;         # total number of messages in input file

#
# Parse the BEAM prologue. There is a blank line following the
# prologue which we can safely ignore.
#
  $beam_prologue = "";
  while($line = <IN>) {
    if($line =~ /^BEAM/) { 
      $beam_prologue .= $line;
    } else {
      last;
    }
  }
#
# Now parse the messages. We cannot easily detect the end of a BEAM 
# complaint because of possibly explanations etc. But we can easily detect
# the beginning of a complaint by its first line that begins with --.
#
  $digits = '0123456789';
  $up_letters = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  $low_letters = lc( $up_letters );

  $kind = "";
  $new_kind = "";
  $file = "";
  $msg  = "";
  while($line = <IN>) {
    $line =~ s/\r$//;    # remove carriage return
    if($line =~ /^-- (\w+)/) {     # A new BEAM message
      $new_kind = $1;
      add_msg ($kind, $file, $msg);
      $msg  = $line;
      $kind = encode($new_kind);
    } else {
      $msg .= $line;
    }
    if($line =~ /^"(.+)", line ([$digits]+): +(.*?)$/) {
      $file = $1;
    }
  }

  add_msg ($kind, $file, $msg);

  print $FP "$beam_prologue\n";

  if($opt_by_file) {
    foreach $key (sort keys %msg_by_file) {   # sort keys
      print $FP "$msg_by_file{$key}";
    }
  }

  if($opt_by_type) {
    foreach $key (sort keys %msg_by_type) {   # sort keys
      print $FP "$msg_by_type{$key}";
    }
  }

  if(! $opt_by_file && ! $opt_by_type) {
    # This is for debugging. The output file should be the same as the
    # input file in this case.
    for($i=0; $i < $total; ++$i) {
      print $FP $msgs[$i];
    }
  }

  if($opt_stat) {
    print "Complaint Summary\n";
    print "----------------------\n";
    $count = 0;
    foreach $key (sort keys %msg_count) {
      $count += $msg_count{$key};
      write;
      #    print "$key $msg_count{$key}\n";
    }
    print "----------------------\n";
    if ($opt_uniq) {
      $key = "total (unique)";
    } else {
      $key = "total";
    }

    $msg_count{$key} = $count;
    write;
  }

  exit(0);
}

#=========================================================================

# When we sort the complaints we want ERROR1 complaints to be followed
# by ERROR2 complaints and not ERROR10 complaints etc.
# So we encode a complaint kind by rewriting its 'number' to be a 3-digit
# number by introducing leading 0's.
#

sub encode ($)
{
  my($kind) = @_;
  my($p1, $p2);

  $kind =~ /([^$digits]+)([$digits]+)/;
  $p1 = $1;
  $p2 = $2;
  if ($p2 < 10) {
    return "$p1" . "00" . "$p2";
  }
  if ($p2 < 100) {
    return "$p1" . "0" . "$p2";
  }
  if ($p2 < 1000) {
    return "$p1" . "$p2";
  }
  print_fatal("cannot encode $kind\n");

  return $kind;
}

#
# Undo what 'encode' did.
#
sub decode ($)
{
  my($kind) = @_;

  my($p1, $p2);

  if ($kind =~ /([^$digits]+)([$digits]+)/) {
    $p1 = $1;
    $p2 = int($2);  # this will strip leading zeroes

    return "$p1" . "$p2";
  }
  return $kind;
}

#=========================================================================

#
# Add a message and update counter accordingly. If the message does not 
# begin with -- do not add it. This is true for the very first message.
#
sub add_msg ($,$,$)
{
  my($kind, $file, $msg) = @_;

  if($msg =~ /^--/) {
    $msgs[$total] = $msg;
    ++$total;
    if(!$opt_uniq || ! $msg_seen{$msg}) {
      $msg_seen{$msg} = 1;
      $msg_by_file{$file} .= "$msg\n";
      $msg_by_type{$kind} .= "$msg\n";
      ++$msg_count{$kind};
    }
  }
}

#=========================================================================

#
# Print message and exit unsuccessfully.
#
sub print_fatal ($) {
  my($str) = @_;

  print STDERR "$::prog_name: (S) $str";
  exit(1);
}


format STDOUT =
@<<<<<<<<<<<<<< @#####
decode($key), $msg_count{$key}
.
