<!--
	@Description:
		Compilation the driver and generation driver package
	@Parameters:
		${JDK5} from compile-control.xml
		${code_dir} from compile-control.xml
    ${java_java_base_dir} from compile-control.xml
	@Invocation:
		NULL
-->

<project default="3.1.2 Build-java-driver">
  <target name="3.1.1 Clean-Java-Environment" depends="">
		<echo level="info" message="Step1 : Rebuild folder &lt;${java_base_dir}/build&gt;" />
    <delete dir="${java_base_dir}/build" failonerror="false" />
		<mkdir dir="${java_base_dir}/build" />
		<echo level="info" message="Step2 : Rebuild folder &lt;${java_base_dir}/temp&gt;" />
    <delete dir="${java_base_dir}/temp" failonerror="false" />
    <mkdir dir="${java_base_dir}/temp" />
		<echo level="info" message="Step3 : Copy file &lt;${java_base_dir}/src/main/resources/errors.properties&gt; to folder &lt;${java_base_dir}/build&gt;" />
    <copy file="${java_base_dir}/src/main/resources/errors.properties" todir="${java_base_dir}/build" failonerror="true" />
  </target>

  <target name="3.1.2 Build-java-driver" depends="3.1.1 Clean-Java-Environment">
		<property name="JDK5" value="false" />
		<tstamp>
			<format property="java_driver_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<if>
    	<equals arg1="${os.arch}" arg2="ppc64" />
    	<then>
    		<property name="jdk_name" value="jdk_ppclinux64" />
      </then>
			<elseif>
				<equais arg1="os.arch" arg2="amd64" />
				<then>
					<if>
						<equals arg1="${JDK5}" arg2="true"/>
						<then>
			      	<property name="jdk_version" value="5" />
							<if>
								<equals arg1="${os.name}" arg2="Linux" />
								<then>
									<property name="jdk_name" value="jdk${jdk_version}_linux64" />
								</then>
								<else>
									<property name="jdk_name" value="jdk${jdk_version}_win64" />
								</else>
							</if>
			      </then>
			      <else>
			        <property name="jdk_version" value="" />
							<if>
								<equals arg1="${os.name}" arg2="Linux" />
								<then>
									<property name="jdk_name" value="jdk${jdk_version}_linux32" />
								</then>
								<else>
									<property name="jdk_name" value="jdk${jdk_version}_win32" />
								</else>
							</if>
			      </else>
					</if>
				</then>
			</elseif>
    </if>
		<echo level="info" message="Step1 : Begin to compile java driver" />
    <javac executable="${code_dir}/java/${jdk_name}/bin/javac" srcdir="${java_base_dir}/src" destdir="${java_base_dir}/build" debug="on" fork="yes" failonerror="true">
       <compilerarg value="-Xlint:unchecked" />
    </javac>

    <trycatch>
    	<try>
        <exec dir="${java_base_dir}" executable="svn" output="${java_base_dir}/temp/svn.status.txt" failonerror="false" >
          <arg line="status -u" />
        </exec>
        <exec dir="${java_base_dir}" executable="grep" output="${java_base_dir}/temp/svn.grep.txt" failonerror="false" >
          <arg line="&apos;Status against revision&apos;" />
          <arg line="${java_base_dir}/temp/svn.status.txt" />
        </exec>
        <exec dir="${java_base_dir}" executable="awk" outputproperty="svn_version" failonerror="false" >
          <arg line="-F &apos;:&apos; &apos;{print $2}&apos;" />
          <arg line="${java_base_dir}/temp/svn.grep.txt" />
        </exec>
    	</try>
    	<catch>
    		<property name="svn_version" value="unknow" />
    	</catch>
    	<finally>
				<echo level="info" message="Step2 : Catch svn info,the command:&#10;
					@ &lt;svn status -u&gt; to ${java_base_dir}/temp/svn.status.txt&#10;
					@ &lt;grep &apos;Status against revision&apos; ${java_base_dir}/temp/svn.status.txt&gt; to ${java_base_dir}/temp/svn.grep.txt&#10;
					@ &lt;awk -F &apos;:&apos; &apos;{print $2}&apos; ${java_base_dir}/temp/svn.grep.txt&gt; to paramater &lt;svn_version&gt;&#10;" />
    	</finally>
    </trycatch>

    <trycatch>
    	<try>
				<echo level="info" message="Step3 : Copy file &lt;${code_dir}/misc/ci/tools/print_version.c&gt; to folder &lt;${java_base_dir}/temp&gt;" />
				<copy file="${code_dir}/misc/ci/tools/print_version.c" todir="${java_base_dir}/temp" failonerror="true" />
     		<echo level="info" message="Step4 : Compile file &lt;${java_base_dir}/temp/print_version.c&gt;,the command is &lt;/usr/bin/gcc  ${java_base_dir}/temp/print_version.c -o ${java_base_dir}/temp/print_version -I${code_dir}/SequoiaDB/engine/include&gt;" />
     		<exec executable="/usr/bin/gcc" dir="${java_base_dir}" failonerror="true">
           <arg line="${java_base_dir}/temp/print_version.c -o ${java_base_dir}/temp/print_version -I${code_dir}/SequoiaDB/engine/include" />
        </exec>
				<echo level="info" message="Step5 : Catch project version info to paramater &lt;project_version&gt;,the command is &lt;${java_base_dir}/temp/print_version&gt;" />
        <exec executable="${java_base_dir}/temp/print_version" dir="${java_base_dir}" failonerror="false" outputproperty="project_version" />
    	</try>
    	<catch>
    	  <property name="project_version" value="unknow" />
    	</catch>
    	<finally>
    	</finally>
    </trycatch>
		<echo level="info" message="Step6 : Write the info of version into file &lt;${java_base_dir}/build/version&gt;" />
    <propertyfile file="${java_base_dir}/build/version">
       <entry key="Release" value="${svn_version}"/>
       <entry key="SequoiaDB Version" value="${project_version}"/>
    </propertyfile>
		<echo level="info" message="Step7 : Package the java driver files into jar package &lt;sequoiadb.jar&gt;" />
    <jar file="${java_base_dir}/sequoiadb.jar" >
       <fileset dir="${java_base_dir}/build"/>
    </jar>
		<tstamp>
			<format property="java_driver_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${java_driver_begintime}" endTime="${java_driver_endtime}" output="java_driver_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The machine which is compiled java driver is &lt;${os.arch}&gt; architecture and &lt;${os.name}&gt; operating system,so use &lt;${jdk_name}&gt;" />
		<echo level="info" message="The java driver's svn version is &lt;${svn_version}&gt; and SequoiaDB version is &lt;${project_version}&gt;" />
		<echo level="info" message="The Java compilation project began at &lt;${java_driver_begintime}&gt;, end at &lt;${java_driver_endtime}&gt;,total spending ${java_driver_time}s" />
		<echo message="**************************************************************************************************************************************************************" />
  </target>
</project>
