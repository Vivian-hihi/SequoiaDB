<!--
	@Description:
		Compilation the driver and generation driver package
	@Parameters:
		${DEBUG} from compile-control.xml
		${JDK5} from compile-control.xml
		${ENTERPRISE} from compile-control.xml
    ${driver_base_dir} from compile-control.xml
	@Invocation:
		build-java-driver.xml
-->

<project default="">
  <property name="code_dir" value="${WORKSPACE}/sequoiadb" />
	<property name="build_dir" value="${WORKSPACE}/release" />
	<target name="3.1 Java-Driver-Compilation" depends="">
		<echo level="info" message="Step1 : Compile the driver of java" />
    <ant antfile="build-java-driver.xml" dir="${driver_base_dir}" target="3.1.2 Build-java-driver" inheritAll="false">
      	<property name="JDK5" value="${JDK5}" />
      	<property name="code_dir" value="${code_dir}" />
		<property name="java_base_dir" value="${code_dir}/driver/java" />
    </ant>
  </target>

  <target name="3.2 C-Driver-Compilation" depends="3.1 Java-Driver-Compilation">
		<echo level="info" message="Step1 : Compile the driver of C" />
  </target>

  <target name="3.3 CPP-Driver-Compilation" depends="3.2 C-Driver-Compilation">
		<echo level="info" message="Step1 : Compile the driver of CPP" />
  </target>

  <target name="3.4 CSharp-Driver-Compilation" depends="3.3 CPP-Driver-Compilation">
		<echo level="info" message="Step1 : Compile the driver of CSharp" />
  </target>

  <target name="3.5 PHP-Driver-Compilation" depends="3.4 CSharp-Driver-Compilation">
		<echo level="info" message="Step1 : Compile the driver of PHP" />
    <chmod file="${code_dir}/thirdparty/php/retriConfig.sh" perm="a+x" />
  </target>

    <echo level="info" message="Step1 : Compile the connector of postgresql" />
		<exec executable="make" dir="${code_dir}/driver/postgresql" failonerror="false">
			<arg line=" clean" />
		</exec>
		<exec executable="make" dir="${code_dir}/driver/postgresql" failonerror="false">
			<arg line=" local" />
		</exec>
		<exec executable="make" dir="${code_dir}/driver/postgresql" failonerror="false">
			<arg line=" all" />
		</exec>

		<ant antfile="${code_dir}/driver/hadoop/hive/build.xml">
			<property name="java.driver.jar" value="${code_dir}/driver/java/${java_driver}"/>
			<property name="javac.base.dir" value="${code_dir}/"/>
			<property name="root.dir" value="${code_dir}/driver/hadoop/hive/"/>
			<property name="open.source.hive_connector.filename" value="${open.source.hive_connector.filename}" />
			<property name="cdh.hive_connector.filename" value="${cdh.hive_connector.filename}" />
		</ant>

		<ant antfile="${code_dir}/driver/hadoop/hadoop-connector/build.xml">
			<property name="hadoop.version" value="1.2" />
			<property name="basedir" value="${code_dir}/driver/hadoop/hadoop-connector" />
			<property name="java.driver.jar" value="${code_dir}/driver/java/${java_driver}"/>
		</ant>
		<ant antfile="${code_dir}/driver/hadoop/hadoop-connector/build.xml">
			<property name="hadoop.version" value="2.2" />
			<property name="basedir" value="${code_dir}/driver/hadoop/hadoop-connector" />
			<property name="java.driver.jar" value="${code_dir}/driver/java/${java_driver}"/>
		</ant>


		<!-- <echo message="/usr/bin/gcc  ${code_dir}/misc/ci/exec-tools/print_version.c -o ${code_dir}/misc/ci/exec-tools/print_version -I${code_dir}/SequoiaDB/engine/include" />
		<exec executable="/usr/bin/gcc" dir="${code_dir}/misc/ci/exec-tools" failonerror="true">
				<arg line="${code_dir}/misc/ci/exec-tools/print_version.c -o ${code_dir}/misc/ci/exec-tools/print_version -I${code_dir}/SequoiaDB/engine/include" />
			</exec>
			<exec executable="${code_dir}/misc/ci/exec-tools/print_version" dir="${code_dir}/misc/ci/exec-tools/" failonerror="true" outputproperty="project.version" />
			<echo message="&#10;project.version=${project.version}" file="${code_dir}/misc/ci/ci.build.properties" append="true" /> -->
	</target>

	<target name="mk-driver" depends="">
		<property name="DRIVER.DIR" value="${build_dir}/driver" />

		<echo message="Begin to make driver package.." />
		<if>
			<equals arg1="${DEBUG}" arg2="true" />
			<then>
				<property name="build.result.dir" value="dd" />
			</then>
			<else>
				<property name="build.result.dir" value="normal" />
			</else>
		</if>

		<mkdir dir="${DRIVER.DIR}/hadoop"/>
		<mkdir dir="${DRIVER.DIR}/java" />
		<mkdir dir="${DRIVER.DIR}/CSharp"/>
		<mkdir dir="${DRIVER.DIR}/include" />
    	<mkdir dir="${DRIVER.DIR}/lib/phplib" />
		<mkdir dir="${DRIVER.DIR}/lib" />
		<mkdir dir="${DRIVER.DIR}/python" />
		<mkdir dir="${DRIVER.DIR}/samples" />
		<mkdir dir="${DRIVER.DIR}/postgresql" />

    	<copy file="${code_dir}/driver/C#.Net/build/release/sequoiadb.dll" tofile="${DRIVER.DIR}/CSharp/sequoiadb.dll" />
		<copy file="${code_dir}/driver/java/${java_driver}" todir="${DRIVER.DIR}/java" />
		<copy file="${code_dir}/driver/hadoop/hive/${open.source.hive_connector.filename}" tofile="${DRIVER.DIR}/hadoop/${open.source.hive_connector.filename}" />
    	<copy file="${code_dir}/driver/hadoop/hive/${cdh.hive_connector.filename}" tofile="${DRIVER.DIR}/hadoop/${cdh.hive_connector.filename}" />
    	<copy todir="${DRIVER.DIR}/hadoop" >
    		<fileset dir="${code_dir}/driver/hadoop/hadoop-connector" includes="**/hadoop-connector-*.jar" />
    	</copy>
		<copy todir="${DRIVER.DIR}/lib">
			<fileset dir="${code_dir}/client/lib/" includes="*" />
		</copy>
		<copy todir="${DRIVER.DIR}/include">
			<fileset dir="${code_dir}/client/include/" includes="**/*" />
		</copy>
		<copy todir="${DRIVER.DIR}/samples">
			<fileset dir="${code_dir}/client/samples/" includes="**/*" />
		</copy>

		<copy file="${code_dir}/driver/postgresql/sdb_fdw.so" tofile="${DRIVER.DIR}/postgresql/sdb_fdw.so" />
		<copy file="${code_dir}/driver/postgresql/sdb_fdw.control" tofile="${DRIVER.DIR}/postgresql/sdb_fdw.control" />
		<copy file="${code_dir}/driver/postgresql/sdb_fdw--1.0.sql" tofile="${DRIVER.DIR}/postgresql/sdb_fdw--1.0.sql" />

	  	<property name="test-type-linux-list" value="5.3.3,5.3.8,5.3.10,5.3.15,5.4.6,5.5.0" />
	  	<property name="test-type-win32-list" value="5.3.18,5.4.15" />
		<for list="${test-type-linux-list}" param="php.version">
			<sequential>
				<antcall target="build-and-copy-php" inheritAll="true">
					<param name="php.version" value="@{php.version}" />
				</antcall>
			</sequential>
		</for>

		<antcall target="build-and-copy-python" inheritAll="true">
			<param name="python.dir" value="${code_dir}/driver/python" />
			<param name="DRIVER.DIR" value="${DRIVER.DIR}" />
		</antcall>

		<tar destfile="${build_dir}/${project.name}-driver-${project.version}-${os.and.platform}.tar.gz" basedir="${build_dir}" includes="driver/**" compression="gzip" />
		<echo message="Make driver package completed." />
	</target>

  	<target name="build-and-copy-php" depends="">
  		<delete dir="${code_dir}/driver/php5/build}" />
  		<mkdir dir="${build_dir}/sequoiadb/lib/phplib" />

  		<chmod perm="u+x" file="${code_dir}/thirdparty/php/linux/retriConfig.sh" />
  		<exec executable="${code_dir}/thirdparty/php/linux/retriConfig.sh" dir="${code_dir}/thirdparty/php/linux" failonerror="true">
			<arg line="  ${php.version} " />
		</exec>
		<exec executable="scons" dir="${code_dir}/driver/php5" failonerror="true">
			<arg line=" ${compile_parameter} --phpversion=${php.version}" />
		</exec>

		<copy file="${code_dir}/driver/php5/build/${build.result.dir}/libsdbphp-${php.version}.so" todir="${DRIVER.DIR}/lib/phplib" />
		<copy file="${code_dir}/driver/php5/build/${build.result.dir}/libsdbphp-${php.version}.so" todir="${build_dir}/sequoiadb/lib/phplib" />
 	</target>

 	<target name="build-and-copy-python" depends="">
 		<property name="python.tar" value="pysequoiadb.tar.gz" />
		<exec executable="scons" dir="${python.dir}">
			<arg line=" " />
		</exec>
		<exec executable="/bin/chmod" dir="${python.dir}">
			<arg line=" u+x ${python.tar}" />
		</exec>
		<copy file="${python.dir}/${python.tar}" todir="${DRIVER.DIR}/python" />
 	</target>

	<target name="mk-release" depends="mk-driver,compile-src">
		<property name="DRIVER.DIR" value="${build_dir}/driver" />

		<mkdir dir="${build_dir}/sequoiadb/bin" />
		<mkdir dir="${build_dir}/sequoiadb/include" />
		<mkdir dir="${build_dir}/sequoiadb/samples" />
		<mkdir dir="${build_dir}/sequoiadb/java/jdk" />
		<mkdir dir="${build_dir}/sequoiadb/CSharp" />
		<mkdir dir="${build_dir}/sequoiadb/hadoop" />
		<mkdir dir="${build_dir}/sequoiadb/doc" />
		<mkdir dir="${build_dir}/sequoiadb/conf/samples" />
		<mkdir dir="${build_dir}/sequoiadb/conf/local" />
		<mkdir dir="${build_dir}/sequoiadb/conf/log" />
		<mkdir dir="${build_dir}/sequoiadb/conf/script" />
		<mkdir dir="${build_dir}/sequoiadb/www" />
		<mkdir dir="${build_dir}/sequoiadb/tools/server/php" />
		<mkdir dir="${build_dir}/sequoiadb/python" />
		<mkdir dir="${build_dir}/sequoiadb/postgresql" />
		<mkdir dir="${build_dir}/sequoiadb/packet" />

		<mkdir dir="${build_dir}/sequoiadb/web" />

		<!-- <if>
			<equals arg1="${DEBUG}" arg2="true" />
			<then>
				<property name="build.result.dir" value="dd" />
			</then>
			<else>
				<property name="build.result.dir" value="normal" />
			</else>
		</if> -->

	    <copy todir="${build_dir}/sequoiadb/bin" >
	       <fileset dir="${code_dir}/bin">
	       		<include name="**/*" />
	       		<exclude name="lib*" />
	       </fileset>
	    </copy>
	    <copy todir="${build_dir}/sequoiadb/web" >
	       <fileset dir="${code_dir}/SequoiaDB/web">
	       		<include name="**/*" />
	       </fileset>
	    </copy>
		<copy todir="${build_dir}/sequoiadb/lib">
			<fileset dir="${code_dir}/client/lib/" includes="**/*" />
		</copy>
		<copy todir="${build_dir}/sequoiadb/tools/sdbsupport">
			<fileset dir="${code_dir}/tools/sdbsupport" includes="**/*" />
		</copy>
		<copy todir="${build_dir}/sequoiadb/include/">
			<fileset dir="${code_dir}/client/include/" includes="**/*" />
		</copy>
		<copy todir="${build_dir}/sequoiadb/www">
			<fileset dir="${code_dir}/client/admin/admintpl" />
		</copy>
		<copy todir="${build_dir}/sequoiadb/samples">
			<fileset dir="${code_dir}/client/samples/" />
		</copy>
		<copy file="${code_dir}/driver/C#.Net/build/release/sequoiadb.dll" tofile="${build_dir}/sequoiadb/CSharp/sequoiadb.dll" />
		<copy todir="${build_dir}/sequoiadb/hadoop" >
    		<fileset dir="${code_dir}/driver/hadoop/hadoop-connector" includes="**/hadoop-connector-*.jar" />
    	</copy>
    	<copy todir="${build_dir}/sequoiadb/conf/script">
    		<fileset dir="${code_dir}/conf/script" includes="**/*" />
    	</copy>
		<copy todir="${build_dir}/sequoiadb/python">
			<fileset dir="${DRIVER.DIR}/python" />
		</copy>
		<copy file="${code_dir}/driver/java/${java_driver}" todir="${build_dir}/sequoiadb/java" />
		<copy file="${code_dir}/driver/hadoop/hive/${open.source.hive_connector.filename}" tofile="${build_dir}/sequoiadb/hadoop/${open.source.hive_connector.filename}" />
		<copy file="${code_dir}/driver/hadoop/hive/${cdh.hive_connector.filename}" tofile="${build_dir}/sequoiadb/hadoop/${cdh.hive_connector.filename}" />

		<copy file="${code_dir}/driver/postgresql/sdb_fdw.so" tofile="${build_dir}/sequoiadb/postgresql/sdb_fdw.so" />
		<copy file="${code_dir}/driver/postgresql/sdb_fdw.control" tofile="${build_dir}/sequoiadb/postgresql/sdb_fdw.control" />
		<copy file="${code_dir}/driver/postgresql/sdb_fdw--1.0.sql" tofile="${build_dir}/sequoiadb/postgresql/sdb_fdw--1.0.sql" />

		<if>
			<equals arg1="${os.arch}" arg2="ppc64" />
			<then>
				<property name="PHP.VERSION" value="php_power" />
				<property name="jdk.file.dir" value="jdk_ppclinux64"/>
			</then>
		</if>
		<if>
			<equals arg1="Linux" arg2="${os.name}" />
			<then>
				<property name="jdk.file.dir" value="jdk_linux64"/>
				<property name="PHP.VERSION" value="php_linux" />
			</then>
			<else>
				<property name="jdk.file.dir" value="jdk_win64"/>
				<property name="PHP.VERSION" value="php_win" />
			</else>
		</if>

		<copy todir="${build_dir}/sequoiadb/java/jdk">
			<fileset dir="${code_dir}/java/${jdk.file.dir}/" />
		</copy>
		<copy todir="${build_dir}/sequoiadb/conf/samples/">
			<fileset dir="${code_dir}/conf/samples/" />
		</copy>
		<copy file="${code_dir}/conf/sdbcm.conf" todir="${build_dir}/sequoiadb/conf" />

		<copy todir="${build_dir}/sequoiadb/tools/server/php">
			<fileset dir="${code_dir}/tools/server/${PHP.VERSION}/" />
		</copy>
		<copy file="${code_dir}/script/sequoiadb" todir="${build_dir}/sequoiadb/" />
		<replaceregexp file="${build_dir}/sequoiadb/sequoiadb" match="&#13;&#10;" replace="&#10;" flags="g" />

		<copy file="${code_dir}/script/install_om.sh" todir="${build_dir}/sequoiadb/" />

	  	<copy file="${code_dir}/script/sdbwsart" todir="${build_dir}/sequoiadb/bin" />
	  	<replaceregexp file="${build_dir}/sequoiadb/bin/sdbwsart" match="&#13;&#10;" replace="&#10;" flags="g" />
	  	<copy file="${code_dir}/script/sdbwstop" todir="${build_dir}/sequoiadb/bin" />
	  	<replaceregexp file="${build_dir}/sequoiadb/bin/sdbwstop" match="&#13;&#10;" replace="&#10;" flags="g" />
		<copy todir="${build_dir}/sequoiadb/doc">
			<fileset dir="${code_dir}/doc/out" />
		</copy>
		<copydir src="${code_dir}/doc/manual/" dest="${build_dir}/sequoiadb/doc/manual" includes="**/*" />
		<copy todir="${build_dir}/sequoiadb/license">
			<fileset dir="${code_dir}/license" />
		</copy>

		<delete includeemptydirs="true">
			<fileset dir="${build_dir}/sequoiadb" includes="**/.svn" />
		</delete>

		<copy file="${code_dir}/misc/ci/mkrelease/sequoiadb_server.xml" todir="${build_dir}/" />
		<copy file="${code_dir}/misc/ci/mkrelease/sequoiadb_en.lng" todir="${build_dir}/" />
		<copy file="${code_dir}/misc/ci/mkrelease/sequoiadb_zh.lng" todir="${build_dir}/" />

		<touch file="${build_dir}/license_empty.txt" />

		<if>
			<equals arg1="${ENTERPRISE}" arg2="true" />
			<then>
				<echo message="the verion is enterprise" />
				<property name="version.name" value="-${enterprise.name}" />
				<echo message="${version.name}" />
			</then>
			<else>
				<echo message="the version is not enterprise" />
				<property name="version.name" value="" />
				<echo message="${version.name}" />
			</else>
		</if>

		<exec dir="${build_dir}" executable="builder" failonerror="true">
			<arg line="build sequoiadb_server.xml --setvars project.version=${project.version}  --setvars platform=${os.and.platform} --setvars enterpriseversion=${version.name} --setvars project.outputDirectory=${build_dir}" />
		</exec>
		<echo message="Make relase package completed." />
		<echo message="os.name=${os.name}, os.arch=${os.arch}" />
		<if>
			<equals arg1="${os.arch}" arg2="amd64" />
			<then>
				<!-- <echo message="begin to make rpm package.." />
				<echo message="tar the sequoiadb-${project.version}.tar.gz to /usr/src/packages/SOURCES..." />
				<move file="${build_dir}/sequoiadb" tofile="${build_dir}/sequoiadb-${project.version}" />
				<tar destfile="/usr/src/packages/SOURCES/sequoiadb-${project.version}.tar.gz" basedir="${build_dir}" includes="sequoiadb-${project.version}/**" compression="gzip" />
				<copy file="${code_dir}/misc/ci/mkrelease/sequoiadb-${project.version}.spec" todir="/usr/src/packages/SPECS" />
				<stafTools workType="shell" workHost="LOCAL" common="rpmbuild -bb -bb sequoiadb-${project.version}.spec" workDir="/usr/src/packages/SPECS" waitTime="30m" />
				<copy file="/usr/src/packages/RPMS/x86_64/sequoiadb-${project.version}-1.x86_64.rpm" todir="${build_dir}" failonerror="false" />
		        <delete file="/usr/src/packages/SOURCES/sequoiadb-${project.version}.tar.gz" />
		        <delete file="/usr/src/packages/SPECS/sequoiadb-${project.version}.spec" />
				<echo message="Make rpm package completed.." /> -->


				<!-- <echo message="begin to make rpm package.." />
				<exec executable="python" timeout="100000" dir="${code_dir}/script" outputproperty="RPM.INFO" resultproperty="ret.rpm">
					<arg line=" package.py" />
				</exec>
				<copy file="${code_dir}/script/sequoiadb-${project.version}-1.x86_64.rpm" todir="${build_dir}" />
				<delete file="${code_dir}/script/sequoiadb-${project.version}-1.x86_64.rpm" /> -->
			</then>
		</if>
	</target>
</project>
