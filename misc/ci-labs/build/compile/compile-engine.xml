<!--
	@Description:
		Compilation the engine
	@Parameters:
		${DEBUG} from compile-control.xml
		${ENTERPRISE} from compile-control.xml
		${code_dir} from compile-control.xml
	@Invocation:
		NULL
-->

<project default="2.1 Build-Engine">
	<target name="2.1 Build-Engine" depends="">
	  	<if>
			<equals arg1="${DEBUG}" arg2="true" />
			<then>
				<echo message="@ The building version is debug now." />
				<property name="compile_parameter" value=" --dd" />
			</then>
			<else>
				<echo message="@ The building version is release now." />
				<property name="compile_parameter" value=" " />
			</else>
		</if>
		<if>
			<equals arg1="${ENTERPRISE}" arg2="true" />
			<then>
				<echo message="@ The building is enterprise now" />
				<property name="enterprise_parameter" value=" --enterprise" />
			</then>
			<else>
				<echo message="@ The building is not enterprise now" />
				<property name="enterprise_parameter" value=" " />
			</else>
		</if>
		<echo level="info" message="Step1 : Begin to compile engine,the command is &lt;scons ${compile_parameter}${enterprise_parameter} --all -j 4&gt;." />
		<exec executable="scons" dir="${code_dir}" failonerror="true">
			<arg line="${compile_parameter}${enterprise_parameter} --all -j 4" />
		</exec>
	</target>
</project>
