<!--@param ${testcases.path} where the test cases files' path-->
<!--@param ${reports.path}: The path where test case direcotry-->
<!--@param ${install.path}: The path where sequoiadb installed.-->
<project name="exec-java-app-test" default="java-app-test">
    <taskdef resource="net/sf/antcontrib/antlib.xml">
        <classpath>
            <pathelement location="/usr/share/java/ant-contrib.jar" />
        </classpath>
    </taskdef>
    <property file="" />

    <target name="clean" depends="">
        <delete dir="${reports.path}" />
        <mkdir="${reports.path}" />
    </target>

    <target name="java-app-test" depends="clean">
        <for param="exec-file">
            <path>
                <fileset dir="${testcases.path}/data-source" includes="sequoiadb*" />
            </path>
            <sequential>
                <echo message="@{exec-file}" />

                <exec executable="${install.path}/sequoiadb/bin/sdb" dir="${install.path}" failonerror="true">
                    <arg line=" -f @{exec-file}" />
                </exec>
            </sequential>
        </for>

        <for param="exec-file">
            <path>
                <fileset dir="${testcases.path}/data-source" includes="mongodb*" />
            </path>
            <sequential>
                <echo message="@{exec-file}" />
                <exec executable="${install.path}/mongodb/bin/mongo" dir="${testcases.path}" failonerror="true">
                    <arg line="  @{exec-file} --nodb " />
                </exec>
            </sequential>
        </for>

        <java jar="${testcases.path}/java-app-test.jar" fork="true" dir="${testcases.path}" failonerror="true" resultproperty="java-res" outputproperty="java-out" errorproperty="java-err" />
    </target>

</project>