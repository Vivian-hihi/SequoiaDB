<!--@param ${install.path} where mongodb install , default in /opt/mongodb-->
<!--@param ${local.mongodb.software.path} where mongodb software is it -->
<!--@param ${properties.dir} where ci.properties.file is it-->
<!--@param ${deploy.host.name} which machine will deploy mongodb software-->
<project name="remote-mongo-deploy" default="deploy-mongo">
	<property name="install.path" value="/opt" />
	<property name="mongodb.install.path" value="${install.path}/mongodb" />
	<property environment="env" />
	<property file="${properties.dir}" />
	
	<target name="trans-file-to-remote" depends="">
		<exec command="${STAF.PATH}\bin\staf LOCAL FS COPY FILE ${local.mongodb.software.path}/mongodb.tar.gz TODIRECTORY ${test.machine.software.path} TOMACHINE ${deploy.host.name}" dir="${STAF.PATH}" failonerror="true" failifexecutionfails="true">
			<env key="PATH" path="${env.PATH}:${STAF.PATH}/bin" />
			<env key="LD_LIBRARY_PATH" path="${env.LD_LIBRARY_PATH}:${STAF.PATH}/lib" />
			<env key="STAFCONVDIR" path="${STAF.PATH}/codepage" />
		</exec>
		<exec command="${STAF.PATH}\bin\staf LOCAL FS COPY FILE ${local.mongodb.software.path}/mongodb-test-deploy.xml TODIRECTORY ${test.machine.software.path} TOMACHINE ${deploy.host.name}" dir="${STAF.PATH}" failonerror="true" failifexecutionfails="true">
			<env key="PATH" path="${env.PATH}:${STAF.PATH}/bin" />
			<env key="LD_LIBRARY_PATH" path="${env.LD_LIBRARY_PATH}:${STAF.PATH}/lib" />
			<env key="STAFCONVDIR" path="${STAF.PATH}/codepage" />
		</exec>
	</target>
	
	<target name="deploy-mongo" depends="trans-file-to-remote" >
		<exec command="${STAF.PATH}\bin\staf ${deploy.host.name} PROCESS START  SHELL COMMAND  ant 
			 -l ${mongodb.install.path}/deploy-mongodb.log 
			 -f ${test.machine.software.path}/mongodb-test-deploy.xml
			 -Dinstall.path=${install.path} 
			 -Dremote.mongodb.software.path=${test.machine.software.path} 
			 WORKDIR ${test.machine.software.path} WAIT 30m" dir="${STAF.PATH}" failonerror="true" failifexecutionfails="true">
			<env key="PATH" path="${env.PATH}:${STAF.PATH}/bin" />
			<env key="LD_LIBRARY_PATH" path="${env.LD_LIBRARY_PATH}:${STAF.PATH}/lib" />
			<env key="STAFCONVDIR" path="${STAF.PATH}/codepage" />
		</exec>
		
		<echo message="${STAF.PATH}\bin\staf ${deploy.host.name} FS GET  FILE ${test.machine.software.path}/deploy-mongodb.log TEXT" />
		<exec command="${STAF.PATH}\bin\staf ${deploy.host.name} FS GET  FILE ${test.machine.software.path}/deploy-mongodb.log TEXT" dir="${STAF.PATH}" failonerror="false" failifexecutionfails="true">
			<env key="PATH" path="${env.PATH}:${STAF.PATH}/bin" />
			<env key="LD_LIBRARY_PATH" path="${env.LD_LIBRARY_PATH}:${STAF.PATH}/lib" />
			<env key="STAFCONVDIR" path="${STAF.PATH}/codepage" />
		</exec>
	</target>
</project>