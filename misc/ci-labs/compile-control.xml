<!--
	@Description:
		Call the build scripts of engine and driver,generate the installation package and driver package
	@Parameters:
		${DEBUG} from Jenkins test intrgration framework
		${JDK5} from Jenkins test intrgration framework
		${ENTERPRISE} from Jenkins test intrgration framework
		${WORKSPACE} from Jenkins test intrgration framework
		${CPU_VERSION} from Jenkins test intrgration framework
	@Invocation:
		compile-engine.xml
    compile-driver.xml
-->

<project default="">
	<property name="code_dir" value="${WORKSPACE}/sequoiadb" />
	<property name="build_dir" value="${WORKSPACE}/release" />
  	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
      	<classpath>
          	<pathelement location="${code_dir}/misc/ci/exec-tools/ant-sdbtasks.jar" />
      	</classpath>
  	</taskdef>

	<target name="1.Prepare-Compilation-Environment" depends="">
		<property file="${code_dir}/misc/ci/ci.build.properties" />
		<echo level="info" message="Step1 : Delete file &lt;${code_dir}/misc/ci/ci.build.properties&gt;." />
  		<delete file="${code_dir}/misc/ci/ci.build.properties" failonerror="false" />
		<echo level="info" message="Step2 : Delete folder &lt;${build_dir}&gt;." />
  		<delete dir="${build_dir}" failonerror="false" />
		<echo level="info" message="Step3 : Rename file &lt;${code_dir}/misc/ci/ci.build.properties.${CPU_VERSION}&gt; to &lt;${code_dir}/misc/ci/ci.build.properties&gt;." />
		<copy file="${code_dir}/misc/ci/ci-properies-files/ci.build.properties.${CPU_VERSION}" tofile="${code_dir}/misc/ci/ci.build.properties" failonerror="false"/>
		<echo level="info" message="Step4 : Rebuild folder &lt;${code_dir}/bin&gt;." />
		<delete dir="${code_dir}/bin"  failonerror="false" />
    	<mkdir dir="${code_dir}/bin" />
		<echo level="info" message="Step5 : Delete folder &lt;${code_dir}/build&gt;." />
    	<delete dir="${code_dir}/build" failonerror="false" />
	</target>

	<target name="2.Engine-Compilation" depends="1.Prepare-Compilation-Environment">
	    <ant antfile="compile-engine.xml" dir="${code_dir}/misc/ci/build/compile" target="2.1 Build-Engine" inheritAll="false">
	      <property name="DEBUG" value="${DEBUG}" />
	      <property name="ENTERPRISE" value="${ENTERPRISE}" />
	      <property name="code_dir" value="${code_dir}" />
	    </ant>
	</target>

  	<target name="3.Driver-Compilation" depends="1.Prepare-Compilation-Environment">
	    <ant antfile="compile-driver.xml" dir="${code_dir}/misc/ci/build/compile" target="" inheritAll="false">
	      <property name="DEBUG" value="${DEBUG}" />
	      <property name="ENTERPRISE" value="${ENTERPRISE}" />
	      <property name="driver_base_dir" value="${code_dir}/misc/ci/build/compile/driver" />
	      <property name="code_dir" value="${code_dir}" />
	    </ant>
	</target>
</project>
