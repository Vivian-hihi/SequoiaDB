<!--
	@Description:
		Control the deployment and testing process
	@Parameters:
		${test.environment} from Jenkins test intrgration framework
		${ci.script.file.path} from Jenkins test intrgration framework
		${BUILD_NUMBER} from Jenkins test intrgration framework
		${WORKSPACE} from Jenkins test intrgration framework
		${test-type-list} from Jenkins test intrgration framework

		test.environment=$TEST_SCENE
		WORKSPACE=$WORKSPACE
		ci.script.file.path=$WORKSPACE/sequoiadb/misc/ci
		BUILD_NUMBER=$BUILD_NUMBER
		test-type-list=js
	@Invocation:
		${test.environment}-${DEPLOY_WILDCARD}.xml
-->

<project default="Deploy-Test-All">
	<hostinfo prefix="host" />
	<property file="${ci.script.file.path}/ci.test.properties" />
	<property name="deploy.config.path" value="${ci.script.file.path}/deploy-config" />
	<property name="release.path" value="${WORKSPACE}/release" />
<!-- 	<property name="isTrunk" value="true" /> -->
	<if>
	   	<equals arg1="${isTrunk}" arg2="true" />
		<then>
		    <property name="test.reports.path" value="${WORKSPACE}/reportsTrunk" />
		</then>
		<else>
		    <property name="test.reports.path" value="${WORKSPACE}/reportsBranch" />
		</else>
	</if>
	<property file="${release.path}/build.version" />
	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
		<classpath>
			<fileset dir="${WORKSPACE}/deploy/ant-sdbtasks" includes="ant-sdbtasks.jar" />
		</classpath>
	</taskdef>
	
	<target name="Tar-Deploy-Package" depends="" >
		<property name="execTools.tar.file.name" value="execTools.tar.gz" />
		<echo level="info" message="Step1 : Tar the package &lt;${WORKSPACE}/${deploy.tar.file.name}&gt; and on &lt;${WORKSPACE}/${execTools.tar.file.name}&gt; &lt;${WORKSPACE}&gt;." />
		<tar destfile="${WORKSPACE}/${deploy.tar.file.name}" basedir="${WORKSPACE}" includes="deploy/**/*" compression="gzip" />
		<!-- <tar destfile="${WORKSPACE}/${execTools.tar.file.name}" basedir="${ci.script.file.path}" includes="exec-tools/SQLExecTest/**/*" compression="gzip" /> -->
	</target>
	
	<target name="Clean-Last-Build-Reports" depends="Tar-Deploy-Package">
		<echo level="info" message="Step1 : Rebuild the folder &lt;${test.reports.path}&gt;." />
		<delete dir="${test.reports.path}" failonerror="false" />
		<mkdir dir="${test.reports.path}" />
	</target>

	<target name="Deploy-Test-All" depends="Clean-Last-Build-Reports">
		<foreach target="Deploy-And-Test-Case" param="deploy.case.fullname">
			<path>
				<fileset dir="${deploy.config.path}" includes="${test.environment}-${DEPLOY_WILDCARD}.xml" excludes="" />
			</path>
		</foreach>
	</target>

	<target name="Deploy-And-Test-Case" depends="">
		<echo level="info" message="Step1 : Call the target &lt;Deploy-Software&gt; on script file &lt;${deploy.case.fullname}&gt; on &lt;${ci.script.file.path}&gt;,command:&lt;ant -f ${deploy.case.fullname} --target=Deploy-Software -Dinstall.package.fullname=${release.path}/${BUILD.INSTALL.FILENAME} -Ddeploy.file.fullname=${deploy.file.fullname} -Ddeploy.path=${WORKSPACE}/deploy&gt;." />
		<ant antfile="${deploy.case.fullname}" dir="${ci.script.file.path}" target="Deploy-Software" inheritAll="true">
			<property name="install.package.fullname" value="${release.path}/${BUILD.INSTALL.FILENAME}" />
			<property name="deploy.file.fullname" value="${WORKSPACE}/${deploy.tar.file.name}" />
			<property name="isTrunk" value="${isTrunk}" />
		</ant>
		<if>
			<equals arg1="${TEST_CHOICE}" arg2="true" />
			<then>
				<ant antfile="${deploy.case.fullname}" dir="${ci.script.file.path}" inheritAll="true">
					<property name="test.reports.path" value="${test.reports.path}" />
					<property name="deploy.case.fullname" value="${deploy.case.fullname}" />
					<property name="WORKSPACE" value="${WORKSPACE}" />
					<property name="test.environment" value="${test.environment}" />
					<property name="DEPLOY_WILDCARD" value="${DEPLOY_WILDCARD}" />
					<property name="ci.script.file.path" value="${ci.script.file.path}" />
					<property name="BUILD_NUMBER" value="${BUILD_NUMBER}" />
					<property name="deploy.file.fullname" value="${WORKSPACE}/${deploy.tar.file.name}" />

					<property name="test-type-list" value="${test-type-list}" />
					<property name="OS_NAME" value="${OS_NAME}" />
					<property name="execTools.file.fullname" value="${execTools.file.fullname}" />
					<property name="isTrunk" value="${isTrunk}" />
					<property name="BACKUP_LOG" value="${BACKUP_LOG}" />
				</ant>
			</then>
		</if>
		<echo message="Deploy ${deploy.case.fullname} complete. " />
	</target>
</project>