<!--@param ${test.environment} : the control the test Environment -->
<!--@param ${WORKSPACE}: The path where the deploy directory -->
<!--@param ${ci.script.file.path} : the ci-script file path -->
<!--@param ${deploy.conffile.wildcard}: deploy config file wildcard. just for debug -->
<!--@param ${is.test}: the flag for whether execute test, if set false, then just deploy. just for debug -->
<!--@param ${BUILD_NUMBER} : what number is it build -->
<project name="deploy-test-all" default="Archive-Test-Result">
	<hostinfo prefix="host" />
	<property file="${ci.script.file.path}/ci.test.properties" />
	<property name="deploy.config.path" value="${ci.script.file.path}/deploy-config" />
	<property name="release.path" value="${WORKSPACE}/release" />
	<property file="${release.path}/build.version" />
	<property name="is.test" value="true" />
	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
		<classpath>
			<fileset dir="${WORKSPACE}/deploy/ant-sdbtasks/" includes="*.jar" />
		</classpath>
	</taskdef>
	
	<target name="Tar-Deploy-File" depends="" >
		<echo message="Tarred the test file by deploy-test-all.xml" />
		<tar destfile="${WORKSPACE}/${deploy.tar.file.name}" basedir="${WORKSPACE}" includes="deploy/**/*" compression="gzip" />
	</target>
	
	<target name="Clean-Last-Build-Reports" depends="Tar-Deploy-File">
		<delete dir="${WORKSPACE}/reports" />
		<mkdir dir="${WORKSPACE}/reports" />
		<!-- <delete dir="${WORKSPACE}/${host.NAME}-copy-log" />
		<mkdir dir="${WORKSPACE}/${host.NAME}-copy-log" /> -->
	</target>

	<target name="Deploy-Test-All" depends="Clean-Last-Build-Reports">
		<!-- <property name="deploy.conffile.wildcard" value="*" /> -->
		
		<foreach target="deploy-one-case-and-test" param="deploy.case.fullname">
			<path>
				<fileset dir="${deploy.config.path}" includes="${test.environment}-${deploy.conffile.wildcard}.xml" />
			</path>
			<param name="deploy.file.fullname" value="${WORKSPACE}/${deploy.tar.file.name}" />
		</foreach>
	</target>

	<target name="clean-deploy-env-before-test" depends="">
		<echo message="Begin to clean test env..." />
		<parallel>
			<ant antfile="deploy-software-in-host.xml" dir="." target="uninstall-software" inheritAll="false">
				<property name="deploy.host.name" value="${test.machine.no1.basic}" />
				<property name="install.package.fullname" value="${release.path}/${BUILD.INSTALL.FILENAME}" />
			</ant>
			<ant antfile="deploy-software-in-host.xml" dir="." target="uninstall-software" inheritAll="false">
				<property name="deploy.host.name" value="${test.machine.no2.basic}" />
				<property name="install.package.fullname" value="${release.path}/${BUILD.INSTALL.FILENAME}" />
			</ant>
			<ant antfile="deploy-software-in-host.xml" dir="." target="uninstall-software" inheritAll="false">
				<property name="deploy.host.name" value="${test.machine.no3.basic}" />
				<property name="install.package.fullname" value="${release.path}/${BUILD.INSTALL.FILENAME}" />
			</ant>
		</parallel>
		<sleep seconds="10"/>
	</target>

	<target name="deploy-one-case-and-test" depends="clean-deploy-env-before-test">
		<echo message="Begin to deploy one case and test.... " />
		<echo message="deploy file=${deploy.case.fullname},deploy.file.fullname=${deploy.file.fullname}" />
	    <echo message="antfile  -f ${deploy.case.fullname} --target=Deploy -Dant.sdb.tasks.path=${ci.script.file.path}/ant-tasks -Dinstall.path=${install.path} -Dinstall.package.fullname=${release.path}/${BUILD.INSTALL.FILENAME} -Ddeploy.file.fullname=${deploy.file.fullname} -Ddeploy.path=${WORKSPACE}/deploy " />	
		<ant antfile="${deploy.case.fullname}" dir="${ci.script.file.path}" target="Deploy" inheritAll="true">
			<property name="ant.sdb.tasks.path" value="${ci.script.file.path}/ant-tasks" />
			<property name="install.path" value="${install.path}" />
			<property name="install.package.fullname" value="${release.path}/${BUILD.INSTALL.FILENAME}" />
			<property name="deploy.file.fullname" value="${deploy.file.fullname}" />
			<property name="deploy.path" value="${WORKSPACE}/deploy" />
<!-- 			<property name="deploy.conffile.wildcard" value="${deploy.conffile.wildcard}" /> -->
		</ant>

		<if>
			<equals arg1="${is.test}" arg2="true" />
			<then>
				<ant antfile="${deploy.case.fullname}" dir="${ci.script.file.path}" target="Test" inheritAll="true">
					<property name="ant.sdb.tasks.path" value="${ci.script.file.path}/ant-tasks" />
					<property name="install.path" value="${install.path}" />
					<property name="deploy.path" value="${WORKSPACE}/deploy" />
					<property name="test.reports.path" value="${WORKSPACE}/reports" />
					<property name="deploy.case.fullname" value="${deploy.case.fullname}" />
					<property name="WORKSPACE" value="${WORKSPACE}" />
					<!-- <property name="deploy.conffile.wildcard" value="${deploy.conffile.wildcard}" /> -->
				</ant>
			</then>
		</if>
		<echo message="Deploy ${deploy.case.fullname} complete. " />
	</target>

	<target name="Archive-Test-Result" depends="">
		<property name="copy.test.log" value="true"/>
		<property name="test.log.path" value="${WORKSPACE}/reports/${test.environment}-${deploy.conffile.wildcard}-${host.NAME}-${current.time.log}">
		<trycatch>
			<try>
				<if>
					<equals arg1="${copy.test.log}" arg2="true" />
					<then>
						<echo message="The copy.test.log is true , then copy all test log to ${save.testLog.hostname}:${save.testLog.dir}"/>
						<tstamp>
							<format property="current.time.log" pattern="yyyy-MM-dd-hh.mm.ss" />
						</tstamp>

						<echo message="Mkdir ${test.log.path}" />
						<mkdir dir="${test.log.path}" />

						<if>
							<equals arg1="${deploy.conffile.wildcard}" arg2="standalone-tp1" />
							<then>
								<echo message="It's the standalone mod..." />
								<sdbCopyAndTar fileHostName="${test.machine.no2.basic}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
							</then>
							<else>
								<echo message="It's the cluster mod..." />
								<sdbCopyAndTar fileHostName="${test.machine.no1.basic}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test.machine.no2.basic}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test.machine.no3.basic}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
							</else>
						</if>

						<tar basedir="${WORKSPACE}/reports" destfile="${test.log.path}.tar.gz" compression="gzip" includes="${test.log.path}/**" />
						<stafTools workType="copy" workHost="${host.NAME}" fileName="${test.log.path}.tar.gz"  toHost="${save.testLog.hostname}" workDir="${WORKSPACE}/reports" saveDir="${save.testLog.dir}" />
						<sdbProperty name="delete.diaglogFile" value="dir=$(find /opt/sequoiadb/database -name diaglog); for d in $dir ; do echo rm -f $d/* ; rm -f $d/* ; done" />
				
						<if>
							<equals arg1="${deploy.conffile.wildcard}" arg2="standalone-tp1" />
							<then>
								<stafTools workType="shell" workHost="${test.machine.no2.basic}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="false" />
							</then>
							<else>
								<stafTools workType="shell" workHost="${test.machine.no1.basic}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="false" />
								<stafTools workType="shell" workHost="${test.machine.no2.basic}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="false" />
								<stafTools workType="shell" workHost="${test.machine.no3.basic}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="false" />
							</else>
						</if>

						<echo message="Delete ${test.log.path}.tar.gz and ${test.log.path} dir ..." />
						<delete file="${test.log.path}.tar.gz" failonerror="false" />
						<delete dir="${test.log.path}" failonerror="false"/>
					</then>
				</if>
			</try>
			<catch>
				<echo message="copy log for download code fail" />
			</catch>
			<finally>
				<echo message="Delete the uninstall configure file on test machine:/tmp... " />
				<property name="delete.cmd" value="find ./ -name 'bitrock_installer*.log'" />
				
				<stafTools workType="shell" workHost="${test.machine.no1.basic}" workDir="/tmp" common="${delete.cmd}" failonerror="false" />
				<stafTools workType="shell" workHost="${test.machine.no2.basic}" workDir="/tmp" common="${delete.cmd}" failonerror="false" />
				<stafTools workType="shell" workHost="${test.machine.no3.basic}" workDir="/tmp" common="${delete.cmd}" failonerror="false" />
			</finally>
		</trycatch>
	</target>
</project>