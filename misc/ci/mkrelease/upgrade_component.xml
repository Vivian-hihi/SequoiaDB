<component>
    <name>upgrade_component</name>    
                    
    <readyToInstallActionList>          
                             
        <consoleWrite text="${msg(Upgrade.NormalMsg.BeginUpgrade)}&#xA;"/>        
        <consoleWrite text="${msg(Upgrade.NormalMsg.CheckList)}&#xA;"/>         
                                
        <throwError>
            <text>${msg(Upgrade.ErrorMsg.SystemConfExist)}</text>
            <ruleList>
                <fileTest condition="not_exists" path="${sys_conf_file}"/>                
            </ruleList>
        </throwError>
        <consoleWrite text="${msg(Upgrade.NormalMsg.SystemConfExist)}&#xA;"/>
        
        <setInstallerVariable name="installdir_inconf" value=""/>
        <setInstallerVariable name="username" value=""/>
        <propertiesFileGet>
            <file>${sys_conf_file}</file>            
            <key>INSTALL_DIR</key>
            <variable>installdir_inconf</variable>
            <customErrorMessage>${msg(Upgrade.ErrorMsg.GetInstallDir)}</customErrorMessage>
        </propertiesFileGet>
        <propertiesFileGet>
            <file>${sys_conf_file}</file>
            <key>SDBADMIN_USER</key>
            <variable>username</variable>
            <customErrorMessage>${msg(Upgrade.ErrorMsg.GetUser)}</customErrorMessage>            
        </propertiesFileGet>        
        <throwError>
            <text>${msg(Upgrade.ErrorMsg.EmptyInstallDir.EmptyUser)}</text>
            <ruleEvaluationLogic>or</ruleEvaluationLogic>
            <ruleList>
                 <compareTextLength text="${username}" logic="equals" length="0"/> 
                 <compareTextLength text="${installdir_inconf}" logic="equals" length="0"/>                                         
            </ruleList>
        </throwError>
        <consoleWrite text="${msg(Upgrade.NormalMsg.GetInstallDir.GetUser)}&#xA;"/>
        
        <setInstallerVariable name="installdir" value="${installdir_inconf}"/>
        <setInstallerVariable name="project.rollbackBackupDirectory" value="${installdir}/rollback/BackupDir_${time}"/>
        <throwError>
            <text>${msg(Upgrade.ErrorMsg.InstallationExist)}</text>            
            <ruleEvaluationLogic>or</ruleEvaluationLogic>
            <ruleList>
                <fileTest condition="not_exists" path="${installdir}"/> 
                <fileTest condition="is_empty" path="${installdir}"/>                      
            </ruleList>
        </throwError>
        <consoleWrite text="${msg(Upgrade.NormalMsg.InstallationExist)}&#xA;"/>
        
        <propertiesFileGet>
            <file>${sys_conf_file}</file>
            <key>MD5</key>
            <variable>old_md5sum</variable> 
            <abortOnError>0</abortOnError>
            <showMessageOnError>0</showMessageOnError>
        </propertiesFileGet>
        <setInstallerVariable name="new_md5sum" value="0000"/>
        <setInstallerVariableFromScriptOutput>
            <exec>/usr/bin/md5sum</exec>
            <execArgs>${installer_pathname} | cut -c 1-32 </execArgs>
            <name>new_md5sum</name>
        </setInstallerVariableFromScriptOutput>
        <throwError>
            <text>${msg(Upgrade.ErrorMsg.ComparePackage)}</text>            
            <ruleList>
                <compareValues value1="${new_md5sum}" logic="equals" value2="${old_md5sum}"/>                                                        
            </ruleList>
        </throwError>
        <consoleWrite text="${msg(Upgrade.NormalMsg.ComparePackage)}&#xA;"/>
                
        <setInstallerVariable name="old_version" value="0"/>
        <setInstallerVariable name="old_edition" value="C"/>
        <setInstallerVariable name="new_version" value="0"/>
        <setInstallerVariable name="new_edition" value="C"/>
                       
        <setInstallerVariableFromScriptOutput>
            <name>old_version</name>
            <exec>${installdir}/bin/sequoiadb</exec>
            <execArgs> --version | grep "version" | awk '{print $3}'</execArgs>                    
        </setInstallerVariableFromScriptOutput> 
        <setInstallerVariableFromScriptOutput>
            <name>old_is_enterprise</name>
            <exec>${installdir}/bin/sequoiadb</exec>
            <execArgs> --version | grep -i enterprise | wc -l </execArgs>            
        </setInstallerVariableFromScriptOutput>
        <setInstallerVariable>
            <name>old_edition</name>
            <value>E</value>
            <ruleList>
                <compareValues value1="${old_is_enterprise}" logic="greater" value2="0"/> 
            </ruleList>    
        </setInstallerVariable>  
                                                                
        <setInstallerVariable name="new_version" value="${project.version}"/>
        <setInstallerVariable>
            <name>new_edition</name>
            <value>E</value>
            <ruleList>
                <compareValues value1="${enterpriseversion}" logic="equals" value2="-enterprise"/> 
            </ruleList>    
        </setInstallerVariable>
                                    
        <throwError>
            <text>${msg(Upgrade.ErrorMsg.SpecialVersion.0)}</text>            
            <ruleEvaluationLogic>and</ruleEvaluationLogic>
            <ruleList>
                <compareValues value1="${old_version}" logic="equals" value2="2.0"/>
                <compareValues value1="${old_edition}" logic="equals" value2="C"/>
            </ruleList>
        </throwError>        
        <throwError>
            <text>${msg(Upgrade.ErrorMsg.SpecialVersion.0)}</text>            
            <ruleEvaluationLogic>and</ruleEvaluationLogic>
            <ruleList>
                <compareValues value1="${new_version}" logic="equals" value2="2.0"/>
                <compareValues value1="${new_edition}" logic="equals" value2="C"/>
            </ruleList>
        </throwError>
                <throwError>
            <text>${msg(Upgrade.ErrorMsg.SpecialVersion.1)}</text>            
            <ruleEvaluationLogic>and</ruleEvaluationLogic>
            <ruleList>
                <compareValues value1="${old_version}" logic="equals" value2="2.1"/>
                <compareValues value1="${old_edition}" logic="equals" value2="C"/>
            </ruleList>
        </throwError>        
        <throwError>
            <text>${msg(Upgrade.ErrorMsg.SpecialVersion.1)}</text>            
            <ruleEvaluationLogic>and</ruleEvaluationLogic>
            <ruleList>
                <compareValues value1="${new_version}" logic="equals" value2="2.1"/>
                <compareValues value1="${new_edition}" logic="equals" value2="C"/>
            </ruleList>
        </throwError>
                                                                                  
        <throwError>
            <text>${msg(Upgrade.ErrorMsg.DiskSpace)}</text>
            <ruleList>
                <checkFreeDiskSpace>
                    <logic>less_or_equal</logic>
                    <path>${installdir}</path>
                    <size>1300000</size>
                </checkFreeDiskSpace>
            </ruleList>
        </throwError>
        <consoleWrite text="${msg(Upgrade.NormalMsg.DiskSpace)}&#xA;"/>
        
        <setInstallerVariable name="has_user" value="0"/>
        <setInstallerVariableFromScriptOutput>
            <exec>cat</exec>
            <execArgs> /etc/passwd | grep sdbadmin | wc -l</execArgs>
            <name>has_user</name>
        </setInstallerVariableFromScriptOutput>
        <throwError>
            <text>${msg(Upgrade.NormalMsg.UserExist)}</text>            
            <ruleList>
                <compareValues value1="${has_user}" logic="equals" value2="0"/>                                                        
            </ruleList>
        </throwError>
        <consoleWrite text="${msg(Upgrade.NormalMsg.UserExist)}&#xA;"/>  
        
        <!--before upgrade, stop service -->       
        <runProgram>
            <program>service</program>
            <programArguments> sdbcm status</programArguments> 
            <abortOnError>0</abortOnError>   
            <showMessageOnError>0</showMessageOnError>       
        </runProgram>        
        <setInstallerVariable name="service_origin_status" value="${program_exit_code}"/>       
        <actionGroup> 
            <actionList>
                <runProgram>
                    <program>service</program>
                    <programArguments> sdbcm stop</programArguments> 
                    <abortOnError>0</abortOnError>          
                </runProgram> 
                <runProgram>
                    <program>service</program>
                    <programArguments> sdbcm status</programArguments> 
                    <abortOnError>0</abortOnError> 
                    <showMessageOnError>0</showMessageOnError>         
                </runProgram>               
                <setInstallerVariable name="service_status" value="${program_exit_code}"/>       
                <throwError>
                    <text>${msg(Upgrade.ErrorMsg.StopProcess)}</text>
                    <ruleList>
                        <compareValues value1="${service_status}" logic="equals" value2="0"/>
                    </ruleList>
                </throwError>    
            </actionList>        
            <ruleList> 
                <compareText logic="equals" text="${service_origin_status}" value="0"/>                                                                  
            </ruleList>          
        </actionGroup>                  
        <actionGroup> 
            <actionList>
                <setInstallerVariable name="process_num" value="-1"/>        
                <setInstallerVariableFromScriptOutput>
                    <name>process_num</name>
                    <exec>${installdir}/bin/sdblist</exec>
                    <execArgs> | grep -v "Total" | wc -l</execArgs> 
                    <abortOnError>0</abortOnError>          
                </setInstallerVariableFromScriptOutput>
                <throwError>
                    <text>${msg(Upgrade.ErrorMsg.StopProcess)}</text>            
                    <ruleList>
                        <compareValues value1="${process_num}" logic="greater" value2="0"/>                                                        
                    </ruleList>
                </throwError> 
            </actionList>        
            <ruleList>
                 <fileTest condition="exists" path="${installdir}/bin/sdblist"/>                                        
            </ruleList>          
        </actionGroup>       
                                                                                                                          
    </readyToInstallActionList>    
                   
    <folderList> 
        <folder>
            <name>check_compatible</name>
            <destination>${installdir}/tmp</destination>
            <actionList>
                <setInstallerVariable name="upgrade_component_done" value="begin"/>  
               
                <changePermissions>
                    <files>${installdir}/tmp/compatible.sh</files>
                    <permissions>0755</permissions>
                </changePermissions>
                
                <setInstallerVariableFromScriptOutput>
                    <name>is_compatible</name>
                    <exec>${installdir}/tmp/compatible.sh</exec>
                    <execArgs>${old_version} ${old_edition} ${new_version} ${new_edition} ${installdir}/tmp/version.conf</execArgs>           
                </setInstallerVariableFromScriptOutput>                
                <setInstallerVariable name="return_code" value="${program_exit_code}"/>        
                <throwError>
                    <text>${msg(Upgrade.ErrorMsg.excuteComatibleSh)}</text>
                    <ruleList>
                        <compareValues value1="${return_code}" logic="does_not_equal" value2="0"/>
                    </ruleList>
                </throwError>
                <throwError>
                    <text>${msg(Upgrade.ErrorMsg.JudgeComatible)}</text>
                    <ruleList>
                        <isFalse value="${is_compatible}"/>
                    </ruleList>
                </throwError>                                    
                <consoleWrite text="${msg(Upgrade.NormalMsg.JudgeComatible)}&#xA;"/>                
                <deleteFile>
                    <abortOnError>0</abortOnError>
                    <path>${installdir}/tmp</path>
                    <ruleList>               
                        <fileExists path="${installdir}/tmp"/>
                    </ruleList>
                </deleteFile>                                  
            </actionList>                     
            <distributionFileList>
                <distributionDirectory>
                    <allowWildcards>1</allowWildcards> 
                    <origin>${build_project_directory}/sequoiadb/tmp/*</origin>
                </distributionDirectory>
            </distributionFileList>                                        
        </folder>             
        <folder>
            <name>copy_files_except_conf_1</name>
            <destination>${installdir}</destination>                      
            <distributionFileList>
                <distributionDirectory>
                    <allowWildcards>1</allowWildcards> 
                    <origin>${build_project_directory}/sequoiadb/*</origin>
                    <excludeFiles>*/conf;*/tmp</excludeFiles>
                </distributionDirectory>
            </distributionFileList>                                        
        </folder>
        <folder>
            <name>copy_files_except_conf_2</name>
            <destination>${installdir}/conf</destination>                    
            <distributionFileList>
                <distributionDirectory>
                    <allowWildcards>1</allowWildcards> 
                    <origin>${build_project_directory}/sequoiadb/conf/*</origin>
                    <excludeFiles>*/local;*/log;*/sdbcm.conf</excludeFiles>
                </distributionDirectory>
            </distributionFileList> 
            <actionList>               
                <setInstallerVariable name="upgrade_component_done" value="end"/>  
            </actionList>                                        
        </folder>        
    </folderList>
      
    <postInstallationActionList>       
               
        <createSymLink>
            <linkName>${installdir}/tools/server/php/libxml2/lib/libxml2.so</linkName>
            <target>${installdir}/tools/server/php/libxml2/lib/libxml2.so.2.9.0</target>
        </createSymLink>
        <createSymLink>
            <linkName>${installdir}/tools/server/php/libxml2/lib/libxml2.so.2</linkName>
            <target>${installdir}/tools/server/php/libxml2/lib/libxml2.so.2.9.0</target>
        </createSymLink>
        <createSymLink>
            <linkName>${installdir}/tools/server/php/libxml2/lib/libz.so</linkName>
            <target>${installdir}/tools/server/php/libxml2/lib/libz.so.1.2.5</target>
        </createSymLink>
        <createSymLink>
            <linkName>${installdir}/tools/server/php/libxml2/lib/libz.so.1</linkName>
            <target>${installdir}/tools/server/php/libxml2/lib/libz.so.1.2.5</target>
        </createSymLink>
        <changeOwnerAndGroup>
            <files>${installdir}/tools/server/php/libxml2/lib</files>
            <group>${username}_group</group>
            <owner>${username}</owner>
        </changeOwnerAndGroup>               
        <changePermissions files="${installdir}/bin/{*,*/*}" permissions="0755">
            <customErrorMessage>${msg(Install.ErrorMsg.ChangeInsallerPathPermissions.error)}</customErrorMessage>
        </changePermissions>
        <changePermissions>
            <files>${installdir}/tools/server/php/bin/*</files>
            <permissions>0755</permissions>
        </changePermissions>
        <changePermissions>
            <files>${installdir}/www/shell/*</files>
            <permissions>0755</permissions>
        </changePermissions>
        <changePermissions>
            <files>${installdir}/install_om.sh</files>
            <permissions>0755</permissions>
        </changePermissions>
        <dos2unix>
            <files>${installdir}/tools/server/php/bin/php</files>
        </dos2unix>
        <iniFileSet>
            <file>${installdir}/tools/server/php/lib/php.ini</file>
            <key>extension_dir</key>
            <section>PHP</section>
            <value>${installdir}/lib/phplib</value>
        </iniFileSet>
        <changePermissions>
            <files>${installdir}/java/jdk/bin/*</files>
            <permissions>0755</permissions>
        </changePermissions>
        
         <runProgram>           
            <program>${installdir}/install_om.sh</program>
            <programArguments>${project.installationType} ${installdir} ${installer_pathname}</programArguments>          
        </runProgram> 
        
        <addUnixService>
            <customErrorMessage>${msg(Install.ErrorMsg.CreateLinuxService.error)}</customErrorMessage>           
            <name>sdbcm</name>
            <program>${installdir}/sequoiadb</program>           
        </addUnixService> 
        
        <!--after upgrade, start service-->       
        <runProgram>
            <program>service</program>
            <programArguments> sdbcm start</programArguments>            
        </runProgram>       
        <runProgram>
            <program>service</program>
            <programArguments> sdbcm status</programArguments>
            <abortOnError>0</abortOnError> 
            <showMessageOnError>0</showMessageOnError>                  
        </runProgram>
        <setInstallerVariable name="service_status" value="${program_exit_code}"/>         
        <consoleWrite>
            <text>${msg(Upgrade.WarnMsg.StartProcess)}&#xA;</text>
            <ruleList>
                <compareValues value1="${service_status}" logic="does_not_equal" value2="0"/>
            </ruleList>
        </consoleWrite>    
                        
        <changePermissions>
            <files>${installdir}/postgresql/*</files>
            <permissions>0755</permissions>
        </changePermissions>
        <changePermissions>
            <files>/tmp</files>
            <permissions>0777</permissions>
        </changePermissions>
        <changeOwnerAndGroup>
            <files>${installdir}/packet/*</files>
            <group>${username}_group</group>
            <owner>${username}</owner>
        </changeOwnerAndGroup>
        <changeOwnerAndGroup>
            <files>${installdir}/bin/sdbomtool</files>
            <group>root</group>
            <owner>root</owner>
        </changeOwnerAndGroup>
        <changePermissions>
            <files>${installdir}/bin/sdbomtool</files>
            <permissions>6755</permissions>
        </changePermissions>        
        
        <propertiesFileSet>
            <file>/etc/default/sequoiadb</file>
            <key>MD5</key>
            <value>${new_md5sum}</value>
        </propertiesFileSet>               
        
        <runProgram>
            <program>echo</program>
            <programArguments>'time: ${time}' &gt;&gt; ${installdir}/upgrade.log</programArguments>
        </runProgram>   
        <setInstallerVariable name="log" value="upgrade from version ${old_version} ${old_edition} to ${new_version} ${new_edition} "/>
        <runProgram>
            <program>echo</program>
            <programArguments> -e '${log}\n' &gt;&gt; ${installdir}/upgrade.log</programArguments>
        </runProgram>
        <changeOwnerAndGroup>
            <files>${installdir}/upgrade.log</files>
            <group>${username}_group</group>
            <owner>${username}</owner>
        </changeOwnerAndGroup>        
        <changeOwnerAndGroup>
            <files>/etc/default/sequoiadb</files>
            <group>root</group>
            <owner>root</owner>
        </changeOwnerAndGroup>
        
        
    </postInstallationActionList>
        
    <installationAbortedActionList>                                                          
        <actionGroup> 
            <actionList>
                <consoleWrite text="&#xA;${msg(Upgrade.NormalMsg.RestoreFile)}&#xA;"/>
                 <runProgram>
                    <program>cp</program>
                    <programArguments>-rfp ${project.rollbackBackupDirectory}/* /</programArguments>                 
                </runProgram>
                <deleteFile path="${project.rollbackBackupDirectory}"/> 
                <deleteFile path="${installdir}/tmp"/>                          
            </actionList>
            <ruleList>
                <compareText logic="equals" text="${upgrade_component_done}" value="begin"/>            
            </ruleList>
        </actionGroup>        
        
        <!--when rollback, restart service-->                
        <actionGroup> 
            <actionList>
                <runProgram>
                    <program>service</program>
                    <programArguments> sdbcm start</programArguments>        
                </runProgram> 
                <runProgram>
                    <program>service</program>
                    <programArguments> sdbcm status</programArguments> 
                    <abortOnError>0</abortOnError>
                    <showMessageOnError>0</showMessageOnError>   
                </runProgram>
                <setInstallerVariable name="service_status" value="${program_exit_code}"/>       
                <consoleWrite>
                    <text>${msg(Upgrade.WarnMsg.StartProcess)}&#xA;</text>
                    <ruleList>
                        <compareValues value1="${service_status}" logic="does_not_equal" value2="0"/>
                    </ruleList>
                </consoleWrite>    
            </actionList>        
            <ruleList> 
                <compareText logic="equals" text="${service_origin_status}" value="0"/>                                                                  
            </ruleList>          
        </actionGroup>                  
                             
    </installationAbortedActionList>    
</component>
  