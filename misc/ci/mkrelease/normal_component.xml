<component>
    <name>normal_component</name>
        
    <readyToInstallActionList>
        <setInstallerVariable name="begin_normal_component" value="true"/>
        
        <throwError>
            <text>There is not enough disk space for installation.</text>
            <ruleList>
                <checkFreeDiskSpace>
                    <logic>less_or_equal</logic>
                    <path>${installdir}</path>
                    <size>1300000</size>
                </checkFreeDiskSpace>
            </ruleList>
        </throwError>
        <throwError>
            <text>The ROOT user is not allowed to create.</text>
            <ruleList>
                <compareValues>
                    <logic>equals</logic>
                    <value1>${username}</value1>
                    <value2>root</value2>
                </compareValues>
            </ruleList>
        </throwError>
        <runProgram>
            <abortOnError>0</abortOnError>
            <customErrorMessage>${msg(Install.ErrorMsg.CreateGroup.error)}</customErrorMessage>
            <program>groupadd</program>
            <programArguments>${username}_group</programArguments>
            <showMessageOnError>0</showMessageOnError>
            <ruleList>              
                <userTest>
                    <logic>not_exists</logic>
                    <username>${username}</username>
                </userTest>
            </ruleList>
        </runProgram>
        <runProgram>
            <abortOnError>0</abortOnError>
            <customErrorMessage>${msg(Install.ErrorMsg.CreateGroup.error)}</customErrorMessage>
            <program>useradd</program>
            <programArguments> ${username} -m -p ${userpasswd} -g ${username}_group  -s /bin/bash </programArguments>
            <useMSDOSPath>0</useMSDOSPath>
            <ruleList>                
                <userTest>
                    <logic>not_exists</logic>
                    <username>${username}</username>
                </userTest>
            </ruleList>
        </runProgram>
        <runProgram>
            <program>echo</program>
            <programArguments> ${username}:${userpasswd} | chpasswd</programArguments>
            <workingDirectory>/usr/sbin</workingDirectory>            
        </runProgram>
        <runProgram>
            <abortOnError>0</abortOnError>
            <program>echo</program>
            <programArguments>3 &gt; /proc/sys/net/ipv4/tcp_retries2</programArguments>
            <ruleList>               
                <fileExists>
                    <path>/proc/sys/net/ipv4/tcp_retries2</path>
                </fileExists>
            </ruleList>
        </runProgram>
        <changePermissions>
            <files>/home</files>
            <permissions>0755</permissions>
            <ruleList>
                <fileExists>
                    <path>/home/${username}</path>
                </fileExists>
            </ruleList>
        </changePermissions>
        <createDirectory>
            <path>~${username}</path>
            <ruleList>
                <fileExists>
                    <negate>1</negate>
                    <path>~${username}</path>
                </fileExists>
            </ruleList>
        </createDirectory>
        <touchFile>
            <path>~${username}/.bashrc</path>
            <ruleList>
                <fileExists>
                    <negate>1</negate>
                    <path>~${username}/.bashrc</path>
                </fileExists>
            </ruleList>
        </touchFile>        
        <changeOwnerAndGroup>
            <files>~${username}/*</files>
            <group>${username}_group</group>
            <owner>${username}</owner>
            <ruleList>
                <fileExists>
                    <path>~${username}</path>
                </fileExists>
            </ruleList>
        </changeOwnerAndGroup>
        <exit>
            <exitCode>1</exitCode>
            <ruleList>
                <userTest>
                    <logic>not_exists</logic>
                    <username>${username}</username>
                </userTest>
            </ruleList>
        </exit>
    </readyToInstallActionList>
                   
    <folderList>         
        <folder>
            <name>files</name>
            <destination>${installdir}</destination>
            <distributionFileList>
                <distributionDirectory> 
                    <allowWildcards>1</allowWildcards>                       
                    <origin>${build_project_directory}/sequoiadb/*</origin>
                    <excludeFiles>*/compatible.sh;*/version.conf</excludeFiles>
                </distributionDirectory>               
            </distributionFileList>
        </folder>
    </folderList> 
    
    <postInstallationActionList>
        <createSymLink>
            <linkName>${installdir}/tools/server/php/libxml2/lib/libxml2.so</linkName>
            <target>${installdir}/tools/server/php/libxml2/lib/libxml2.so.2.9.0</target>
        </createSymLink>
        <runProgram>
            <program>chown</program>
            <programArguments>-h ${username}:${username}_group ${installdir}/tools/server/php/libxml2/lib/libxml2.so</programArguments>            
        </runProgram>
        
        <createSymLink>
            <linkName>${installdir}/tools/server/php/libxml2/lib/libxml2.so.2</linkName>
            <target>${installdir}/tools/server/php/libxml2/lib/libxml2.so.2.9.0</target>
        </createSymLink>
        <runProgram>
            <program>chown</program>
            <programArguments>-h ${username}:${username}_group ${installdir}/tools/server/php/libxml2/lib/libxml2.so.2</programArguments>            
        </runProgram>
        
        <createSymLink>
            <linkName>${installdir}/tools/server/php/libxml2/lib/libz.so</linkName>
            <target>${installdir}/tools/server/php/libxml2/lib/libz.so.1.2.5</target>
        </createSymLink>
        <runProgram>
            <program>chown</program>
            <programArguments>-h ${username}:${username}_group ${installdir}/tools/server/php/libxml2/lib/libz.so</programArguments>            
        </runProgram>
        
        <createSymLink>
            <linkName>${installdir}/tools/server/php/libxml2/lib/libz.so.1</linkName>
            <target>${installdir}/tools/server/php/libxml2/lib/libz.so.1.2.5</target>
        </createSymLink>
        <runProgram>
            <program>chown</program>
            <programArguments>-h ${username}:${username}_group ${installdir}/tools/server/php/libxml2/lib/libz.so.1</programArguments>            
        </runProgram>
        
        <changeOwnerAndGroup>
            <files>${installdir}/tools/server/php/libxml2/lib/*</files>
            <group>${username}_group</group>
            <owner>${username}</owner>
        </changeOwnerAndGroup>
        <deleteFile>
            <path>/etc/default/sequoiadb</path>
            <ruleList>
                <fileExists>
                    <path>/etc/default/sequoiadb</path>
                </fileExists>
            </ruleList>
        </deleteFile>
        <propertiesFileSet>
            <file>/etc/default/sequoiadb</file>
            <key>NAME</key>
            <value>sdbcm</value>
        </propertiesFileSet>
        <propertiesFileSet>
            <file>/etc/default/sequoiadb</file>
            <key>SDBADMIN_USER</key>
            <value>${username}</value>
        </propertiesFileSet>
        <propertiesFileSet>
            <file>/etc/default/sequoiadb</file>
            <key>INSTALL_DIR</key>
            <value>${installdir}</value>
        </propertiesFileSet>
        <changePermissions files="${installdir}/bin/{*,*/*}" permissions="0755">
            <customErrorMessage>${msg(Install.ErrorMsg.ChangeInsallerPathPermissions.error)}</customErrorMessage>
        </changePermissions>
        <changePermissions>
            <files>${installdir}/tools/server/php/bin/*</files>
            <permissions>0755</permissions>
        </changePermissions>
        <changePermissions>
            <files>${installdir}/www/shell/*</files>
            <permissions>0755</permissions>
        </changePermissions>
        <changePermissions>
            <files>${installdir}/install_om.sh</files>
            <permissions>0755</permissions>
        </changePermissions>
        <changePermissions>
            <files>${installdir}/conf/script/{*.sh,*/*.sh}</files>
            <permissions>0755</permissions>
        </changePermissions> 
        <dos2unix>
            <files>${installdir}/tools/server/php/bin/php</files>
        </dos2unix>
        <iniFileSet>
            <file>${installdir}/tools/server/php/lib/php.ini</file>
            <key>extension_dir</key>
            <section>PHP</section>
            <value>${installdir}/lib/phplib</value>
        </iniFileSet>
        <changePermissions>
            <files>${installdir}/java/jdk/bin/*</files>
            <permissions>0755</permissions>
        </changePermissions>
        <propertiesFileSet>
            <file>${installdir}/conf/sdbcm.conf</file>
            <key>defaultPort</key>
            <value>${port}</value>
        </propertiesFileSet>
        <addUnixService>
            <customErrorMessage>${msg(Install.ErrorMsg.CreateLinuxService.error)}</customErrorMessage>
            <description>SequoiaDB Cluster Manager</description>
            <name>sdbcm</name>
            <program>${installdir}/sequoiadb</program>                       
        </addUnixService>
        <propertiesFileSet>
            <file>${installdir}/conf/sdbcm.conf</file>
            <key>AutoStart</key>
            <value>false</value>
            <ruleList>
                <isTrue>
                    <negate>1</negate>
                    <value>${processAutoStart}</value>
                </isTrue>                
            </ruleList>
        </propertiesFileSet>       
        <changePermissions>
            <files>${installdir}/postgresql/*</files>
            <permissions>0755</permissions>
        </changePermissions>
        <changePermissions>
            <files>/tmp</files>
            <permissions>0777</permissions>
        </changePermissions>        
        <changeOwnerAndGroup>
            <files>${project.rollbackBackupDirectory};${installdir}/rollback</files>
            <group>${username}_group</group>
            <owner>${username}</owner>
        </changeOwnerAndGroup>        
        <changeOwnerAndGroup>
            <files>${installdir}/bin/sdbomtool</files>
            <group>root</group>
            <owner>root</owner>
        </changeOwnerAndGroup>
        <changePermissions>
            <files>${installdir}/bin/sdbomtool</files>
            <permissions>6755</permissions>
        </changePermissions>
        
        <runProgram>
            <program>service</program>
            <programArguments> sdbcm start</programArguments>            
        </runProgram>
        <runProgram>
            <customErrorMessage>${msg(Install.ErrorMsg.IntallationOM.error)}</customErrorMessage>
            <program>${installdir}/install_om.sh</program>
            <programArguments>${project.installationType} ${installdir} ${installer_pathname} ${port} ${svcname} ${dbpath} ${restname}</programArguments>           
            <ruleList>               
                <isTrue value="${SMS}" />
            </ruleList>
            <onErrorActionList>
                <consoleWrite text="&#xA;error message:&#xA;${program_stdout}&#xA;"/>
            </onErrorActionList>
        </runProgram>
        <changeOwnerAndGroup>
            <files>${installdir}/packet/${installerFilename}</files>
            <group>${username}_group</group>
            <owner>${username}</owner>
        </changeOwnerAndGroup>
        
        <runProgram>
            <program>echo</program>
            <programArguments>'' &gt;&gt; /etc/default/sequoiadb</programArguments>
        </runProgram>
        <runProgram>
            <program>echo</program>
            <programArguments> -n MD5= &gt;&gt; /etc/default/sequoiadb</programArguments>
        </runProgram>
        <runProgram>
            <program>/usr/bin/md5sum</program>
            <programArguments>${installer_pathname} | cut -c 1-32 &gt;&gt; /etc/default/sequoiadb</programArguments>
        </runProgram>
        <runProgram>
            <program>grep</program>
            <programArguments>-q "^export PATH=\$PATH:${installdir}\/bin$" ~sdbadmin/.bashrc</programArguments> 
            <abortOnError>0</abortOnError>   
            <showMessageOnError>0</showMessageOnError>       
        </runProgram>          
        <runProgram>
            <abortOnError>0</abortOnError>
            <program>echo</program>
            <programArguments>'export PATH=$PATH:${installdir}/bin' &gt;&gt; ~${username}/.bashrc</programArguments>
            <ruleList> 
                <compareText logic="does_not_equal" text="${program_exit_code}" value="0"/>                                                                  
            </ruleList>
        </runProgram>  
        <runProgram>
            <program>grep</program>
            <programArguments>-q "^export LD_LIBRARY_PATH=\$LD_LIBRARY_PATH:${installdir}\/lib$" ~sdbadmin/.bashrc</programArguments> 
            <abortOnError>0</abortOnError>   
            <showMessageOnError>0</showMessageOnError>       
        </runProgram>          
        <runProgram>
            <abortOnError>0</abortOnError>
            <program>echo</program>
            <programArguments>'export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:${installdir}/lib' &gt;&gt; ~${username}/.bashrc</programArguments>
            <ruleList> 
                <compareText logic="does_not_equal" text="${program_exit_code}" value="0"/>                                                                  
            </ruleList>
        </runProgram>            
        <createSymLink>
            <linkName>${installdir}/www/doc</linkName>
            <target>${installdir}/doc</target>
        </createSymLink> 
        <runProgram>
            <program>chown</program>
            <programArguments>-h ${username}:${username}_group ${installdir}/www/doc</programArguments>            
        </runProgram>     
    </postInstallationActionList>
    
    <installationAbortedActionList>
        <actionGroup> 
            <actionList>
                <removeUnixService>
                    <name>sdbcm</name>            
                </removeUnixService>
                <deleteFile>
                    <abortOnError>0</abortOnError>
                    <path>/etc/default/sequoiadb</path>
                    <ruleList>               
                        <fileExists path="/etc/default/sequoiadb"/>
                    </ruleList>
                </deleteFile> 
                <runProgram>
                    <customErrorMessage>${msg(Install.ErrorMsg.DeleteUser.error)}</customErrorMessage>
                    <program>userdel</program>
                    <programArguments>${username}</programArguments>
                    <ruleList>
                        <userTest>
                            <logic>exists</logic>
                            <password>${username}</password>
                            <username>${username}</username>
                        </userTest>                                          
                    </ruleList>
                </runProgram>
                <deleteGroup>
                    <groupname>${username}_group</groupname>
                    <ruleList>
                        <userTest>
                            <logic>exists</logic>
                            <username>${username}</username>
                        </userTest>                             
                    </ruleList>
                </deleteGroup>                    
            </actionList>            
            <ruleList>
                <isTrue value="${begin_normal_component}" />
            </ruleList>        
        </actionGroup>
                
    </installationAbortedActionList>
                               
</component>