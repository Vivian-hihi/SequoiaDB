<!--@param ${test.machine.deploy.path} , where test cases in the test machine-->
<!--@param ${test.machine.deploy.path} , where deploy file in the test machine-->
<!--@param ${install.path} , the sequoiadb install path -->
<!--@param ${antFileName} , the ant file name is -->
<!--@param ${test.reports.path} , where the report put in-->
<!--@param ${test-type} , what the test type-->
<project name="test-type" default="test-type">

   <target name="test-type" depends="">
   	  <!--property file="ci.properties" /-->
      <property environment="env" />
      <property file="${basedir}/ci.test.properties" />
      <switch value="${test-type}">
         <case value="basic">
         	
	          <echo message="begin to test js tests ..." />
	          <!--getRowNum propertyName="lineNum1" /-->
			
						<sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-basic-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/js_testcases/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
							<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/js_testcases/" />
							<param name="install.path" value="${install.path}" />
							<param name="excludes.dir.patterns" value="vote" />
							<!--parma name="parallel.num" value="${lineNum1}" /-->
							<param name="antTask.jar.path" value="${test.machine.deploy.path}/deploy/ant-sdbtasks" />
							<param name="ci.properties.path" value="${test.machine.software.path}/ci.test.properties" />
						</sdbtest>
				    <echo message="...test js tests are over ..." />
				    
         </case>
         <case value="ant">
         	
				    <echo message="... test ant-testcases ..." />
						<sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-ant-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/ant_testcases/reports" masterreports="${test.reports.path}" timeout="300m" antFileName="${antFileName}">
							<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/ant_testcases/" />
							<param name="install.path" value="${install.path}" />
							<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
						</sdbtest>
						<echo message="... test ant-testcases is over ..." />
						
         </case>
         <case value="driver-python">
         	<echo message="...test python driver..."/>
         	  <sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-driver-python-test.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/drivers_testcases/python/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
	         	  	<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/drivers_testcases/python/build" />
	         	  	<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
	         	  	<param name="ci.properties.path" value="${test.machine.software.path}/ci.test.properties" />
	         	  	<param name="coord_port" value="50000" />
	         	  	<param name="data_port" value="21100" />
         	  </sdbtest>
         </case>
         <case value="driver-php" >
         	  <echo message="... test the php driver ..." />
         	  <sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-driver-php-test.xml" 
         	  	remotereports="${test.machine.deploy.path}/deploy/hlt/drivers_testcases/php/reports" 
         	  	masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
         	  	<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/php_testcases" />
         	  	<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
         	  	<param name="php-bin.dir" value="/opt/sequoiadb/tools/server/php/bin" />
         	  	<!--param name="phpunit.phar.dir" value="/opt/sequoiadb/tools/server/php/phpunit.phar" /-->
         	  </sdbtest>
         </case>
         <case value="driver-java">
         
				    <echo message="... test the java driver ..." />                                                                                   
						<sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-driver-java-test.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/drivers_testcases/java/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
							<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/drivers_testcases" />
							<param name="install.path" value="${install.path}" />
							<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
						</sdbtest>
						<echo message="... test java driver is over ..." />
						
         </case>
         <case value="driver-C">
         
				    <echo message="... test the C driver ..." />
				    <property name="testCcases" value="*-*sdbConnect_with_usr*:*sdbCreateCollection1_doubtful*:*sdbCreateUsr*:*sdbListReplicaGroups*:*sdbRemoveUsr*:*sdbResetSnapshot*:*sdbSplitCollection*" />     
						<sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-driver-C-test.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/drivers_testcases/C/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
							<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/drivers_testcases" />
							<param name="test_name" value="${testCcases}"  />
							<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
						</sdbtest>
						<echo message="... test C driver is over ..." />
						
         </case>
         <case value="driver-CPP">
         
				    <echo message="... test the CPP driver ..." />		
						<property name="testCPPcases" value="*-*create*:*drop*:*insert_with_iterator*:*rename*:*split*:*createCollection_with_Sharding_and_replSize*:*resetSnapshot*:*transactionBegin*:*transactionCommit*:*transactionRollback*:*getList_SDB_LIST_GROUPS*" />
						<sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-driver-CPP-test.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/drivers_testcases/CPP/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
							<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/drivers_testcases" />
							<param name="test_name" value="${testCPPcases}"  />
							<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
						</sdbtest>
				    <echo message="... test CPP driver is over ..." />
				    
         </case>
         <case value="sample">
				         
				    <echo message="... test the client sample test ..." />
						<sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-samples-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/samples_testcases/CPP/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
							<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/samples_testcases" />
							<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
						</sdbtest>
				    <echo message="... client sample test is over ..." />
    
         </case>
         <case value="tpcc">
            <echo message=" ...begin to test tpcc ..." />
	          <sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-tpcc-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/tpcc_testcases/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
				     	<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/sql_testcases/" />
							<param name="install.path" value="${install.path}" />
							<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
							<param name="antTask.jar.path" value="${test.machine.deploy.path}/deploy/ant-sdbtasks" />
						</sdbtest>
				    <echo message=" ... tpcc test over ..." />
				    
         </case>
         <case value="java-app">
         	  <echo message="" />
         	  <sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-java-app-test.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/java_app_testcases/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
         	     <param name="testcases.path" value="${test.machine.deploy.path}/deploy/hlt/java-app-test"/>
         	     <param name="install.path" value="${install.path}"/>
         	  </sdbtest>
         </case>
         <case value="unusual">
            <echo message=" ...begin to test unusual cases ..." />
	          <sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-unusual-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/unusual_testcases/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
				     	<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/unusual_testcases" />
							<param name="install.path" value="${install.path}" />
							<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
							<param name="antTask.jar.path" value="${test.machine.deploy.path}/deploy/ant-sdbtasks" />
						</sdbtest>
				    <echo message=" ... unusual testcases are over ..." />
				    
         </case>
         
         <case value="basic-tpcc">
	         <parallel failonany="true" >
				    	
					    <echo message=" ...begin to test tpcc ..." />
					    <sdbtest host="${test.machine.no1.basic}" testscript="${test.machine.deploy.path}/deploy/exec-tpcc-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/tpcc_testcases/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
								<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/sql_testcases/" />
								<param name="install.path" value="${install.path}" />
								<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
								<param name="antTask.jar.path" value="${test.machine.deploy.path}/deploy/ant-sdbtasks" />
							</sdbtest>
					    <echo message=" ... tpcc test over ..." />	
				    	
					    <echo message="begin to test js tests ..." />
							<sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-basic-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/js_testcases/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
								<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/js_testcases/" />
								<param name="install.path" value="${install.path}" />
								<param name="excludes.dir.patterns" value="vote" />
								<param name="antTask.jar.path" value="${test.machine.deploy.path}/deploy/ant-sdbtasks" />
							</sdbtest>
					    <echo message="...test js tests are over ..." />	
	    	
	    		 </parallel>
         </case>
         <default>
            <parallel failonany="true" >
				    	
					    <echo message=" ...begin to test tpcc ..." />
					    <sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-tpcc-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/tpcc_testcases/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
								<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/sql_testcases/" />
								<param name="install.path" value="${install.path}" />
								<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
								<param name="antTask.jar.path" value="${test.machine.deploy.path}/deploy/ant-sdbtasks" />
							</sdbtest>
					    <echo message=" ... tpcc test over ..." />	
				    	
					    <echo message="begin to test js tests ..." />
							<sdbtest host="${test.machine.no2.basic}" testscript="${test.machine.deploy.path}/deploy/exec-basic-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/js_testcases/reports" masterreports="${test.reports.path}" timeout="250m" antFileName="${antFileName}">
								<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/js_testcases/" />
								<param name="install.path" value="${install.path}" />
								<param name="excludes.dir.patterns" value="vote" />
								<param name="antTask.jar.path" value="${test.machine.deploy.path}/deploy/ant-sdbtasks" />
							</sdbtest>
					    <echo message="...test js tests are over ..." />	
	    	
	    		 </parallel>
         </default>
      </switch>
   </target>


</project>