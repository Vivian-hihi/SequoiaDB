<!--
	@Description:
		Dectecting whether the package is the lastest and up to date
	@Parameters:
		${DEPLOY_WILDCARD} from Jenkins test intrgration framework
		${TEST_SCENE} from Jenkins test intrgration framework
		${TEST_CHOICE} from Jenkins test intrgration framework
		${WORKSPACE} from Jenkins test intrgration framework
		${OS_NAME} from Jenkins test intrgration framework
		${SCRIPT_DIR} from Jenkins test intrgration framework
	@Invocation:
		NULL
-->

<project default="1.Check-Version">
	<hostinfo prefix="local" />
	<property environment="env" />
	<property name="build_dir" value="${WORKSPACE}/release" />
 	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
		<classpath>
			<pathelement location="${SCRIPT_DIR}/exec-tools/ant-sdbtasks.jar" />
		</classpath>
	</taskdef>

	<target name="1.Check-Version" depends="">
		<echo level="info" message="Step1 : Delete the file &lt;${build_dir}/build.version.local&gt;." />
		<delete file="${build_dir}/build.version.local" failonerror="false" />
		<echo level="info" message="Step2 : Checking the file &lt;${build_dir}/build.version&gt; exists and if its true,copy the file &lt;${build_dir}/build.version&gt; to the file &lt;${build_dir}/build.version&gt;,and change parameters &lt;BUILD.NUMBER&gt; to &lt;BUILD.NUMBER.LOCAL&gt;,parameters &lt;BUILD.INSTALL.FILENAME&gt; to &lt;BUILD.INSTALL.FILENAME.LOCAL&gt;,parameters &lt;BUILD.DRIVER.FILENAME&gt; to &lt;BUILD.DRIVER.FILENAME&gt; in file &lt;${build_dir}/build.version.local&gt;." />
		<available property="build_version_exist" file="${build_dir}/build.version" />
		<if>
			<equals arg1="${build_version_exist}" arg2="true" />
			<then>
				<echo message="@ The file &lt;${build_dir}/build.version&gt; is exist." />
				<copy file="${build_dir}/build.version" tofile="${build_dir}/build.version.local" failonerror="false" />
				<property file="${build_dir}/build.version.local" />
				<replace file="${build_dir}/build.version.local" token="BUILD.NUMBER" value="BUILD.NUMBER.LOCAL" />
				<replace file="${build_dir}/build.version.local" token="BUILD.INSTALL.FILENAME" value="BUILD.INSTALL.FILENAME.LOCAL" />
				<replace file="${build_dir}/build.version.local" token="BUILD.DRIVER.FILENAME" value="BUILD.DRIVER.FILENAME.LOCAL" />
			</then>
			<else>
				<echo message="@ The file &lt;${build_dir}/build.version&gt; is not exist." />
				<property name="BUILD.NUMBER.LOCAL" value="-1" />
			</else>
		</if>
		<echo level="info" message="Step3 : Delete the file &lt;${build_dir}/build.version&gt;." />
		<delete file="${build_dir}/build.version" failonerror="false" />
		<mkdir dir="${build_dir}" />
		<echo level="info" message="Step4 : Rebuild the file &lt;${SCRIPT_DIR}/ci.test.properties&gt;." />
		<delete file="${SCRIPT_DIR}/ci.test.properties" failonerror="false" />
		<copy file="${SCRIPT_DIR}/ci-properies-files/ci.test.properties.${OS_NAME}" tofile="${SCRIPT_DIR}/ci.test.properties" failonerror="false" />
		<property file="${SCRIPT_DIR}/ci.test.properties" />
		<echo level="info" message="Step5 : Copy the file &lt;${copy_tar}/build.version&gt; from &lt;${deploy_tar_hostname}&gt;,command:staf &lt;${deploy_tar_hostname}&gt; FS COPY FILE &lt;${copy_tar}/build.version&gt; TODIRECTORY &lt;${build_dir}&gt; TOMACHINE &lt;${jenkins_master}&gt;." />
		<stafTools workType="copy" workHost="${deploy_tar_hostname}" fileName="${copy_tar}/build.version" saveDir="${build_dir}" toHost="${jenkins_master}" failonerror="true"/>
    	<property file="${build_dir}/build.version" />
    	<property file="${build_dir}/build.version.local" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The old SequoiaDB version is ${BUILD.NUMBER.LOCAL} and the new SequoiaDB version is ${BUILD.NUMBER}."/>
		<echo message="**************************************************************************************************************************************************************" />
		<if>
			<not>
				<equals arg1="${BUILD.NUMBER}" arg2="${BUILD.NUMBER.LOCAL}" />
			</not>
			<then>
				<available property="driver_exist" file="${build_dir}/driver" type="dir" />
				<if>
					<equals arg1="${driver_exist}" arg2="true" />
					<then>
						<echo message="@ The folder &lt;${build_dir}/driver&gt; is exist." />
					</then>
				</if>
			</then>
			<else>
				<echo message="@ The folder &lt;${build_dir}/driver&gt; is not exist." />
				<antcall target="3.Copy-Software-Package" inheritAll="true" />
			</else>
		</if>
	</target>

	<target name="2.Clean-Last-Software" depends="">
		<echo level="info" message="Step1 : Rebuild the folder &lt;${build_dir}&gt;." />
		<delete dir="${build_dir}" failonerror="false" />
		<mkdir dir="${build_dir}" />
	</target>

	<target name="3.Copy-Software-Package" depends="2.Clean-Last-Software">
		<property file="${SCRIPT_DIR}/ci.test.properties" />
		<echo level="info" message="Step1 : Copy the files &lt;${copy_tar}/build.version&gt;,&lt;${copy_tar}/${BUILD.INSTALL.FILENAME}.${BUILD.NUMBER}&gt;,&lt;${copy_tar}/${BUILD.DRIVER.FILENAME}.${BUILD.NUMBER}&gt; from ${deploy_tar_hostname}." />
		<stafTools workType="copy" workHost="${deploy_tar_hostname}" fileName="${copy_tar}/build.version" saveDir="${build_dir}" toHost="${jenkins_master}" failonerror="true"/>
		<stafTools workType="copy" workHost="${deploy_tar_hostname}" fileName="${copy_tar}/${BUILD.INSTALL.FILENAME}.${BUILD.NUMBER}" saveDir="${build_dir}" toHost="${jenkins_master}" failonerror="true"/>
		<stafTools workType="copy" workHost="${deploy_tar_hostname}" fileName="${copy_tar}/${BUILD.DRIVER.FILENAME}.${BUILD.NUMBER}" saveDir="${build_dir}" toHost="${jenkins_master}" failonerror="true"/>
		<echo level="info" message="Step2 : Change the files' name &lt;${build_dir}/${BUILD.INSTALL.FILENAME}.${BUILD.NUMBER}&gt; to &lt;${build_dir}/${BUILD.INSTALL.FILENAME}&gt;,&lt;${build_dir}/${BUILD.DRIVER.FILENAME}.${BUILD.NUMBER}&gt; to &lt;${build_dir}/${BUILD.DRIVER.FILENAME}&gt;." />
		<move file="${build_dir}/${BUILD.INSTALL.FILENAME}.${BUILD.NUMBER}" tofile="${build_dir}/${BUILD.INSTALL.FILENAME}" />
		<move file="${build_dir}/${BUILD.DRIVER.FILENAME}.${BUILD.NUMBER}" tofile="${build_dir}/${BUILD.DRIVER.FILENAME}" />
		<echo level="info" message="Step3 : Untar the file &lt;${build_dir}/${BUILD.DRIVER.FILENAME}&gt; to folder &lt;${build_dir}&gt;." />
		<untar src="${build_dir}/${BUILD.DRIVER.FILENAME}" dest="${build_dir}" compression="gzip" />
	</target>
</project>
