<!--@param ${install.package.fullname}: The path where place software package.-->
<!--@param ${deploy.host.name} :  The host name for deploy test scripts and install software-->
<!--@param ${coord.service.port}:  coord's service port-->
<!--@param ${is.standalone.mode}:  the flag whether start with standalone mode-->
<!--@param ${is.coord.master}: flag this node is coord master or no-->
<!--@param ${catalog.addrs}: The string include catalog addr and port-->

<project name="install-software" default="install-software">
	<property file="ci.test.properties" />
	<property name="is.standalone.mode" value="false" />
	<property name="catalog.addrs" value="" />
	<property name="is.coord.master" value="true" />
	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
		<classpath>
			<fileset dir="${WORKSPACE}/deploy/ant-sdbtasks/ant-sdbtasks.jar" />
		</classpath>
	</taskdef>
	
	<target name="uninstall-software" depends="uninstall-software">
	    <stafTools workHost="${deploy.host.name}" workType="shell" workDir="${test.machine.software.path}" common="ant -l ${test.machine.software.path}/install-basic-in-host.log -f ${test.machine.software.path}/install-basic-in-host.xml clean-install -Dtest.basedir=${test.machine.software.path}" />
	    <stafTools workHost="${deploy.host.name}" worktype="get" fileName="${test.machine.software.path}/install-basic-in-host.log" />
	    <stafTools workHost="${deploy.host.name}" worktype="delete" fileName="${test.machine.software.path}" />
	    <stafTools workHost="${deploy.host.name}" worktype="create" filename="${test.machine.software.path}" />
	</target>

	<target name="install-software" depends="uninstall-software">		
		<stafTools workType="copy" fileName="${install.package.fullname}" saveDir="${test.machine.software.path}" toHost="${deploy.host.name}" />
		<stafTools workType="copy" fileName="${basedir}/ci.test.properties" saveDir="${test.machine.software.path}" toHost="${deploy.host.name}" />
		<stafTools workType="copy" fileName="${basedir}/install-basic-in-host.xml" saveDir="${test.machine.software.path}" toHost="${deploy.host.name}" />
		<basename property="install.package.filename" file="${install.package.fullname}"/>
		<stafTools workHost="${deploy.host.name}" workType="shell" workDir="${test.machine.software.path}" waitTime="200m" common="ant -l ${test.machine.software.path}/install-basic-in-host.log -f ${test.machine.software.path}/install-basic-in-host.xml -Dtest.basedir=${test.machine.software.path} -Dinstall.package.filename=${install.package.filename} -Dis.standalone.mode=${is.standalone.mode} -Dis.coord.master=${is.coord.master} -Dcatalog.addrs=${catalog.addrs}" />
		<stafTools workType="get" workHost="${deploy.host.name}" fileName="${test.machine.software.path}/install-basic-in-host.log" />
	</target>
</project>



