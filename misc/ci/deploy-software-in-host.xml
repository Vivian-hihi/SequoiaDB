<!--@param ${deploy.host.name} :  The host name for deploy test scripts and install software-->

<!--@param ${install.package.fullname}: The path where place software package.-->
<!--@param ${deploy.host.name}: The machine deploy and test cases. -->
<!--@param ${is.standalone.mode}:  the flag whether start with standalone mode-->
<!--@param ${is.coord.master}: flag this node is coord master or no-->
<!--@param ${catalog.addrs}: The string include catalog addr and port-->

<!-- hostname:jenkins.master.ip -->
<!-- depends:deploy-test-all.xml,${deploy.case.fullname} -->
<!-- call:install-basic-in-host.xml -->

<project name="Install-Software" default="Install-Software">
	<property file="ci.test.properties" />
	<property file="${release.path}/build.version" />
	<target name="Uninstall-Software" depends="">
		<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="ls -d ${test.machine.software.path}" trust="true" resultproperty="ret.code" failonerror="false" />
		<if>
			<not>
				<equals arg1="${ret.code}" arg2="0" />
			</not>
			<then>
				<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="mkdir ${test.machine.software.path}" trust="true" failonerror="true" />
			</then>
		</if>
		<scp file="${basedir}/ci.test.properties" todir="${remote.user}:${remote.password}@${deploy.host.name}:${test.machine.software.path}/ci.test.properties" trust="true" failonerror="true" />
		<scp file="${basedir}/install-basic-in-host.xml" todir="${remote.user}:${remote.password}@${deploy.host.name}:${test.machine.software.path}/install-basic-in-host.xml" trust="true" failonerror="true" />
		<scp file="${basedir}/ant-sdbtask/ant-sdbtasks.jar" todir="${remote.user}:${remote.password}@${deploy.host.name}:${test.machine.software.path}/ant-sdbtasks.jar" trust="true" failonerror="true" />
		<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="ant -l ${test.machine.software.path}/clean-install-basic-in-host.log -f ${test.machine.software.path}/install-basic-in-host.xml clean-install -Dtest.basedir=${test.machine.software.path}" trust="true" failonerror="false" />
		<echo message="###############################################################################################################################" />
		<echo message="hostname=${deploy.host.name}:Clean-install" />
		<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="cat ${test.machine.software.path}/clean-install-basic-in-host.log" trust="true" failonerror="true" />
		<echo message="###############################################################################################################################" />
		<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="rm -rf ${test.machine.software.path}" trust="true" failonerror="false" />
		<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="mkdir ${test.machine.software.path}" trust="true" failonerror="true" />
	</target>

	<target name="Install-Software" depends="Uninstall-Software">
		<scp file="${install.package.fullname}" todir="${remote.user}:${remote.password}@${deploy.host.name}:${test.machine.software.path}/${BUILD.INSTALL.FILENAME}" trust="true" failonerror="true" />
		<scp file="${basedir}/ci.test.properties" todir="${remote.user}:${remote.password}@${deploy.host.name}:${test.machine.software.path}/ci.test.properties" trust="true" failonerror="true" />
		<scp file="${basedir}/install-basic-in-host.xml" todir="${remote.user}:${remote.password}@${deploy.host.name}:${test.machine.software.path}/install-basic-in-host.xml" trust="true" failonerror="true" />
		<scp file="${basedir}/ant-sdbtask/ant-sdbtasks.jar" todir="${remote.user}:${remote.password}@${deploy.host.name}:${test.machine.software.path}/ant-sdbtasks.jar" trust="true" failonerror="true" />

		<basename property="install.package.filename" file="${install.package.fullname}"/>

		<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="ant -l ${test.machine.software.path}/install-basic-in-host.log -f ${test.machine.software.path}/install-basic-in-host.xml -Dtest.basedir=${test.machine.software.path} -Dinstall.package.filename=${install.package.filename} -Dis.standalone.mode=${is.standalone.mode} -Dis.coord.master=${is.coord.master} -Dcatalog.addrs=${catalog.addrs}" trust="true" failonerror="true" />
		<echo message="###############################################################################################################################" />
		<echo message="hostname=${deploy.host.name}:Install" />
		<echo message="BUILD.INSTALL.FILENAME = ${BUILD.INSTALL.FILENAME}" />
		<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="cat ${test.machine.software.path}/install-basic-in-host.log" trust="true" failonerror="true" />
		<echo message="###############################################################################################################################" />
		<scp file="${basedir}/deploy-test-result.xml" todir="${remote.user}:${remote.password}@${deploy.host.name}:${test.machine.software.path}/deploy-test-result.xml" trust="true" failonerror="true" />
	</target>
</project>
