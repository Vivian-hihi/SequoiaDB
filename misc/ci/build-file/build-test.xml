<!--
	@Description:
		Compile testcases and ant-sdbtasks.jar
	@Parameters:
		${DEPLOY_WILDCARD} from Jenkins test intrgration framework
		${TEST_SCENE} from Jenkins test intrgration framework
		${TEST_CHOICE} from Jenkins test intrgration framework
		${WORKSPACE} from Jenkins test intrgration framework
		${SCRIPT_DIR} from Jenkins test intrgration framework
	@Invocation:
		build.xml
		build-driver-test.xml
-->

<project default="7.Build-Testcases">
	<property file="${SCRIPT_DIR}/ci.test.properties" />
	<property name="deploy_dir" value="${WORKSPACE}/deploy" />
	<property name="testcases_dir" value="${WORKSPACE}/sequoiadb/testcases/hlt" />
	<property name="driver_testcases_dir" value="${WORKSPACE}/sequoiadb/driver/test" />
	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
		<classpath>
			<pathelement location="${SCRIPT_DIR}/exec-tools/ant-sdbtasks.jar" />
		</classpath>
	</taskdef>

	<target name="4.Clean-Last-Deploy" depends="">
		<echo level="info" message="Step1 : Rebuild the folder &lt;${deploy_dir}&gt;." />
		<delete dir="${deploy_dir}" failonerror="false" />
	</target>

	<target name="5.Build-Sdbtasks-Jar" depends="4.Clean-Last-Deploy" >
		<ant antfile="${SCRIPT_DIR}/ant-sdbtask/build.xml">
			<property name="WORKSPACE" value="${WORKSPACE}" />
			<property name="sdbtask_path" value="${SCRIPT_DIR}/ant-sdbtask" />
			<property name="deploy_dir" value="${deploy_dir}" />
		</ant>
	</target>

	<target name="6.Build-Driver-Testcases" depends="5.Build-Sdbtasks-Jar">
		<ant antfile="${SCRIPT_DIR}/build-file/build-driver-test.xml">
			<property name="SCRIPT_DIR" value="${SCRIPT_DIR}" />
			<property name="testcases_dir" value="${driver_testcases_dir}" />
			<property name="deploy_dir" value="${deploy_dir}" />
			<property name="driver_dir" value="${WORKSPACE}/release/driver" />
		</ant>
	</target>

	<target name="7.Build-Testcases" depends="6.Build-Driver-Testcases">
		<echo level="info" message="Step1 : Begin to built folders &lt;${deploy_dir}/hlt/ant_testcases&gt;,&lt;${deploy_dir}/hlt/js_testcases&gt;,&lt;${deploy_dir}/hlt/basic_testcases&gt;." />
		<mkdir dir="${deploy_dir}/hlt/ant_testcases" />
		<mkdir dir="${deploy_dir}/hlt/js_testcases" />
		<mkdir dir="${deploy_dir}/hlt/basic_testcases" />
		<echo level="info" message="Step2 : Copy the folder from &lt;${testcases_dir}/ant_testcases&gt; to folder &lt;${deploy_dir}/hlt/ant_testcases&gt;." />
		<copy todir="${deploy_dir}/hlt/ant_testcases">
			<fileset dir="${testcases_dir}/ant_testcases" includes="**/*" />
		</copy>
		<echo level="info" message="Step3 : Copy the folder from &lt;${testcases_dir}/js_testcases&gt; to folder &lt;${deploy_dir}/hlt/js_testcases&gt;." />
		<copy todir="${deploy_dir}/hlt/js_testcases">
			<fileset dir="${testcases_dir}/js_testcases" includes="**/*" />
		</copy>
		<echo level="info" message="Step4 : Copy the folder from &lt;${testcases_dir}/basic_testcases&gt; to folder &lt;${deploy_dir}/hlt/basic_testcases&gt;." />
		<copy todir="${deploy_dir}/hlt/basic_testcases">
			<fileset dir="${testcases_dir}/basic_testcases" includes="**/*" />
		</copy>
		<echo level="info" message="Step5 : Copy the file &lt;${SCRIPT_DIR}/ci.test.properties&gt; to folder &lt;${deploy_dir}&gt;." />
		<copy file="${SCRIPT_DIR}/ci.test.properties" todir="${deploy_dir}" />
		<echo level="info" message="Step6 : Copy the exec scripts from &lt;${SCRIPT_DIR}/exec-testcases&gt; to folder &lt;${deploy_dir}&gt;." />
		<copy todir="${deploy_dir}">
			<fileset dir="${SCRIPT_DIR}/exec-testcases" includes="exec*.xml" />
		</copy>
	</target>
</project>
