<project default="build_offline_doc">
	<property file="${CODE_DIR}/misc/ci/ci.build.properties" />
	<echo message="${CODE_DIR}/misc/ci/ci.build.properties" />
	<target name="clean" depends="">
		<delete dir="${root_dir}/api" failonerror="false" />
		<delete dir="${root_dir}/out" failonerror="false" />
		<delete file="${root_dir}/${offline_doc_name}" failonerror="false" />
		
		<mkdir dir="${root_dir}/api" />
	</target>

	<target name="gen_api_doc" depends="clean">
		<foreach target="test-one-case" param="test.case.fullname">
			<fileset dir="${root_dir}/conf" includes="*.conf" excludes="" />
		</foreach>
	</target>

	<target name="test-one-case" depends="">
		<property name="sdb.cmd.argument" value=" -g ${test.case.fullname}" />
		<property name="command" value="doxygen${sdb.cmd.argument}" />
		<echo message="Command:${command}" />
		<exec executable="doxygen" dir="" timeout="60000" outputproperty="screen.output" resultproperty="ret.code" failonerror="false">
			<arg line="${sdb.cmd.argument}" />
		</exec>
		<echo message="${screen.output}" />
	</target>

	<target name="deploy_api_images" depends="gen_api_doc">
		<!-- <var name="op" value="*" />
		<math result="edition" operand1="${project.version}" operation="${op}" operand2="100" datatype="int" />
		<echo message="The edition is ${edition}" /> -->

		<stafTools worktype="delete" workHost="${target_deploy_api_ip}" fileName="${api_dir}/${edition}/api" failonerror="false" />
		<stafTools workType="copy directory" workHost="LOCAL" fileName="${root_dir}/api" saveDir="${api_dir}/${edition}" toHost="${target_deploy_api_ip}" failonerror="true"/>
		<stafTools workType="shell" workHost="${target_deploy_api_ip}" workDir="${api_dir}/${edition}" common="chown -R sequoiadb:sequoiadb api" failonerror="true"/>

		<stafTools worktype="delete" workHost="${target_deploy_api_ip}" fileName="${images_dir}/${edition}/images" failonerror="false" />
		<stafTools workType="copy directory" workHost="LOCAL" fileName="${root_dir}/images" saveDir="${images_dir}/${edition}" toHost="${target_deploy_api_ip}" failonerror="true"/>
		<stafTools workType="shell" workHost="${target_deploy_api_ip}" workDir="${images_dir}/${edition}" common="chown -R sequoiadb:sequoiadb images" failonerror="true"/>
	</target>

	<target name="build_offline_doc" depends="deploy_api_images">
		<echo message="#####################${offline_dir}/${offline_doc_name}####################" />
		<stafTools workType="copy" workHost="${target_offline_ip}" fileName="${offline_dir}/${offline_doc_name}" saveDir="${root_dir}" toHost="${target.deploy_tar_gz.ip}" failonerror="true"/>
		<untar src="${root_dir}/${offline_doc_name}" dest="${root_dir}/out" />
		<mkdir dir="${root_dir}/out/api" />
		<mkdir dir="${root_dir}/out/images" />
		<copydir src="${root_dir}/api" dest="${root_dir}/out/api" includes="**/*" />
		<copydir src="${root_dir}/images" dest="${root_dir}/out/images" includes="**/*" />
	</target>
</project>
