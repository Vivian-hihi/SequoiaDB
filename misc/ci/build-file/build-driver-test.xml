<!--
	@Description:
		Compile testcases 
	@Parameters:
		${SCRIPT_DIR} from build-test.xml
		${testcases_dir} from build-test.xml
		${deploy_dir} from build-test.xml
		${driver_dir} from build-test.xml
	@Invocation:
		NULL
-->

<project default="6.0 Compile-Driver-Testcases">
	<property file="${SCRIPT_DIR}/ci.test.properties" />
	
	<target name="6.0 Compile-Driver-Testcases" depends="">
        <if>
            <equals arg1="${isTrunk}" arg2="true" />
            <then>
                <antcall target="6.1 Clean-Driver-Testcases"        inheritAll="false" />
                <antcall target="6.2 Build-Java-Testcases"          inheritAll="false" />
                <antcall target="6.3 Build-Python-Testcases"        inheritAll="false" />
                <antcall target="6.4 Build-PHP-Testcases"           inheritAll="false" />
                <antcall target="6.5 Build-C-Testcases"             inheritAll="false" />
                <antcall target="6.6 Build-CPP-Testcases"           inheritAll="false" />
                <antcall target="6.7 Build-Lob-Testcases"           inheritAll="false" />
                <antcall target="6.8 Build-Mongoc-Testcases"        inheritAll="false" />
                <antcall target="6.9 Build-STORY-PHP-Testcases"     inheritAll="false" />
                <antcall target="6.10 Build-STORY-C-Testcases"      inheritAll="false" />
                <antcall target="6.11 Build-STORY-CPP-Testcases"    inheritAll="false" />
                <antcall target="6.12 Build-Story-Java-Testcases"   inheritAll="false" />                    
            </then>                                                                     
            <else>                                                                      
                <antcall target="6.1 Clean-Driver-Testcases"        inheritAll="false" />
                <antcall target="6.2 Build-Java-Testcases"          inheritAll="false" />
                <antcall target="6.3 Build-Python-Testcases"        inheritAll="false" />
                <antcall target="6.4 Build-PHP-Testcases"           inheritAll="false" />
                <antcall target="6.5 Build-C-Testcases"             inheritAll="false" />
                <antcall target="6.6 Build-CPP-Testcases"           inheritAll="false" />
                <antcall target="6.7 Build-Lob-Testcases"           inheritAll="false" />
                <antcall target="6.8 Build-Mongoc-Testcases"        inheritAll="false" />   
            </else>                                                                     
        </if>     
	    
	</target>   
	
	<target name="6.1 Clean-Driver-Testcases" depends="">
		<echo level="info" message="Step1 : Rebuild the folders &lt;${testcases_dir}/C/build_test&gt;,&lt;${testcases_dir}/CPP/build_test&gt;,&lt;${testcases_dir}/mongoc/build_test&gt;." />
		<delete dir="${testcases_dir}/C/build_test"  failonerror="false" />
		<delete dir="${testcases_dir}/C/staticlib/build_test"  failonerror="false" />
		<delete dir="${testcases_dir}/CPP/build_test"  failonerror="false" />
		<delete dir="${testcases_dir}/CPP/staticlib/build_test"  failonerror="false" />
		<delete dir="${lob_testcases_dir}/build_test"  failonerror="false" />
		<delete dir="${testcases_dir}/mongoc/build_test" failonerror="false" />
		<mkdir dir="${testcases_dir}/C/build_test" />
		<mkdir dir="${testcases_dir}/C/staticlib/build_test" />
		<mkdir dir="${testcases_dir}/CPP/build_test" />
		<mkdir dir="${testcases_dir}/CPP/staticlib/build_test" />
		<mkdir dir="${lob_testcases_dir}/build_test"/>
		<mkdir dir="${testcases_dir}/mongoc/build_test" />
		<echo level="info" message="Step2 : Rebuild the folders &lt;${deploy_dir}/hlt/drivers_testcases&gt;." />
		<delete dir="${deploy_dir}/hlt/drivers_testcases" failonerror="false" />
		<delete dir="${deploy_dir}/hlt/lob_testcases" failonerror="false" />
		<mkdir dir="${deploy_dir}/hlt/drivers_testcases/C/build" />
		<mkdir dir="${deploy_dir}/hlt/drivers_testcases/C/lib" />
		<mkdir dir="${deploy_dir}/hlt/drivers_testcases/CPP/build" />
		<mkdir dir="${deploy_dir}/hlt/drivers_testcases/CPP/lib" />
		<mkdir dir="${deploy_dir}/hlt/drivers_testcases/python" />
		<mkdir dir="${deploy_dir}/hlt/drivers_testcases/java/build" />
		<mkdir dir="${deploy_dir}/hlt/drivers_testcases/java/lib" />
		<mkdir dir="${deploy_dir}/hlt/drivers_testcases/mongoc/build" />
		<mkdir dir="${deploy_dir}/hlt/drivers_testcases/mongoc/lib" />
		<mkdir dir="${deploy_dir}/hlt/lob_testcases" />
		<if>
            <equals arg1="${isTrunk}" arg2="true" />
            <then>
        		<mkdir dir="${deploy_dir}/hlt/drivers_testcases/story_java/build" />
        		<mkdir dir="${deploy_dir}/hlt/drivers_testcases/story_java/lib" />
        	</then>
        </if>		
	</target>

	<target name="6.2 Build-Java-Testcases" depends="">
		<tstamp>
			<format property="java_testcases_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<if>
			<equals arg1="${os.name}" arg2="Linux" />
			<then>
				<property name="jdk_name_os" value="jdk_linux" />
			</then>
			<else>
				<property name="jdk_name_os" value="jdk_win" />
			</else>
		</if>
		<if>
			<equals arg1="${os.arch}" arg2="ppc64" />
			<then>
				<property name="jdk_name" value="jdk_ppclinux64" />
			</then>
		</if>
		<if>
			<equals arg1="${os.arch}" arg2="amd64" />
			<then>
				<property name="jdk_name" value="${jdk_name_os}64" />
			</then>
			<else>
				<property name="jdk_name" value="${jdk_name_os}32" />
			</else>
		</if>
    	<echo level="info" message="Step1 : Copy the file &lt;${driver_dir}/java/sequoiadb.jar&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/java/lib/sequoiadb.jar&gt;." />
		<copy file="${driver_dir}/java/sequoiadb.jar" tofile="${deploy_dir}/hlt/drivers_testcases/java/lib/sequoiadb.jar" />
		<echo level="info" message="Step2 : Compile the java driver testcases." />
		<javac executable="${WORKSPACE}/sequoiadb/java/${jdk_name}/bin/javac" 
		       srcdir="${testcases_dir}/java" 
		       destdir="${deploy_dir}/hlt/drivers_testcases/java/build" 
		       fork="yes" 		       
		       includeAntRuntime="false" 
		       includeJavaRuntime="false" 
		       encoding="UTF-8"
		       debug="true"
		       debuglevel="lines,vars,source"
		       failonerror="true">
			<classpath>
				<pathelement location="${deploy_dir}/ant-sdbtasks/ant-sdbtasks.jar" />
				<pathelement location="${deploy_dir}/hlt/drivers_testcases/java/lib/sequoiadb.jar" />
			</classpath>
		</javac>
		<echo level="info" message="Step3 : Jar the &lt;java_test.jar&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/java/lib&gt;." />
		<jar file="${deploy_dir}/hlt/drivers_testcases/java/lib/java_test.jar">
			<manifest>
				<attribute name="Version" value="1.0" />
			</manifest>
			<fileset dir="${deploy_dir}/hlt/drivers_testcases/java/build" includes="**/*" />
		</jar>
		<tstamp>
			<format property="java_testcases_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${java_testcases_begintime}" endTime="${java_testcases_endtime}" output="java_testcases_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The machine which is compiled java driver testcases is &lt;${os.arch}&gt; architecture and &lt;${os.name}&gt; operating system,so use &lt;${jdk_name}&gt;." />
		<echo level="info" message="The java driver testcases compilation project began at &lt;${java_testcases_begintime}&gt;, end at &lt;${java_testcases_endtime}&gt;,total spending ${java_testcases_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
	</target>

	<target name="6.3 Build-Python-Testcases" depends="">
		<tstamp>
			<format property="python_testcases_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<echo level="info" message="Step1 : Copy the folder &lt;${testcases_dir}/python&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/python&gt;." />
		<copy todir="${deploy_dir}/hlt/drivers_testcases/python">
			<fileset dir="${testcases_dir}/python" includes="**/*" />
		</copy>
		<tstamp>
			<format property="python_testcases_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${python_testcases_begintime}" endTime="${python_testcases_endtime}" output="python_testcases_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The python driver testcases compilation project began at &lt;${python_testcases_begintime}&gt;, end at &lt;${python_testcases_endtime}&gt;,total spending ${python_testcases_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
	</target>

	<target name="6.4 Build-PHP-Testcases" depends="">
		<tstamp>
			<format property="php_testcases_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<echo level="info" message="Step1 : Copy the folder &lt;${testcases_dir}/php&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/php&gt;." />
		<copy todir="${deploy_dir}/hlt/drivers_testcases/php">
			<fileset dir="${testcases_dir}/php" includes="**/*" />
		</copy>
		<tstamp>
			<format property="php_testcases_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${php_testcases_begintime}" endTime="${php_testcases_endtime}" output="php_testcases_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The php driver testcases compilation project began at &lt;${php_testcases_begintime}&gt;, end at &lt;${php_testcases_endtime}&gt;,total spending ${php_testcases_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
	</target>	

	<target name="6.5 Build-C-Testcases" depends="">
		<tstamp>
			<format property="c_testcases_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<echo level="info" message="Step1 : Rebuild folder &lt;${WORKSPACE}/sequoiadb/client/lib&gt;,copy folder &lt;${driver_dir}/lib&gt; to &lt;${WORKSPACE}/sequoiadb/client/lib&gt;." />
		<delete dir="${WORKSPACE}/sequoiadb/client/lib" failonerror="false"/>
		<mkdir dir="${WORKSPACE}/sequoiadb/client/lib" />
		<copy todir="${WORKSPACE}/sequoiadb/client/lib">
			<fileset dir="${driver_dir}/lib" includes="*" />
		</copy>
		<echo level="info" message="Step2 : Rebuild folder &lt;${WORKSPACE}/sequoiadb/client/include&gt;,copy folder &lt;${driver_dir}/include&gt; to &lt;${WORKSPACE}/sequoiadb/client/include&gt;." />
		<delete dir="${WORKSPACE}/sequoiadb/client/include" failonerror="false"/>
		<mkdir dir="${WORKSPACE}/sequoiadb/client/include" />
		<copy todir="${WORKSPACE}/sequoiadb/client/include">
			<fileset dir="${driver_dir}/include" includes="**/*" />
		</copy>
		<echo level="info" message="Step3 : Compile the C driver dynamic testcases,command: &lt;scons ${testcases_dir}/C lib_path=${driver_dir}/lib include_path=${driver_dir}/include&gt;." />
		<exec executable="scons" dir="${testcases_dir}/C" failonerror="true">
			<arg line=" --lib_path=${driver_dir}/lib --include_path=${driver_dir}/include" />
		</exec>
		<!--echo level="info" message="Step4 : Compile the C driver static testcases,command: &lt;scons ${testcases_dir}/C/staticlib ==dd lib_path=${driver_dir}/lib include_path=${driver_dir}/include&gt;." />
		<exec executable="scons" dir="${testcases_dir}/C/staticlib" failonerror="false">
			<arg line=" ==dd ==lib_path=${driver_dir}/lib ==include_path=${driver_dir}/include" />
		</exec-->
		<echo level="info" message="Step5 : Copy the C driver dynamic testcases from &lt;${testcases_dir}/C/build_test&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/C/build&gt;." />
		<copy todir="${deploy_dir}/hlt/drivers_testcases/C/build">
			<fileset dir="${testcases_dir}/C/build_test" includes="*" />
		</copy>
		<!--echo level="info" message="Step6 : Copy the C driver static testcases from &lt;${testcases_dir}/C/staticlib/build_test&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/C/build&gt;." />
		<copy todir="${deploy_dir}/hlt/drivers_testcases/C/build">
			<fileset dir="${testcases_dir}/C/staticlib/build_test" includes="*static" />
		</copy-->
		<tstamp>
			<format property="c_testcases_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${c_testcases_begintime}" endTime="${c_testcases_endtime}" output="c_testcases_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The c driver testcases compilation project began at &lt;${c_testcases_begintime}&gt;, end at &lt;${c_testcases_endtime}&gt;,total spending ${c_testcases_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
	</target>

	<target name="6.6 Build-CPP-Testcases" depends="">
		<tstamp>
			<format property="cpp_testcases_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<echo level="info" message="Step1 : Compile the CPP driver dynamic testcases,command: &lt;scons ${testcases_dir}/CPP lib_path=${driver_dir}/lib include_path=${driver_dir}/include&gt;." />
		<exec executable="scons" dir="${testcases_dir}/CPP" failonerror="true">
			<arg line=" --lib_path=${driver_dir}/lib --include_path=${driver_dir}/include" />
		</exec>
		<!--echo level="info" message="Step2 : Compile the CPP driver static testcases,command: &lt;scons ${testcases_dir}/CPP/staticlib ==dd lib_path=${driver_dir}/lib include_path=${driver_dir}/include&gt;." />
		<exec executable="scons" dir="${testcases_dir}/CPP/staticlib" failonerror="false">
			<arg line=" ==dd ==lib_path=${driver_dir}/lib ==include_path=${driver_dir}/include" />
		</exec-->
		<echo level="info" message="Step3 : Copy the CPP driver dynamic testcases from &lt;${testcases_dir}/CPP/build_test&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/CPP/build&gt;." />
		<copy todir="${deploy_dir}/hlt/drivers_testcases/CPP/build">
			<fileset dir="${testcases_dir}/CPP/build_test" includes="*" />
		</copy>
		<!--echo level="info" message="Step4 : Copy the CPP driver static testcases from &lt;${testcases_dir}/CPP/staticlib/build_test&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/CPP/build&gt;." />
		<copy todir="${deploy_dir}/hlt/drivers_testcases/CPP/build">
			<fileset dir="${testcases_dir}/CPP/staticlib/build_test" includes="*static" />
		</copy-->
		<tstamp>
			<format property="cpp_testcases_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${cpp_testcases_begintime}" endTime="${cpp_testcases_endtime}" output="cpp_testcases_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The cpp driver testcases compilation project began at &lt;${cpp_testcases_begintime}&gt;, end at &lt;${cpp_testcases_endtime}&gt;,total spending ${cpp_testcases_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
	</target>

	<target name="6.7 Build-Lob-Testcases" depends="">
		<tstamp>
			<format property="lob_testcases_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<echo level="info" message="Step1 : Compile the Lob testcases,command: &lt;scons ${lob_testcases_dir} lib_path=${driver_dir}/lib include_path=${driver_dir}/include&gt;." />
		<exec executable="scons" dir="${lob_testcases_dir}" failonerror="true">
			<arg line=" --lib_path=${driver_dir}/lib --include_path=${driver_dir}/include" />
		</exec>
		<echo level="info" message="Step2 : Copy the Lob testcases from &lt;${lob_testcases_dir}/build_test&gt; to &lt;${deploy_dir}/hlt/lob_testcases/build&gt;." />
		<copy todir="${deploy_dir}/hlt/lob_testcases/build">
			<fileset dir="${lob_testcases_dir}/build_test" includes="*" />
		</copy>
		<tstamp>
			<format property="lob_testcases_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${lob_testcases_begintime}" endTime="${lob_testcases_endtime}" output="lob_testcases_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The lob testcases compilation project began at &lt;${lob_testcases_begintime}&gt;, end at &lt;${lob_testcases_endtime}&gt;,total spending ${lob_testcases_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
	</target>

	<target name="6.8 Build-Mongoc-Testcases" depends="">
		<tstamp>
			<format property="mongoc_testcases_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<if>
			<equals arg1="${os.arch}" arg2="amd64" />
			<then>
				<echo level="info" message="Step1 : Compile the mongoc testcases,command: &lt;scons ${testcases_dir}/mongoc&gt;." />
				<exec executable="scons" dir="${testcases_dir}/mongoc" failonerror="false" />
				<echo level="info" message="Step2 : Copy the mongoc testcases from &lt;${testcases_dir}/mongoc/build_test&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/mongoc/build&gt;." />
				<copy todir="${deploy_dir}/hlt/drivers_testcases/mongoc/build">
					<fileset dir="${testcases_dir}/mongoc/build_test" includes="*" />
				</copy>
				<echo level="info" message="Step3 : Copy the mongoc lib from &lt;${testcases_dir}/mongoc/lib&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/mongoc/lib&gt;." />
				<copy todir="${deploy_dir}/hlt/drivers_testcases/mongoc/lib">
					<fileset dir="${testcases_dir}/mongoc/lib" includes="*" />
				</copy>
			</then>
		</if>
		<tstamp>
			<format property="mongoc_testcases_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${mongoc_testcases_begintime}" endTime="${mongoc_testcases_endtime}" output="mongoc_testcases_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The machine which is compiled mongoc testcases is &lt;${os.arch}&gt;." />
		<echo level="info" message="The mongoc testcases compilation project began at &lt;${mongoc_testcases_begintime}&gt;, end at &lt;${mongoc_testcases_endtime}&gt;,total spending ${mongoc_testcases_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
	</target>
	
	<target name="6.9 Build-STORY-PHP-Testcases" depends="">
		<tstamp>
			<format property="story_php_testcases_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<echo level="info" message="Step1 : Copy the folder &lt;${testcases_dir}/../../testcases/hlt/drivers_testcases/php/&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/story_php&gt;." />
		<copy todir="${deploy_dir}/hlt/drivers_testcases/story_php">
			<fileset dir="${testcases_dir}/../../testcases/hlt/drivers_testcases/php/" includes="**/*" />
		</copy>
		<tstamp>
			<format property="story_php_testcases_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${story_php_testcases_begintime}" endTime="${story_php_testcases_endtime}" output="story_php_testcases_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The php driver testcases compilation project began at &lt;${story_php_testcases_begintime}&gt;, end at &lt;${story_php_testcases_endtime}&gt;,total spending ${story_php_testcases_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
	</target>
	
	<target name="6.10 Build-STORY-C-Testcases" depends="">
		<tstamp>
			<format property="sc_testcases_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		
		<echo level="info" message="Step1 : Compile the C driver testcases,command: &lt;scons ${testcases_dir}/../../testcases/hlt/drivers_testcases/c lib_path=${driver_dir}/lib include_path=${driver_dir}/include&gt;." />
		<exec executable="scons" dir="${testcases_dir}/../../testcases/hlt/drivers_testcases/c" failonerror="true">
			<arg line=" --lib_path=${driver_dir}/lib --include_path=${driver_dir}/include" />
		</exec>

		<echo level="info" message="Step2 : Copy the C driver testcases from &lt;${testcases_dir}/../../testcases/hlt/drivers_testcases/c/build_test&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/story_C/build&gt;." />
		<copy todir="${deploy_dir}/hlt/drivers_testcases/story_C/build">
			<fileset dir="${testcases_dir}/../../testcases/hlt/drivers_testcases/c/build_test" includes="*" />
		</copy>
		
		<tstamp>
			<format property="sc_testcases_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${sc_testcases_begintime}" endTime="${sc_testcases_endtime}" output="sc_testcases_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The story c driver testcases compilation project began at &lt;${sc_testcases_begintime}&gt;, end at &lt;${sc_testcases_endtime}&gt;,total spending ${sc_testcases_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
	</target>

	<target name="6.11 Build-STORY-CPP-Testcases" depends="">
		<tstamp>
			<format property="scpp_testcases_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		
		<echo level="info" message="Step1 : Compile the CPP driver testcases,command: &lt;scons ${testcases_dir}/../../testcases/hlt/drivers_testcases/cpp lib_path=${driver_dir}/lib include_path=${driver_dir}/include&gt;." />
		<exec executable="scons" dir="${testcases_dir}/../../testcases/hlt/drivers_testcases/cpp" failonerror="true">
			<arg line=" --lib_path=${driver_dir}/lib --include_path=${driver_dir}/include" />
		</exec>

		<echo level="info" message="Step2 : Copy the CPP driver testcases from &lt;${testcases_dir}/../../testcases/hlt/drivers_testcases/cpp/build_test&gt; to &lt;${deploy_dir}/hlt/drivers_testcases/story_CPP/build&gt;." />
		<copy todir="${deploy_dir}/hlt/drivers_testcases/story_CPP/build">
			<fileset dir="${testcases_dir}/../../testcases/hlt/drivers_testcases/cpp/build_test" includes="*" />
		</copy>
		
		<tstamp>
			<format property="scpp_testcases_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${scpp_testcases_begintime}" endTime="${scpp_testcases_endtime}" output="scpp_testcases_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The story cpp driver testcases compilation project began at &lt;${scpp_testcases_begintime}&gt;, end at &lt;${scpp_testcases_endtime}&gt;,total spending ${scpp_testcases_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
	</target>	
	
	<target name="6.12 Build-Story-Java-Testcases" depends="">
		<tstamp>
			<format property="sjava_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<if>
			<equals arg1="${os.name}" arg2="Linux" />
			<then>
				<property name="jdk_name_os" value="jdk_linux" />
			</then>
			<else>
				<property name="jdk_name_os" value="jdk_win" />
			</else>
		</if>
		<if>
			<equals arg1="${os.arch}" arg2="ppc64" />
			<then>
				<property name="jdk_name" value="jdk_ppclinux64" />
			</then>
		</if>
		<if>
			<equals arg1="${os.arch}" arg2="amd64" />
			<then>
				<property name="jdk_name" value="${jdk_name_os}64" />
			</then>
			<else>
				<property name="jdk_name" value="${jdk_name_os}32" />
			</else>
		</if>
				
		<property name="sjava_src_path"    value="${testcases_dir}/../../testcases/hlt/drivers_testcases/java/" />
		<property name="sjava_deploy_path" value="${deploy_dir}/hlt/drivers_testcases/story_java" />
		
    	<echo level="info" message="1 : Copy ${driver_dir}/java/sequoiadb.jar to ${sjava_deploy_path}/lib/sequoiadb.jar." />
		<copy file="${driver_dir}/java/sequoiadb.jar"   todir="${sjava_deploy_path}/lib" />
		<copy file="${sjava_src_path}/testng.xml"       todir="${sjava_deploy_path}" />
		<copy todir="${sjava_deploy_path}/lib">
		   <fileset dir="${sjava_src_path}/lib">
		      <exclude name="sequoiadb.jar"/>
		   </fileset>   
		</copy>   
		
		<echo level="info" message="2 : Compile the java driver testcases." />
		<javac executable="${WORKSPACE}/sequoiadb/java/${jdk_name}/bin/javac" 
		       srcdir="${sjava_src_path}" 
		       destdir="${sjava_deploy_path}/build" 
		       encoding="UTF-8"
		       debug="true"
		       debuglevel="lines,vars,source"
		       failonerror="true">
			<classpath>
				<pathelement location="${sjava_deploy_path}/lib/sequoiadb.jar" />
            <pathelement location="${sjava_deploy_path}/lib/testng-6.9.11.jar"/>
            <pathelement location="${sjava_deploy_path}/lib/jcommander-1.49.jar"/>  
			</classpath>
		</javac>
		
		<echo level="info" message="3 : compress ${sjava_deploy_path}/build to ${sjava_deploy_path}/lib/story_java_test.jar." />
		<copy todir="${sjava_deploy_path}/build/com/sequoiadb/lob/testlobfile" > 
		   <fileset dir="${sjava_src_path}/com/sequoiadb/lob/testlobfile" /> 
		</copy>	
		<jar file="${sjava_deploy_path}/lib/story_java_test.jar">
			<manifest>
				<attribute name="Version" value="1.0" />
			</manifest>
			<fileset dir="${sjava_deploy_path}/build" includes="**/*" />
		</jar>
		
		<tstamp>
			<format property="sjava_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
		</tstamp>
		<sdbTime beginTime="${sjava_begintime}" endTime="${sjava_endtime}" output="sjava_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The machine which is compiled story java testcases is &lt;${os.arch}&gt; architecture and &lt;${os.name}&gt; operating system,so use &lt;${jdk_name}&gt;." />
		<echo level="info" message="The story java testcases compilation project began at &lt;${sjava_begintime}&gt;, end at &lt;${sjava_endtime}&gt;,total spending ${sjava_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
	</target>
		
</project>
