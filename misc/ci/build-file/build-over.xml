<!--@param ${WORKSPACE} : The workspace path-->
<!--@param ${release.path} :  The path where place softwore-->
<!--@param ${BUILD_NUMBER}:  The build number. this param pass by jenkins-->

<project name="copy_tar_build" default="copy_tar_build">
	<property file="${WORKSPACE}/sequoiadb/misc/ci/ci.build.properties" />	
 	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
		<classpath>
			<pathelement location="${WORKSPACE}/sequoiadb/misc/ci/exec-tools/ant-sdbtasks.jar" />
		</classpath>
	</taskdef> 

	<target name="copy_tar_build" depends="">
		<if>
			<equals arg1="${enterprise}" arg2="true" />
			<then>
				<echo message="the verion is enterprise" />
				<property name="version.name" value="-${enterprise.name}" />
				<echo message="${version.name}" />
			</then>
			<else>
				<echo message="the version is not enterprise" />
				<property name="version.name" value="" />
				<echo message="${version.name}" />
			</else>
		</if>
		<property name="software.package.name" value="${project.name}-${projects.version}-${os.and.platform}${version.name}-installer.run" />
		<echo message="software.package.name=${software.package.name}" />
		<property name="driver.package.name" value="${project.name}-driver-${projects.version}-${os.and.platform}.tar.gz" />
		<echo message="driver.package.name=${driver.package.name}" />
		<property name="document.package.name" value="${project.name}-document-${projects.version}-linux.tar.gz" />
		<echo message="document.package.name=${document.package.name}" />

		<echo message="Begin to copy the ${software.package.name} ${driver.package.name} ${document.package.name}..." />
		<copy file="${release.path}/${software.package.name}" tofile="${release.path}/${software.package.name}.${BUILD_NUMBER}" />
		<copy file="${release.path}/${driver.package.name}" tofile="${release.path}/${driver.package.name}.${BUILD_NUMBER}" />
		<if>
			<equals arg1="${CPU.version}" arg2="x86" />
			<then>
				<copy file="${release.path}/${document.package.name}" tofile="${release.path}/${document.package.name}.${BUILD_NUMBER}" />
				<stafTools workType="copy" workHost="LOCAL" fileName="${release.path}/${document.package.name}.${BUILD_NUMBER}" saveDir="${copy_tar}" toHost="${target.deploy_tar_gz.ip}" failonerror="true"/>
				<stafTools workType="copy" workHost="LOCAL" fileName="${release.path}/${document.package.name}" saveDir="${copy_tar}" toHost="${target.deploy_tar_gz.ip}" failonerror="true"/>
				<delete file="${release.path}/${document.package.name}.${BUILD_NUMBER}" failonerror="false" />
			</then>
		</if>

		<stafTools workType="copy" workHost="LOCAL" fileName="${release.path}/${software.package.name}.${BUILD_NUMBER}" saveDir="${copy_tar}" toHost="${target.deploy_tar_gz.ip}" failonerror="true"/>
		<stafTools workType="copy" workHost="LOCAL" fileName="${release.path}/${driver.package.name}.${BUILD_NUMBER}" saveDir="${copy_tar}" toHost="${target.deploy_tar_gz.ip}" failonerror="true"/>
		<echo message="delete the file ${copy_tar}/build.version" />
		<stafTools workType="delete" workHost="LOCAL" fileName="${copy_tar}/build.version" failonerror="false"/>

		<if>
			<equals arg1="${compile.debug}" arg2="false" />
			<then>
				<propertyfile file="${WORKSPACE}/sequoiadb/misc/ci/build.version" comment="true">
					<entry key="BUILD.NUMBER" value="${BUILD_NUMBER}" type="string" />
					<entry key="BUILD.INSTALL.FILENAME" value="${software.package.name}" type="string" />
					<entry key="BUILD.DRIVER.FILENAME" value="${driver.package.name}" type="string" />			
					<entry key="RELEASE.NUMBER" value="${BUILD_NUMBER}" type="string"/>			
				</propertyfile>
			</then>
			<else>
				<propertyfile file="${WORKSPACE}/sequoiadb/misc/ci/build.version" comment="true">
					<entry key="BUILD.NUMBER" value="${BUILD_NUMBER}" type="string" />
					<entry key="BUILD.INSTALL.FILENAME" value="${software.package.name}" type="string" />
					<entry key="BUILD.DRIVER.FILENAME" value="${driver.package.name}" type="string" />
				</propertyfile>
			</else>
		</if>
		<stafTools workType="copy" workHost="LOCAL" fileName="${WORKSPACE}/sequoiadb/misc/ci/build.version" saveDir="${copy_tar}" toHost="LOCAL" failonerror="true"/>
		<stafTools workType="shell" workHost="LOCAL" common="/usr/bin/find ${copy_tar} -mtime +7 -delete;" workDir="${copy_tar}" waitTime="30m" failonerror="true"/>

		<delete file="${release.path}/${software.package.name}.${BUILD_NUMBER}" />
		<delete file="${release.path}/${driver.package.name}.${BUILD_NUMBER}" />		
	</target>
</project>



