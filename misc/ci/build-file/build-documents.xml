<project default="load_doc">
	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
		<classpath>
			<fileset dir="${WORKSPACE}/misc/ci/exec-tools" includes="*.jar" />
		</classpath>
	</taskdef>

	<target name="clean" depends="">
		<delete dir="${WORKSPACE}/doc/SdbDoc_Cn" failonerror="false" />
		<delete dir="${WORKSPACE}/doc/SdbDoc_En" failonerror="false" />
		
		<mkdir dir="${WORKSPACE}/doc/SdbDoc_Cn" />
		<mkdir dir="${WORKSPACE}/doc/SdbDoc_En" />
		<copydir dest="${WORKSPACE}/doc/SdbDoc_Cn" src="${WORKSPACE}/doc/Cn" includes="**/*" />
	</target>

	<target name="compile_web_tools" depends="clean">
		<property name="base_dir" value="${WORKSPACE}/doc/tools/xml2sql" />
		<ant antfile="${base_dir}/build.xml">
			<property name="root_dir" value="${base_dir}/src/com/sequoiadb/xml2sql" />
			<property name="build_dir" value="${base_dir}/build" />
			<property name="lib_dir" value="${base_dir}/lib" />
			<property name="jar_name" value="${base_dir}/xml2sql.jar" />
		</ant>
	</target>

	<target name="gen_web_doc" depends="compile_web_tools">
		<foreach target="test-one-suite" param="test.suite.fullname" >
			<path>
				<dirset dir="${WORKSPACE}/doc/SdbDoc_Cn" />
			</path>
			<param name="includes.case.patterns" value="*.md" />
			<param name="excludes.case.patterns" value="" />
		</foreach>
		<copydir dest="${WORKSPACE}/doc/SdbDoc_En" src="${WORKSPACE}/doc/SdbDoc_Cn" includes="**/*" />
		<foreach target="change-one-suite" param="change.suite.fullname" >
			<path>
				<dirset dir="${WORKSPACE}/doc/SdbDoc_En" />
			</path>
			<param name="includes.case.patterns" value="*.html" />
			<param name="excludes.case.patterns" value="" />
		</foreach>
	</target>

	<target name="load_doc" depends="gen_web_doc">
		<java jar="/opt/xml2sql/xml2sql.jar" />
	</target>

	<target name="test-one-suite" depends="">
		<foreach target="test-one-case" param="test.case.fullname">
			<fileset dir="${test.suite.fullname}" includes="${includes.case.patterns}" excludes="${excludes.case.patterns}" />
		</foreach>
	</target>

	<target name="test-one-case" depends="">
		<basename property="test.case.name" file="${test.case.fullname}" suffix=".md" />
		<dirname property="test.case.dir" file="${test.case.fullname}" />

		<property name="sdb.cmd.argument" value=" '${test.case.dir}/${test.case.name}.md' -o '${test.case.dir}/${test.case.name}.html'" />
		<property name="command" value="pandoc${sdb.cmd.argument}" />
		<echo message="Command:${command}" />
		<exec executable="pandoc" dir="" timeout="60000" outputproperty="screen.output" resultproperty="ret.code" failonerror="false">
			<arg line="${sdb.cmd.argument}" />
		</exec>
		<echo message="${screen.output}" />
		<delete file="${test.case.fullname}" failonerror="false" />
	</target>

	<target name="change-one-suite" depends="">
		<foreach target="change-one-case" param="change.case.fullname">
			<fileset dir="${change.suite.fullname}" includes="${includes.case.patterns}" excludes="${excludes.case.patterns}" />
		</foreach>
	</target>

	<target name="change-one-case" depends="">
		<basename property="change.case.name" file="${change.case.fullname}" suffix=".html" />
		<dirname property="change.case.dir" file="${change.case.fullname}" />

        <exec executable="mv" dir="" timeout="60000" outputproperty="screen.output.conv" resultproperty="ret.code.conv" failonerror="false">
            <arg line=" '${change.case.fullname}' '${change.case.dir}/${change.case.name}_en.html'" />
        </exec>
        <echo message="${screen.output.conv}" />
		<delete file="${change.case.fullname}" failonerror="false" />
	</target>
</project>
