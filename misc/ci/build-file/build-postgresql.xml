<project default="archive_pg_connector">
	<property name="CODE_DIR" value="${WORKSPACE}/sequoiadb" />
	<property name="PG_DIR" value="${WORKSPACE}/postgresql" />
<!-- 	<property name="Engine_DIR" value="${CODE_DIR}/SequoiaDB" /> -->
	<property name="pg_connector_name" value="sdb_fdw.so" />
	<property file="${CODE_DIR}/misc/ci/ci-properies-files/ci.pg.properties.x86" />
	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
        <classpath>
            <pathelement location="${CODE_DIR}/misc/ci/exec-tools/ant-sdbtasks.jar" />
        </classpath>
    </taskdef>

    <target name="clean" depends="">
    	<exec executable="make" dir="${PG_DIR}" failonerror="false">
			<arg line=" uninstall" />
		</exec>
		<exec executable="make" dir="${PG_DIR}" failonerror="false">
			<arg line=" clean" />
		</exec>
    	<exec executable="make" dir="${CODE_DIR}/driver/postgresql" failonerror="false">
			<arg line=" clean" />
		</exec>
		<delete dir="${PG_DIR}/pgsql" failonerror="false" />
		<delete dir="${PG_DIR}/pgsql/pg_data" failonerror="false" />
		<delete dir="${WORKSPACE}/release" failonerror="false" />
    	<mkdir dir="${WORKSPACE}/release" />
    </target>

    <target name="compile_pg" depends="clean">
    	<echo message="Compile the postgresql..." />
    	<chmod file="${PG_DIR}/configure" perm="u+x" />
    	<exec executable="./configure" dir="${PG_DIR}" failonerror="true">
    		<arg line=" --without-readline --without-zlib --prefix=${PG_DIR}/pgsql" />
    	</exec>
    	<exec executable="make" dir="${PG_DIR}" failonerror="true">
    		<arg line=" all" />
		</exec>
		<exec executable="make" dir="${PG_DIR}" failonerror="true">
			<arg line=" install" />
		</exec>
		<mkdir dir="${PG_DIR}/pgsql/pg_data" />
    </target>

    <target name="compile_sdb" depends="compile_pg">
    	<if>
			<equals arg1="${compile.debug}" arg2="true" />
			<then>
				<echo message="compile.debug is ture" />
				<property name="compile.arg.line" value="--dd" />
				<echo message="${compile.arg.line}" />
			</then>
			<else>
				<echo message="compile.debug is false" />
				<property name="compile.arg.line" value="" />
				<echo message="${compile.arg.line}" />
			</else>
		</if>

		<if>
			<equals arg1="${enterprise}" arg2="true" />
			<then>
				<echo message="enterprise is ture" />
				<property name="enterprise.line" value=" --enterprise" />
				<echo message="${enterprise.line}" />
			</then>
			<else>
				<echo message="enterprise is false" />
				<property name="enterprise.line" value="" />
				<echo message="${enterprise.line}" />
			</else>
		</if>
    	<exec executable="scons" dir="${CODE_DIR}" failonerror="true">
			<arg line="${compile.arg.line}${enterprise.line} -j 4" />
		</exec>
    </target>

    <target name="build_pg_connector" depends="compile_sdb">
    	<echo message="Compile the connector of postgresql..." />
    	<property environment="env" />
    	<echo file="${PG_DIR}/pgsql/build.sh" message="bin/initdb -D pg_data&#10;bin/postgres -D pg_data &gt;&gt; ${WORKSPACE}/release/logfile.${BUILD_NUMBER} 2&gt;&#38;1 &#38;" />
    	<!--replace file="${CODE_DIR}/driver/postgresql/Makefile" token="DEBUG?=-ggdb" value="DEBUG?=-ggdb -DSDB_USE_OWN_POSTGRES" /-->
		<exec executable="sh" dir="${PG_DIR}/pgsql" failonerror="true">
			<arg line=" ./build.sh" />
			<env key="LD_LIBRARY_PATH" value="${PG_DIR}/pgsql/lib:${env.LD_LIBRARY_PATH}" />
		</exec>
		<exec executable="make" dir="${CODE_DIR}/driver/postgresql" failonerror="true">
			<arg line=" local" />
		</exec>
		<exec executable="make" dir="${CODE_DIR}/driver/postgresql" failonerror="true">
			<arg line=" all" />
		</exec>
    </target>

    <target name="copy_pg_connector" depends="build_pg_connector">
    	<echo message="Begin to copy the ${pg_connector_name} ... " />
		<copy file="${CODE_DIR}/driver/postgresql/${pg_connector_name}" tofile="${CODE_DIR}/driver/postgresql/${pg_connector_name}.${BUILD_NUMBER}" />
		<stafTools workType="copy" workHost="LOCAL" fileName="${CODE_DIR}/driver/postgresql/${pg_connector_name}.${BUILD_NUMBER}" saveDir="${copy_tar}" toHost="${target.deploy_tar_gz.ip}" failonerror="true"/>
		<echo message="delete the file ${CODE_DIR}/pg.version" />
		<stafTools workType="delete" workHost="LOCAL" fileName="${CODE_DIR}/pg.version" failonerror="false"/>
		<if>
			<equals arg1="${compile.debug}" arg2="false" />
			<then>
				<propertyfile file="${CODE_DIR}/pg.version" comment="true">
					<entry key="BUILD.NUMBER" value="${BUILD_NUMBER}" type="string" />
					<entry key="BUILD.INSTALL.FILENAME" value="${pg_connector_name}${enterprise.line}" type="string" />
					<entry key="RELEASE.NUMBER" value="${BUILD_NUMBER}" type="string"/>	
				</propertyfile>
			</then>
			<else>
				<propertyfile file="${CODE_DIR}/pg.version" comment="true">
					<entry key="BUILD.NUMBER" value="${BUILD_NUMBER}" type="string" />
					<entry key="BUILD.INSTALL.FILENAME" value="${pg_connector_name}${enterprise.line}" type="string" />	
				</propertyfile>
			</else>
		</if>
		<stafTools workType="copy" workHost="LOCAL" fileName="${CODE_DIR}/pg.version" saveDir="${copy_tar}" toHost="LOCAL" failonerror="true"/>
		<stafTools workType="shell" workHost="LOCAL" common="/usr/bin/find ${copy_tar} -mtime +7 -delete;" workDir="${copy_tar}" waitTime="30m" failonerror="true"/>
		<delete file="${CODE_DIR}/driver/postgresql/${pg_connector_name}.${BUILD_NUMBER}" />
    </target>

    <target name="archive_pg_connector" depends="copy_pg_connector">
    	<copy file="${CODE_DIR}/driver/postgresql/${pg_connector_name}" tofile="${WORKSPACE}/release/${pg_connector_name}" />
    </target>
</project>