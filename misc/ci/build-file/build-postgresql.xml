<project default="make_release">
   <property name="SEQUOIADB_CODE_DIR" value="${WORKSPACE}/sequoiadb" />
   <property name="FDW_CODE_DIR" value="${SEQUOIADB_CODE_DIR}/driver/postgresql" />
   <property name="PG_CODE_DIR" value="${WORKSPACE}/postgresql" />
   
   <!--SEQUOIASQL_DIR: for pg output and fdw output, before packed by builder-->
   <property name="SEQUOIASQL_DIR" value="${PG_CODE_DIR}/sequoiasql" /> 
   <property name="RELEASE_CONF_DIR" value="${PG_CODE_DIR}/package/run/conf" />
   <property name="RELEASE_DIR" value="${WORKSPACE}/release" />
   
   <property file="${SEQUOIADB_CODE_DIR}/misc/ci/ci-properies-files/ci.pg.properties.x86" />
   <taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
      <classpath>
         <pathelement location="${SEQUOIADB_CODE_DIR}/misc/ci/exec-tools/ant-sdbtasks.jar" />
      </classpath>
   </taskdef>
   
   <target name="clean" depends="">
      <property environment="env" />
      <exec executable="make" dir="${FDW_CODE_DIR}" failonerror="true">
         <env key="PATH" path="${SEQUOIASQL_DIR}/bin:${env.PATH}" />
         <arg line=" clean" />
      </exec>
      <exec executable="make" dir="${PG_CODE_DIR}" failonerror="true">
         <arg line=" uninstall" />
      </exec>
      <exec executable="make" dir="${PG_CODE_DIR}" failonerror="true">
         <arg line=" clean" />
      </exec>
      
      <delete dir="${SEQUOIASQL_DIR}" failonerror="false" />
      <delete dir="${RELEASE_DIR}" failonerror="false" />
      <mkdir dir="${RELEASE_DIR}" />
   </target>

   <target name="compile_pg" depends="clean">
      <echo message="Compile the postgresql..." />
      
      <if>
         <equals arg1="${compile.debug}" arg2="true" />
         <then>
            <echo message="compile pg is debug" />
            <property name="compile.arg.line" value="'CFLAGS=-O0' --enable-debug" />
         </then>
         <else>
            <echo message="compile pg is release" />
            <property name="compile.arg.line" value="" />
         </else>
      </if>
      
      <chmod file="${PG_CODE_DIR}/configure" perm="u+x" />
      <exec executable="./configure" dir="${PG_CODE_DIR}" failonerror="true">
         <arg line=" --without-readline --without-zlib ${compile.arg.line} --prefix=${SEQUOIASQL_DIR}" />
      </exec>
      <exec executable="make" dir="${PG_CODE_DIR}" failonerror="true">
         <arg line=" all" />
      </exec>
      <exec executable="make" dir="${PG_CODE_DIR}" failonerror="true">
         <arg line=" install" />
      </exec>
   </target>

   <target name="compile_sequoiadb" depends="compile_pg">
      <echo message="Compile the sequoiadb..." />     
      <exec executable="scons" dir="${SEQUOIADB_CODE_DIR}" failonerror="true">
         <arg line=" --enterprise -j 4" />
      </exec>
   </target>
   
   <target name="build_pg_connector" depends="compile_sequoiadb">
      <echo message="Compile the connector of postgresql..." />
      <property environment="env" />
      
      <if>
         <equals arg1="${compile.debug}" arg2="true" />
         <then>
            <echo message="compile fdw is debug" />
            <replace file="${FDW_CODE_DIR}/Makefile" token="OPTIMIZATION?=-O3" value="OPTIMIZATION?=-O0" />      
         </then>
         <else>
            <echo message="compile fdw is release" />          
         </else>
      </if>
      
      <!--fdw for changed pg-->
      <replace file="${FDW_CODE_DIR}/Makefile" token="DEBUG?=-ggdb" value="DEBUG?=-ggdb -DSDB_USE_OWN_POSTGRES" />
         
      <exec executable="make" dir="${FDW_CODE_DIR}" failonerror="true">
         <env key="PATH" path="${SEQUOIASQL_DIR}/bin:${env.PATH}" />
         <arg line=" local" />
      </exec>
      <exec executable="make" dir="${FDW_CODE_DIR}" failonerror="true">
         <env key="PATH" path="${SEQUOIASQL_DIR}/bin:${env.PATH}" />
         <arg line=" all" />
      </exec>
      
      <!--get sequoiadb version-->
      <echo message="/usr/bin/gcc  ${SEQUOIADB_CODE_DIR}/misc/ci/exec-tools/print_version.c -o ${SEQUOIADB_CODE_DIR}/misc/ci/exec-tools/print_version -I${SEQUOIADB_CODE_DIR}/SequoiaDB/engine/include" />
      <exec executable="/usr/bin/gcc" dir="${SEQUOIADB_CODE_DIR}/misc/ci/exec-tools" failonerror="true">
         <arg line="print_version.c -o print_version -I${SEQUOIADB_CODE_DIR}/SequoiaDB/engine/include" />
      </exec>
      <exec executable="./print_version" 
            dir="${SEQUOIADB_CODE_DIR}/misc/ci/exec-tools" 
            failonerror="true" 
            outputproperty="db_version" />
      <echo message="sequoiadb version = ${db_version}" />

      <!--get svn version--> 
      <echo message="svn info | grep Revision | awk '{print $2}', dir = ${FDW_CODE_DIR}" /> 
      <exec executable="bash" dir="${FDW_CODE_DIR}" failonerror="true" outputproperty="fdw_svn">
         <arg value="-c" />
         <arg line="&quot;svn info | grep Revision | awk '{print $2}'&quot;" />
      </exec>     
      <echo message="fdw svn revision = ${fdw_svn}" />
      
      <!--get edition (judge changed or original) -->
      <exec executable="bash" dir="${FDW_CODE_DIR}" failonerror="true" outputproperty="fdw_output">
         <arg value="-c" />
         <arg line="&quot;nm sdb_fdw.so | grep sdbuseownpostgres&quot;" />
      </exec>  
      
      <!--change fdw name-->
      <if>
         <equals arg1="${fdw_output}" arg2="" />
         <then>            
            <property name="fdw_name" value="sdb_fdw.so_${db_version}_${fdw_svn}" /> 
            <echo message="fdw is original, fdw new name = ${fdw_name}" />  
         </then>
         <else>             
            <property name="fdw_name" value="sdb_fdw.so_e_${db_version}_${fdw_svn}" />
            <echo message="fdw is enterprise, fdw new name = ${fdw_name}" />  
         </else>
      </if>                   
      
   </target>

   <target name="make_release" depends="build_pg_connector">   
      <echo message="Begin to copy fdw files to ${SEQUOIASQL_DIR}"/>    
      
      <!--1 copy fdw files-->
      <copy file="${FDW_CODE_DIR}/sdb_fdw.control"  tofile="${SEQUOIASQL_DIR}/share/extension/sdb_fdw.control" />
      <copy file="${FDW_CODE_DIR}/sdb_fdw--1.0.sql" tofile="${SEQUOIASQL_DIR}/share/extension/sdb_fdw--1.0.sql" />
      <copy file="${FDW_CODE_DIR}/sdb_fdw.so"       tofile="${SEQUOIASQL_DIR}/lib/${fdw_name}" />
      <chmod file="${SEQUOIASQL_DIR}/lib/${fdw_name}" perm="a+x" />
      <exec executable="ln" dir="${SEQUOIASQL_DIR}/lib" failonerror="true">
         <arg line="-sf ${fdw_name} sdb_fdw.so" />
      </exec>     
      
      <!--2 make run package-->
      <exec executable="arch" failonerror="true" outputproperty="platform"/>
      
      <exec executable="bash" dir="${SEQUOIASQL_DIR}" failonerror="true" outputproperty="edition_output">
         <arg value="-c" />
         <arg line="&quot;./bin/postgres --version | grep SequoiaDB&quot;" />
      </exec> 
      <if>
         <equals arg1="${edition_output}" arg2="" />
         <then>            
            <property name="edition_str" value="" /> 
            <echo message="pg is original" />  
         </then>
         <else>             
            <property name="edition_str" value="-enterprise" />
            <echo message="pg is enterprise" />  
         </else>
      </if>  

      <exec dir="${RELEASE_CONF_DIR}" executable="builder" failonerror="true">
         <arg line="build sequoiasql.xml --setvars project.version=${db_version} --setvars platform=${platform} --setvars edition=${edition_str} --setvars project.outputDirectory=${RELEASE_DIR}" />
      </exec>
      <echo message="build sequoiasql.xml --setvars project.version=${db_version} --setvars platform=${platform} --setvars edition=${edition_str} --setvars project.outputDirectory=${RELEASE_DIR}" />
      
      <!--3 copy run package to archive dir-->
      <property name="PACKAGE_NAME" value="${project.name}-${db_version}-${platform}${edition_str}-installer.run" />      
      <echo message="Begin to copy ${PACKAGE_NAME} to ${archive.dir}"/>
      <copy file="${RELEASE_DIR}/${PACKAGE_NAME}" tofile="${archive.dir}/${PACKAGE_NAME}.${BUILD_NUMBER}" />
      <exec executable="bash" dir="${archive.dir}" failonerror="true">
         <arg value="-c" />
         <arg line="&quot;find *.run* -mtime +7 -exec rm -rf {} \;&quot;" />
      </exec>  
      
      <!--4 make pg.version-->
      <echo message="Begin to make pg.version, copy it to ${archive.dir}"/>
      <delete file="${PG_CODE_DIR}/pg.version" failonerror="false"/>
      <if>
         <equals arg1="${compile.debug}" arg2="false" />
         <then> <!--release-->
            <propertyfile file="${PG_CODE_DIR}/pg.version" comment="true">
               <entry key="BUILD.NUMBER" value="${BUILD_NUMBER}" type="string" />
               <entry key="BUILD.INSTALL.FILENAME" value="${PACKAGE_NAME}" type="string" />
               <entry key="RELEASE.NUMBER" value="${BUILD_NUMBER}" type="string"/>  
            </propertyfile>
         </then>
         <else> <!--debug-->
            <propertyfile file="${PG_CODE_DIR}/pg.version" comment="true">
               <entry key="BUILD.NUMBER" value="${BUILD_NUMBER}" type="string" />
               <entry key="BUILD.INSTALL.FILENAME" value="${PACKAGE_NAME}" type="string" />  
            </propertyfile>         
         </else>
      </if>    
      <copy file="${PG_CODE_DIR}/pg.version" tofile="${archive.dir}/pg.version" failonerror="true"/>  
      
   </target>
   
</project>
