<!--@param ${install.path} where mongodb install , default in /opt/mongodb-->

<!--@param ${remote.mongodb.software.path} where mongodb software is it -->

<project name="deploy-mongodb" default="deploy-mongodb">
	<property name="install.path" value="/opt" />
	<property name="mongodb.install.path" value="${install.path}/mongodb"/>
	<target name="clean" depend="">
		
		<delete dir="${mongodb.install.path}" />
		<untar dest="${install.path}" src="${remote.mongodb.software.path}/mongodb.tar.gz" />
    <!--stop the mongodb server-->
    <echo message="stop the mongodb server" />
    <exec executable="${testcases.path}/mongodb/bin/mongo" dir="${testcases.path}" failonerror="false" >
    	<arg line=" admin --eval 'db.shutdownServer() ' " />
    </exec>
		
		<mkdir dir="${mongodb.install.path}/database" />
	</target>
	
  <target name="deploy-mongodb" depends="clean">
  	<!--start mongodb standalong mode-->
  	<echo message="start mongodb standalong" />
    <exec executable="${mongodb.install.path}/bin/mongod" spawn="true"  dir="${mongo.install.path}">
      <arg line=" --dbpath ${mongo.install.path}/database --logpath ${mongo.install.path}/database/mongo.test.log"/>
    </exec>
  </target>
  
</project>
