<!--@param ${antTask.jar.path}: The path where ant-sdbtask.jar direcotry.-->
<!--@param ${java.testcase.path}: The path where test case direcotry.-->
<!--@param ${deploy.case.fullname}: The run in which env -->
<!--@param ${reports.path}: The path where test case direcotry.-->

<project default="Exec-Testcases-Over">                
    <taskdef resource="testngtasks" classpath="${java.testcase.path}/lib/testng-6.9.11.jar"/>   
    <taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
        <classpath>
            <fileset dir="${antTask.jar.path}" includes="*.jar" />
        </classpath>
    </taskdef>
      
    <target name="Clean-Java-Reports" depends="">
        <delete dir="${reports.path}" failonerror="false" />
        <mkdir dir="${reports.path}" />
        <property name="tmp.reports.path" value="${java.testcase.path}/testng_report" />
        <delete dir="${tmp.reports.path}" failonerror="false" />
        <mkdir dir="${tmp.reports.path}" />
    </target>

    <target name="Test-Story-Java" depends="Clean-Java-Reports">
        <tstamp>
        	<format property="test_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
        </tstamp>
        	                
        <path id="calsspath.test">
            <fileset dir="${java.testcase.path}/lib">
                <include name="*.jar"/>
            </fileset>
            <pathelement path="${java.testcase.path}/build" />        
        </path>
        <testng outputDir="${tmp.reports.path}" classpathref="calsspath.test">
            <xmlfileset dir="${java.testcase.path}" includes="testng.xml"/>        
        </testng>        
    	    			 	    
        <tstamp>
        	<format property="test_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
        </tstamp>
		<sdbTime beginTime="${test_begintime}" endTime="${test_endtime}" output="test_time" />
		<echo message="**************************************************************************************************************************************************************" />
		<echo level="info" message="The story java test began at &lt;${test_begintime}&gt;, end at &lt;${test_endtime}&gt;,total spending ${test_time}s." />
		<echo message="**************************************************************************************************************************************************************" />
    
    </target>
       
    <target name="Exec-Testcases-Over" depends="Test-Story-Java">
        <hostinfo prefix="host" />
        <copy todir="${reports.path}">
            <fileset dir="${tmp.reports.path}/junitreports"/>
        </copy> 
        <basename property="deploy.name" file="${deploy.case.fullname}" suffix=".xml" />
        <replace token='name="com.sequoiadb' value='name="testcases-story-java.${deploy.name}-${host.NAME}-${parallel.num}-'>
            <fileset dir="${reports.path}"  includes="*" />
        </replace>
    </target>
</project>
