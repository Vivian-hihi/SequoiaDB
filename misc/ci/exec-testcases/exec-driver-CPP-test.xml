<!--@param ${testcase.path}: The path where test case direcotry.-->
<!--@param ${reports.path}: The path where test case direcotry.-->
<!--@param ${test_name}: will not test name. -->
<!--@param ${deploy.case.fullname}: The run in which env -->

<project name="exec-driver-CPP-test" default="Test-Driver-CPP-Over">
    <property name="test_name" value="*" /> 
    <property name="append" value=" --gtest_filter=${test_name}  --gtest_output=xml:${reports.path}/ " />
    <taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
        <classpath>
            <fileset dir="${antTask.jar.path}" includes="*.jar" />
        </classpath>
    </taskdef>

    <target name="Clean-CPP-Reports" depends="">
        <echo message="Reports' path is ${reports.path}" />
        <delete dir="${reports.path}" failonerror="false" />
        <mkdir dir="${reports.path}" />
        <echo message="Clean deploy result reports compeleted." />
    </target>

    <target name="Test-Driver-CPP" depends="Clean-CPP-Reports">
        <echo message="Begin test driver cpp testcases..." />
        <echo message="Perform the driver cpp testcases,with testcase.path=${CPP.testcase.path}" />

        <chmod dir="${CPP.testcase.path}" perm="u+x" includes="*" />
        <foreach target="test-one-case" param="case-full-name">
            <path>
                <dirset dir="${CPP.testcase.path}" includes="${includes.dir.patterns}" excludes="${excludes.dir.patterns}" />
            </path>
            <param name="test-type" value="driver-cpp" />
        </foreach>
    </target>

    <target name="test-one-case" depends="">   
        <echo message="Exec ${case-full-name}  ${append} ...path is /opt/sequoiadb/lib ..." />
        <echo message="Env is LD_LIBRARY_PATH=/opt/sequoiadb/lib" />

        <echo message="####case-full-name=${case-full-name}####" />
        <tstamp>
            <format property="testcase.begin.time" pattern="yyyy-MM-dd-hh.mm.ss" />
        </tstamp>
        <echo message="Now testcase ${case-full-name}.cpp begin with ${testcase.begin.time}"/>

        <exec executable="${case-full-name}" dir="${testcase.path}/CPP/build" timeout="1200000" outputproperty="screen.output" resultproperty="ret.code" failonerror="false">
            <arg line=" ${append} " />
            <env key="LD_LIBRARY_PATH" path="${env.LD_LIBRARY_PATH}:/opt/sequoiadb/lib" />
        </exec>
        <echo message="${screen.output}" />

        <tstamp>
            <format property="testcase.end.time" pattern="yyyy-MM-dd-hh.mm.ss" />
        </tstamp>
        <sdbTime beginTime="${testcase.begin.time}" endTime="${testcase.end.time}" output="testcase.timeOutput" />
        <echo message="The result code is ${ret.code} and it's succ ..." />
        <echo message="The testcase ${test.case.name}.cpp end with ${testcase.end.time} and cost ${testcase.timeOutput} s in total..." />           
    </target>

    <target name="Test-Driver-CPP-Over" depends="Test-Driver-CPP">
        <basename property="deploy.name" file="${deploy.case.fullname}" suffix=".xml" />
        <replaceregexp match="&lt;testsuite (.*)&gt;" replace="" flags="g" byline="true" encoding="utf-8">
            <fileset dir="${reports.path}/" includes="*" />
        </replaceregexp>
        <replaceregexp match="&lt;/testsuites(.*)&gt;" replace="" flags="g" byline="true" encoding="utf-8">
            <fileset dir="${reports.path}/" includes="*" />
        </replaceregexp>
        <replaceregexp match='classname="' replace='classname="com.sequoiadb.testcases-driverC.${deploy.name}.' flags="g" byline="true" encoding="utf-8">
            <fileset dir="${reports.path}/" includes="*" />
        </replaceregexp>
        <replace token="AllTests" value="com.sequoiadb.testcases-driverC.${deploy.name}">
            <fileset dir="${reports.path}/"  includes="*" />
        </replace>
        <replace token="testsuites" value="testsuite">
            <fileset dir="${reports.path}/"  includes="*" />
        </replace>
    </target>
</project>

