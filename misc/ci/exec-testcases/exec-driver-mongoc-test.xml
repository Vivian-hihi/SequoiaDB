<project default="Test-Driver-mongoc">
   <property file="${ci.properties.path}" />
   <taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
      <classpath>
         <fileset dir="${antTask.jar.path}" includes="*.jar" />
      </classpath>
   </taskdef>
   
   <target name="Clean-mongoc-Reports">
      <echo message="Reports' path is ${reports.path}" />
      <delete dir="${reports.path}" failonerror="false" />
      <mkdir dir="${reports.path}" />
      <echo message="Clean deploy result reports compeleted." />
   </target>
   
   <target name="Test-Driver-mongoc" depends="Clean-mongoc-Reports">
      <hostinfo prefix="host" />
      <basename property="deploy.name" file="${deploy.case.fullname}" suffix=".xml" />
      <property name="test.suite.class.name" value="testcases-driver-mongoc.${deploy.name}-${host.NAME}-${parallel.num}" />
      <tstamp>
         <format property="testtype_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
      </tstamp>
      
      <echo message="Begin test driver mongoc testcases..." />
      <echo message="Perform the driver mongoc testcases,with testcase.path=${mongoc.testcase.path}" />
      <chmod file="${mongoc.testcase.path}/test-mongo" perm="u+x" />     
      <exec executable="./test-mongo" dir="${mongoc.testcase.path}" timeout="60000" output="${mongoc.testcase.path}/testcases.txt" resultproperty="ret.code" failonerror="true">
         <arg line=" --help" />
         <env key="LD_LIBRARY_PATH" path="${LD_LIBRARY_PATH}:${mongoc.testcase.libpath}" />
      </exec>
      <exec executable="grep" timeout="60000" input="${mongoc.testcase.path}/testcases.txt" output="${mongoc.testcase.path}/testcases.txt" resultproperty="ret.code" failonerror="true">
         <arg line="'^    '" />
         <env key="LD_LIBRARY_PATH" path="${LD_LIBRARY_PATH}:${mongoc.testcase.libpath}" />
      </exec>
      <replace file="${mongoc.testcase.path}/testcases.txt" token="    " value="" />
      <replace file="${mongoc.testcase.path}/testcases.txt" token="&#10;" value="," />
      <replace file="${mongoc.testcase.path}/testcases.txt" token="-h, --help   Show this help menu.,-f   Do not fork() before running tests.,-l NAME  Run test by name.,-p   Do not run tests in parallel.,-v   Be verbose with logs.,-tTest Suite executive duration-F   Test Report Path(.xml/.txt)," value="" />
      <loadfile property="testcases" srcFile="${mongoc.testcase.path}/testcases.txt" failonerror="false" />
      <foreach list="${testcases}" target="test-one-case" param="test.case.name" delimiter=",">
         <param name="testcases.path" value="${mongoc.testcase.path}" />
      </foreach>

      <replaceregexp match='name=""' replace='name="${test.suite.class.name}"' flags="g" byline="true" encoding="utf-8">
         <fileset dir="${reports.path}/" includes="*" />
      </replaceregexp>
      <replaceregexp match='testcase name="' replace='testcase classname="${test.suite.class.name}-' flags="g" byline="true" encoding="utf-8">
         <fileset dir="${reports.path}/" includes="*" />
     </replaceregexp>

      <echo message="parallel executable" />
      <echo message="current parallel execute all testcases" /> 
      <echo message="Exec test-mongo -f " /> 
      <echo message="Env:LD_LIBRARY_PATH=${mongoc.testcase.libpath}" />
      <echo message="The testcases path on ${testcases.path}" />
      <exec executable="./test-mongo" dir="${mongoc.testcase.path}" timeout="60000" outputproperty="mongo.screen.output" resultproperty="mongo.ret.code" failonerror="false">
         <!-- <arg line=" -f -F ${reports.path}/concurrent_report.xml" /> -->
         <arg line=" -f " />
         <env key="LD_LIBRARY_PATH" path="${LD_LIBRARY_PATH}:${mongoc.testcase.libpath}" />
         <env key="MONGOC_TEST_HOST" value="${mongoc.test.host}" />
      </exec>
      <echo message="${mongo.screen.output}" />
      <echo message="The result = ${mongo.ret.code} after exec parallel testcase." />

      <tstamp>
         <format property="testtype_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
      </tstamp>
      <sdbTime beginTime="${testtype_begintime}" endTime="${testtype_endtime}" output="testtype_time" />
      <echo message="**************************************************************************************************************************************************************" />
      <echo level="info" message="The mongo began at &lt;${testtype_begintime}&gt;, end at &lt;${testtype_endtime}&gt;,total spending ${testtype_time}s." />
      <echo file="/opt/testsuite.log${BUILD_NUMBER}" append="true" message="Now testtype is driver-mongoc,cost ${testtype_time}s,hostname=${host.NAME}&#10;" />
      <echo message="**************************************************************************************************************************************************************" />
   </target>        
    
   <target name="test-one-case">
      <hostinfo prefix="host" />
      <echo message="current execute ${test.case.name}" />  
      <echo message="Exec test-mongo -f -p -l ${test.case.name}" />
      <echo message="Env:LD_LIBRARY_PATH=${mongoc.testcase.libpath}" />
      <echo message="The testcase ${test.case.name} path on ${testcases.path}" />
      
      

      <echo message="**************************************************************************************************************************************************************" />
      <echo message="test.suite.class.name=${test.suite.class.name}" />
      <echo message="test.case.name=${test.case.name}" />
      <echo message="reports.path=${reports.path}" />
      <echo message="**************************************************************************************************************************************************************" />
      <exec executable="./test-mongo" dir="${testcases.path}" timeout="60000" outputproperty="screen.output" resultproperty="ret.code" failonerror="false">
         <arg line=" -f -p -l ${test.case.name} -F ${reports.path}/${test.case.name}.xml" />
         <env key="LD_LIBRARY_PATH" path="${LD_LIBRARY_PATH}:${mongoc.testcase.libpath}" />
         <env key="MONGOC_TEST_HOST" value="${mongoc.test.host}" />
      </exec>     
      <!-- <if>
         <not>
            <equals arg1="${ret.code}" arg2="0" />
         </not>
         <then>
            <echo file="${reports.path}/${test.case.name}.xml" message="&lt;testsuites tests=&quot;1&quot; failures=&quot;1&quot; errors=&quot;1&quot; name=&quot;&quot;&gt;&#10;&lt;testcase name=&quot;${test.case.name}&quot; status=&quot;fail&quot; time=&quot;1&quot;&gt;&#10;&lt;failure&gt;&#10;&lt;![CDATA[&#10;${screen.output}]]&gt;&#10;&lt;/failure&gt;&#10;&lt;/testcase&gt;&#10;&lt;/testsuites&gt;&#10;" />
         </then>
      </if> -->
      <echo message="${screen.output}" />
      <echo message="The result = ${ret.code} after exec ${test.case.name} testcase." />
   </target> 
</project>

