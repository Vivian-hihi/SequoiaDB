<!--@param ${testcase.path}: The path where test case direcotry.-->
<!--@param ${reports.path}: The path where test case direcotry.-->
<!--@param ${deploy.case.fullname}: The run in which env -->
<!--@param ${php-bin.dir} : The php-bin's director-->
<!--@param ${phpunit.phar.dir} : The phpunit.phpar's director-->

<project name="exec-driver-php-test" default="exec-driver-php-test">
	<property name="php-bin.dir" value="/opt/sequoiadb/tools/server/php/bin" />
	<property name="phpunit.phar.dir" value="${testcase.path}/tools/phpunit.phar" />
	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
		<classpath>
			<fileset dir="${antTask.jar.path}" includes="*.jar" />
		</classpath>
	</taskdef>

	<target name="clean-env" depends="">
		<delete dir="${reports.path}" failonerror="false" />
		<mkdir dir="${reports.path}" />
	</target>

	<target name="exec-driver-php-test" depends="clean-env">
		<echo message="phpunit.phar.dir is ${phpunit.phar.dir}" />
		<echo message="testcase dir is ${testcase.path}" />
		<foreach target="test-php-folder" param="test.php.folder.dir" >
			<path>
				<dirset dir="${testcase.path}" includes="*" excludes="tools" />
			</path>
		</foreach>
	</target>

	<target name="test-php-folder" depends="" >
	<basename property="test.php.folder.name" file="${test.php.folder.dir}" />
	<echo message="test folder is ${test.php.folder.name}" />
		<foreach target="test-one-case" param="one.php.fullname">
			<fileset dir="${test.php.folder.dir}" includes="*.php"/>
			<param name="test.php.folder.name" value="${test.php.folder.name}" />
		</foreach>
	</target>

	<target name="test-one-case" depends="">
		<basename property="php.name" file="${one.php.fullname}" suffix=".php" />

		<tstamp>
			<format property="testcase.begin.time" pattern="yyyy-MM-dd-hh.mm.ss" />
		</tstamp>
		<echo message="This testcase begin time is ${testcase.begin.time}"/>

		<echo message="test one case is ${php.name}" />
		<exec executable="${php-bin.dir}/php-bin" failonerror="false" dir="${php-bin.dir}" timeout="1200000" outputproperty="screen.output" resultproperty="ret.code">
			<arg line="${phpunit.phar.dir}   --log-junit ${reports.path}/${php.name}.xml ${one.php.fullname}"/>
			<arg line="${phpunit.phar.dir}   --log-junit ${reports.path}/${php.name}.xml ${one.php.fullname}"/>
		</exec>
		<echo message="${screen.output}" />

		<tstamp>
			<format property="testcase.end.time" pattern="yyyy-MM-dd-hh.mm.ss" />
		</tstamp>
		<echo message="This testcase end time is ${testcase.end.time}"/>
		<sdbTime beginTime="${testcase.begin.time}" endTime="${testcase.end.time}" output="testcase.timeOutput" />
		<echo message="The testcase ${test.case.name}.js cost ${testcase.timeOutput} s in total..." />

		<antcall target="overWriteReportFile">
			<param name="php.name" value="${php.name}" />
		</antcall>
	</target>

	<target name="overWriteReportFile" depends="">
		<basename property="deploy.name" file="${deploy.case.fullname}" suffix=".xml" />
		<replaceregexp match="&lt;(.*)testsuites&gt;" replace="" flags="g" byline="true" encoding="utf-8">
			<fileset dir="${reports.path}/" includes="${php.name}*" />
		</replaceregexp>
		<replaceregexp match='&lt;testsuite name="(.*)" file' replace='&lt;testsuite name="com.sequoiadb.testcases-driverPHP.${deploy.name}" file' flags="g" byline="true" encoding="utf-8">
			<fileset dir="${reports.path}/" includes="${php.name}*" />
		</replaceregexp>
		<replaceregexp match='&lt;testcase n' replace='&lt;testcase classname="com.sequoiadb.testcases-driverPHP.${deploy.name}.${php.name}" n' flags="g" byline="true" encoding="utf-8">
			<fileset dir="${reports.path}/" includes="${php.name}*" />
		</replaceregexp>
	</target>
</project>
