<!--@param ${testcase.path}: The path where test case direcotry.-->
<!--@param ${install.path}: The path where sequoiadb installed.-->
<!--@param ${antTask.jar.path}: The antTask.jar's path.-->
<!--@param ${reports.path}: The path where test case direcotry.-->
<!--@param ${test.package.name}: The name of test package name,.-->
<!--@param ${parallel.num}:  The parallel number when parallel in same host.-->
<!--@param ${excludes.dir.patterns}: A comma- or space-sparated list of patterns of directories that must be excluded.-->
<!--@param ${to.copy.test.log}: If it is true ,then copy the test log for everyone to down them , default is true-->
<!--@param ${ci.properties.path}: where is the ci.properties file -->
<!--@param ${report.suffix}:this is for long time test, default is NULL-->
<project name="test-basic-testcases" default="test-basic-testcases">
	
	<property name="report.suffix" value="" />
	<property file="${ci.properties.path}" />
	<property name="COORD_SVC_NAME" value="50000" />
	<property name="testcase.path" value="${testcase.path}" />
	<property name="sdb.fullname" value="${install.path}/sequoiadb/bin/sdb" />

	<target name="clean-test-reports" depends="">
		<echo message="Begin to clean test result reports..." />
		<delete dir="${testcase.path}/reports${parallel.num}" />
		<echo message="Clean deploy result reports compeleted." />
	</target>

	<property name="STAF.PATH" value="/usr/local/staf" />
	<property name="to.copy.test.log" value="true"/>
	 
	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
		<classpath>
			<fileset dir="${antTask.jar.path}" includes="*.jar" />
			<!--
			<pathelement location="${STAF.PATH}/lib/JSTAF.jar" />
			<pathelement location="${STAF.PATH}/samples/demo/STAFDemo.jar" />
			-->
		</classpath>
	</taskdef>

	<property name="excludes.dir.patterns" value="" />

	<target name="test-basic-testcases" depends="clean-test-reports">
		<echo message="Begin test basic testcases..." />
		<!--
		<taskdef resource="net/sf/antcontrib/antlib.xml">
			<classpath>
				<pathelement location="/usr/share/java/ant-contrib.jar" />
			</classpath>
		</taskdef>
		-->

		<mkdir dir="${reports.path}" />
		<echo message="perform the base-bussiness testcases,with testcase.path=${testcase.path}" />
		<chmod file="${install.path}/sequoiadb/bin/sdb" perm="u+x" />

		<property name="sdb.cmd.allPrepare" value="-e &quot;var COORDSVCNAME=${COORDSVCNAME} ;&quot; -f &quot;${testcase.path}/libs/func.js ,${testcase.path}/libs/all_prepare.js&quot;" />
		<property name="sdb.cmd.allClean" value="-e &quot;var COORDSVCNAME=${COORDSVCNAME} ;&quot; -f &quot;${testcase.path}/libs/func.js ,${testcase.path}/libs/all_clean.js&quot;" />

		<echo message="Exec:${sdb.fullname} ${sdb.cmd.allPrepare}" />
		<exec executable="${sdb.fullname}" dir="" timeout="300000" outputproperty="screen.output" errorproperty="error.output" resultproperty="allPrepare.ret.code">
			<arg line="${sdb.cmd.allPrepare}" />
		</exec>

		<foreach target="test-one-suite" param="test.suite.fullname">
			<path>
				<dirset dir="${testcase.path}/js" excludes="${excludes.dir.patterns}" />
			</path>
			<!--fileset dir="${testcase.path}js">
				<exclude name="${excludes.dir.patterns}" />
				<exclude name="procedures" />
			</fileset-->
			<param name="testcase.path" value="${testcase.path}" />
			<param name="sdb.fullname" value="${install.path}/sequoiadb/bin/sdb" />
		</foreach>
		
		<echo message="Exec:${sdb.fullname} ${sdb.cmd.allClean}" />
		<exec executable="${sdb.fullname}" dir="" timeout="300000" outputproperty="screen.output" errorproperty="error.output" resultproperty="allClean.ret.code">
			<arg line="${sdb.cmd.allClean}" />
		</exec>
	</target>

	<target name="test-one-suite" depends="">

		<basename property="test.suite.name" file="${test.suite.fullname}" />
		<hostinfo prefix="host" />

		<property name="test.suite.class.name" value="com.sequoiadb.testcases-js.${test.package.name}.${host.NAME}-${parallel.num}-${test.suite.name}" />
    	<echo message="now testsuite ${test.suite.name}" />
		
		<tstamp>
			<format property="testsuite.begin.time" pattern="yyyy-MM-dd-hh.mm.ss" />
		</tstamp>
		<echo message="This suite begin time is ${testsuite.begin.time}"/>

		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" message="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot; ?&gt;&#10;
							            &lt;testsuite errors=&quot;0&quot; failures=&quot;0&quot; hostname=&quot;${host.NAME}&quot; name=&quot;${test.suite.class.name}&quot; tests=&quot;1&quot;&gt;&#10;" />


    
		<available file="${test.suite.fullname}/commlib.js" property="commlib.exist" />
		<if>
			<isset property="commlib.exist" />
			<then>
				<echo message="${test.suite.fullname}/commlib is exist , then test will add it " />
				<sdbProperty name="commlib.option" value=",${test.suite.fullname}/commlib.js" />
			</then>	
			<else>
				<echo message="${test.suite.fullname}/commlib is not exist , then test will not add it" />
				<sdbProperty name="commlib.option" value="" />
			</else>
		</if>
		
		<foreach target="test-one-case" param="test.case.fullname">
			<fileset dir="${test.suite.fullname}" includes="*.js" excludes="commlib.js" />
			<param name="testcase.path" value="${testcase.path}" />
			<param name="sdb.fullname" value="${sdb.fullname}" />
			<param name="host.NAME" value="${host.NAME}" />
			<param name="parallel.num" value="${parallel.num}" />
			<param name="test.suite.class.name" value="${test.suite.class.name}" />
			<param name="commlib.option" value="${commlib.option}" />
		</foreach>

		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" message="
								&lt;system-out&gt;&#10;
								&lt;![CDATA[${on screen}]]&gt;&#10;
								&lt;/system-out&gt;&#10;
								&lt;/testsuite&gt;&#10;" append="true" />
		<tstamp>
			<format property="testsuite.end.time" pattern="yyyy-MM-dd-hh.mm.ss" />
		</tstamp>
		<echo message="This suite end time is ${testsuite.end.time}"/>

	</target>


	<target name="test-one-case" depends="">
		<tstamp>
			<format property="testcase.begin.time" pattern="yyyy-MM-dd-hh.mm.ss" />
		</tstamp>
		<echo message="This testcase begin time is ${testcase.begin.time}"/>

		<exec executable="${sdb.fullname}" timeout="300000" dir="" outputproperty="db.RG.info" resultproperty="ret.code.forShards">
		  <arg line=" -s &quot; db = new Sdb('localhost',50000);var rg = db.listReplicaGroups();println(rg);db.close(); &quot;" />
		</exec>
		
		<if>
			<not>
			<equals arg1="${ret.code.forShards}" arg2="0" />
			</not>
			<then>
				<sdbProperty name="db.RG.info" value="this env is standalone , host is ${test.machine.no2.basic}"/>
			</then>
		</if>
		<if>
	     	<equals arg1="${os.arch}" arg2="ppc64" />
	   		<then>
	   	  	<property name="URL.download.pre" value="http://192.168.30.150:8080" />
	   		</then>
	   		<else>
	    	  <property name="URL.download.pre" value="http://192.168.30.184:8080" />
	   		</else>
   		</if>
		<basename property="test.case.name" file="${test.case.fullname}" suffix=".js" />
		
		<exec executable="sed">
			<arg line="-i 's/^\xEF\xBB\xBF//g'  ${test.case.fullname}"/>
		</exec>
		
		<exec executable="sed">
			<arg line="-i 's/^\xEF\xBB\xBF//g'  ${testcase.path}/libs/func.js"/>
		</exec>

    	<echo message="now testcase ${test.case.name}.js" />
	
		<!--
		<sdbFileAdd srcFile="${testcase.path}/libs/func.js"  destFile="${test.case.fullname}.${parallel.num}" />
		<sdbFileAdd srcFile="${test.case.fullname}" destFile="${test.case.fullname}.${parallel.num}" />		
		-->
		<!-- end -->


		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" append="true" message="&lt;testcase classname=&quot;${test.suite.class.name}&quot; name=&quot;${test.case.name}&quot; &gt;&#10;" />
    

    
    <property name="CS_PRIX_TMP" value="${host.NAME}${parallel.num}${test.case.name}"/>
    <!--script language="javascript"><![CDATA[
       var before = project.getProperty("CS_PRIX_TMP");
       before = before.replaceAll("_", "");
       before = before.replaceAll("-", "");
       project.setProperty("CS_PRIX", before);
    ]]></script-->
    
    <!--set the property name="CS_PRIX" value="~~"-->
    <sdbprefix prefixName="CS_PRIX">
    	 <param name="${host.NAME}" value="${host.NAME}" />
    	 <param name="${test.case.name}" value="${test.case.name}" />
    	 <param name="${parallel.num}" value="${parallel.num}" />
    </sdbprefix>
    
		<!--property name="CS_PRIX" value="${host.NAME}${start_time}${test.case.name}" /-->
		<!--property name="CS_PRIX" value="${start_time}" /-->
		
		
		<!--propertyregex property="CS_PRIX_TMP" input="${host.NAME}${parallel.num}${test.case.name}" regexp="-" replace="" />
		<propertyregex property="CS_PRIX" input="${CS_PRIX_TMP}" regexp="_" replace="" /-->

		<property name="sdb.cmd.argument" value="-e &quot;var CSPREFIX='${CS_PRIX}' ; var COORDSVCNAME='${COORD_SVC_NAME}' ;
			 &quot; -f &quot;${testcase.path}/libs/func.js ${commlib.option} ,${test.case.fullname}&quot;" />

		<property name="sdb.cmd.beforeUsecase" value="-e &quot; var COORDSVCNAME='${COORD_SVC_NAME}' ;&quot; -f &quot;${testcase.path}/libs/func.js ${commlib.option} ,${testcase.path}/libs/before_usecase.js&quot;" />
		<property name="sdb.cmd.afterUsecase" value="-e &quot; var COORDSVCNAME='${COORD_SVC_NAME}' ;&quot; -f &quot;${testcase.path}/libs/func.js ${commlib.option} ,${testcase.path}/libs/after_usecase.js&quot;" />
		
		<sdbProperty name="testBeginStr" value="begin test,file is ${test.case.fullname}" />
		<sdbProperty name="testEndStr" value="over test,file is ${test.case.fullname}" />
		
		<exec executable="${sdb.fullname}" dir="" timeout="300000">
		  <arg line=" -s &quot; db = new Sdb('localhost',50000);db.msg('${testBeginStr}');db.close(); &quot;" />
		</exec>

		<echo message="Exec:${sdb.fullname} ${sdb.cmd.beforeUsecase}" />
		<echo message="Exec:${sdb.fullname} ${sdb.cmd.argument}" />
		<echo message="Exec:${sdb.fullname} ${sdb.cmd.afterUsecase}" />

		<exec executable="${sdb.fullname}" dir="" timeout="1200000" outputproperty="screen.output" errorproperty="error.output" resultproperty="beforeUsecase.ret.code">
			<arg line="${sdb.cmd.beforeUsecase}" />
		</exec>

		<exec executable="${sdb.fullname}" dir="" timeout="1200000" outputproperty="screen.output" errorproperty="error.output" resultproperty="ret.code">
			<arg line="${sdb.cmd.argument}" />
		</exec>

		<exec executable="${sdb.fullname}" dir="" timeout="1200000" outputproperty="screen.output" errorproperty="error.output" resultproperty="afterUsecase.ret.code">
			<arg line="${sdb.cmd.afterUsecase}" />
		</exec>

		

		<echo message="the result = ${ret.code} after exec ${test.case.fullname} testcase." />
		<exec executable="${sdb.fullname}" dir="" timeout="300000">
			<arg line=" -s &quot; db = new Sdb('localhost',50000);db.msg('${testEndStr}');db.close(); &quot;" />
		</exec>

		<if>
			<not>
				<equals arg1="${ret.code}" arg2="0" />
			</not>
			<then>
				
				<trycatch>
					<try>

				 <if>
					<equals arg1="${to.copy.test.log}" arg2="true" />
					<then>
						<echo message="to.copy.test.log is true , then copy all test log to ${save.testLog.hostname}:${save.testLog.dir}"/>
						
						<tstamp>
							<format property="current.time.log" pattern="MM-dd-hh.mm.ss" />
						</tstamp>
						<echo>mkdir ${test.machine.deploy.path}/${host.NAME}-${parallel.num}-${current.time.log}</echo>
						<mkdir dir="${test.machine.deploy.path}/${host.NAME}-${parallel.num}-${current.time.log}" />
						<if>
							<not>
							<equals arg1="${ret.code.forShards}" arg2="0" />
							</not>
							<then>
								<!--statealong mode-->
								<sdbCopyAndTar fileHostName="LOCAL" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.machine.deploy.path}/${host.NAME}-${parallel.num}-${current.time.log}" />
							</then>
							<else>
								<sdbCopyAndTar fileHostName="${test.machine.no1.basic}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.machine.deploy.path}/${host.NAME}-${parallel.num}-${current.time.log}" />
								<sdbCopyAndTar fileHostName="${test.machine.no2.basic}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.machine.deploy.path}/${host.NAME}-${parallel.num}-${current.time.log}" />
								<sdbCopyAndTar fileHostName="${test.machine.no3.basic}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.machine.deploy.path}/${host.NAME}-${parallel.num}-${current.time.log}" />
							</else>
						</if>
						<tar basedir="${test.machine.deploy.path}" 
						destfile="${test.machine.deploy.path}/${host.NAME}-${parallel.num}-${current.time.log}.tar.gz" 
						compression="gzip" includes="${host.NAME}-${parallel.num}-${current.time.log}/**" />
						<stafTools workHost="${host.NAME}"
						fileName="${test.machine.deploy.path}/${host.NAME}-${parallel.num}-${current.time.log}.tar.gz"
						workType="copy"
						toHost="${save.testLog.hostname}"
						workDir="${test.machine.deploy.path}" 
						saveDir="${save.testLog.dir}"
						  />
						<sdbProperty name="delete.diaglogFile" value="dir=$(find /opt/sequoiadb/database -name diaglog); for d in $dir ; do echo rm -f $d/* ; rm -f $d/* ; done" />
						<if>
							<not>
							<equals arg1="${ret.code.forShards}" arg2="0" />
							</not>
							<then>
								<!--standalone mode-->
								<stafTools workType="shell" workHost="LOCAL" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="false" />
							</then>
							<else>
								<stafTools workType="shell" workHost="${test.machine.no1.basic}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="false" />
								<stafTools workType="shell" workHost="${test.machine.no2.basic}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="false" />
								<stafTools workType="shell" workHost="${test.machine.no3.basic}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="false" />
							</else>
						</if>
						<echo>rm -f ${test.machine.deploy.path}/${host.NAME}-${parallel.num}-${current.time.log}</echo>
						<delete file="${test.machine.deploy.path}/${host.NAME}-${parallel.num}-${current.time.log}.tar.gz" failonerror="false" />
						<delete dir="${test.machine.deploy.path}/${host.NAME}-${parallel.num}-${current.time.log}" failonerror="false"/>
					</then>
				 </if>
				 </try>
					<catch>
						<echo>copy log for download code fail</echo>
					</catch>
				  <finally>
				  	
				  	<if>
			        	<not>
			        		<equals arg1="${allPrepare.ret.code}" arg2="0" />
			        	</not>
			        	<then>
			        		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" append="true" message="The allPrepare.ret.code.js failed..." />
			        	</then>
				  	</if>
				  	<if>
			        	<not>
			        		<equals arg1="${allClean.ret.code}" arg2="0" />
			        	</not>
			        	<then>
			        		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" append="true" message="The allClean.js failed..." />
			        	</then>
				  	</if>
				  	<if>
			        	<not>
			        		<equals arg1="${beforeUsecase.ret.code}" arg2="0" />
			        	</not>
			        	<then>
			        		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" append="true" message="The before_usecase.js failed..." />
			        	</then>
				  	</if>
				  	<if>
				  		<not>
				  			<equals arg1="${afterUsecase.ret.code}" arg2="0" />
				  		</not>
				  		<then>
			        		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" append="true" message="The after_usecase.js failed..." />		
				  		</then>
				  	</if>
				  	
				<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" append="true" message="&lt;failure 
					type=&quot;junit.framework.AssertionFailedError&quot;&gt;&#10;&lt;![CDATA[command= ${sdb.fullname} ${sdb.cmd.argument}; 
					return code=${ret.code}; error message=${error.output} &#10; screen=&#10; ${screen.output}&#10;&#10;
					testBeginStr=${testBeginStr} &#10;
					testEndStr=${testEndStr} &#10;
					db.listReplicaGroups() : &#10;
					${db.RG.info} &#10;&#10;
					download the test log :&#10;
					${URL.download.pre}/${host.NAME}-${parallel.num}-${current.time.log}.tar.gz]]&gt;&#10;
					&lt;/failure&gt;&#10;" />
					
						<sdbHaveMaster waitTime="10" propertyName="haveMaster" groupName="1" hostName="localhost" failonerror="false" />
						<echo message="${haveMaster}" />
						<if>
							<equals arg1="${haveMaster}" arg2="true"/>
							<then>
								<echo message="haveMaster is true"/>
								<sdbClearEnvCS hostName="localhost" port="50000" csprefix="${CS_PRIX}"/>
							</then>
							<else>
								<echo message="test is failed , CS_PRIX is ${CS_PRIX} , but when drop the cs , there are no catalog master node" />
							</else>
						</if>
					
					</finally>
				</trycatch>
			</then>
			<else>
			
			</else>
		</if>
		<sdbHaveMaster waitTime="10" propertyName="haveMaster" groupName="1" hostName="localhost"/>
			<echo message="${haveMaster}" />
			<if>
				<equals arg1="${haveMaster}" arg2="true"/>
				<then>
					<echo message="haveMaster is true"/>
					<sdbClearEnvCS hostName="localhost" port="50000" csprefix="${CS_PRIX}"/>
				</then>
				<else>
					<echo message="test is failed , CS_PRIX is ${CS_PRIX} , but when drop the cs , there are no catalog master node" />
				</else>
			</if>
		
		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" append="true" message="&lt;/testcase&gt;&#10;" />
		
		<tstamp>
			<format property="testcase.end.time" pattern="yyyy-MM-dd-hh.mm.ss" />
		</tstamp>
		<echo message="This testcase end time is ${testcase.end.time}"/>
	</target>
</project>