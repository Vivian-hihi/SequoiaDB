<!--@param ${testcase.path}: The path where test case direcotry.-->
<!--@param ${install.path}: The path where sequoiadb installed.-->
<!--@param ${antTask.jar.path}: The antTask.jar's path.-->
<!--@param ${reports.path}: The path where test case direcotry.-->
<!--@param ${test.package.name}: The name of test package name,.-->
<!--@param ${parallel.num}:  The parallel number when parallel in same host.-->
<!--@param ${excludes.dir.patterns}: A comma- or space-sparated list of patterns of directories that must be excluded.-->
<!--@param ${to.copy.test.log}: If it is true ,then copy the test log for everyone to down them , default is true-->
<!--@param ${save.testLog.hostname} : If ${to.copy.test.log} is true ,then copy the tar.gz to ${save.testLog.hostname}-->
<!--@param ${sace.testLog.dir}:If ${to.copy.test.log} is true, then copy the tar.gz to ${save.testLog.dir}-->
<project name="test-basic-testcases" default="test-basic-testcases">

	<target name="clean-test-reports" depends="">
		<echo message="Begin to clean test result reports..." />
		<delete dir="${testcase.path}/reports" />
		<echo message="Clean deploy result reports compeleted." />
	</target>
	
	 <property name="STAF.PATH" value="/usr/local/staf" />
	 <property name="to.copy.test.log" value="true"/>
	 <property name="save.testLog.hostname" value="192.168.30.184" />
	 <property name="save.testLog.dir" value="/opt/jetty/webapps/root" />
	 
	<taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
		<classpath>
			<fileset dir="${antTask.jar.path}" includes="*.jar" />
			<pathelement location="${STAF.PATH}/lib/JSTAF.jar" />
			<pathelement location="${STAF.PATH}/samples/demo/STAFDemo.jar" />
		</classpath>
	</taskdef>

	<property name="excludes.dir.patterns" value="" />

	<target name="test-basic-testcases" depends="clean-test-reports">
		<echo message="Begin test basic testcases..." />

		<taskdef resource="net/sf/antcontrib/antlib.xml">
			<classpath>
				<pathelement location="/usr/share/java/ant-contrib.jar" />
			</classpath>
		</taskdef>

		<mkdir dir="${reports.path}" />
		<tstamp />
		<echo message="perform the base-bussiness testcases,with testcase.path=${testcase.path}" />
		<chmod file="${install.path}/sequoiadb/bin/sdb" perm="u+x" />

		<foreach target="test-one-suite" param="test.suite.fullname">
			<path>
				<dirset dir="${testcase.path}/js" excludes="${excludes.dir.patterns}" />
			</path>
			<!--fileset dir="${testcase.path}js">
				<exclude name="${excludes.dir.patterns}" />
				<exclude name="procedures" />
			</fileset-->
			<param name="testcase.path" value="${testcase.path}" />
			<param name="sdb.fullname" value="${install.path}/sequoiadb/bin/sdb" />
		</foreach>
	</target>

	<target name="test-one-suite" depends="">

		<basename property="test.suite.name" file="${test.suite.fullname}" />
		<hostinfo prefix="host" />

		<property name="test.suite.class.name" value="com.sequoiadb.testcases-js.${test.package.name}.${host.NAME}-${parallel.num}-${test.suite.name}" />
    <echo message="now test ${test.suite.name} suite file" />
		<tstamp>
			<format property="current.time" pattern="MM-dd-hh.mm.ss" />
		</tstamp>

		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" message="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot; ?&gt;&#10;
							            &lt;testsuite errors=&quot;0&quot; failures=&quot;0&quot; hostname=&quot;${host.NAME}&quot; name=&quot;${test.suite.class.name}&quot; tests=&quot;1&quot; time=&quot;0.55&quot; timestamp=&quot;${current.time}&quot;&gt;&#10;" />

		<foreach target="test-one-case" param="test.case.fullname">
			<fileset dir="${test.suite.fullname}" includes="*.js" />
			<param name="testcase.path" value="${testcase.path}" />
			<param name="sdb.fullname" value="${sdb.fullname}" />
			<param name="host.NAME" value="${host.NAME}" />
			<param name="parallel.num" value="${parallel.num}" />
			<param name="test.suite.class.name" value="${test.suite.class.name}" />
		</foreach>

		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" message="
								&lt;system-out&gt;&#10;
								&lt;![CDATA[${on screen}]]&gt;&#10;
								&lt;/system-out&gt;&#10;
								&lt;/testsuite&gt;&#10;" append="true" />

	</target>


	<target name="test-one-case" depends="">
		<basename property="test.case.name" file="${test.case.fullname}" suffix=".js" />
		
		<exec executable="sed">
			<arg line="-i 's/^\xEF\xBB\xBF//g'  ${test.case.fullname}"/>
		</exec>
		
		<exec executable="sed">
			<arg line="-i 's/^\xEF\xBB\xBF//g'  ${testcase.path}/libs/func.js"/>
		</exec>
    <echo message="now test ${test.case.name}.js file" />
		<!-- Add function to js test case -->
		<loadfile property="js.context" srcFile="${test.case.fullname}" encoding="UTF-8" />
		<loadfile property="js.functions.context" srcFile="${testcase.path}/libs/func.js" encoding="UTF-8"/>

		<echo message="${js.functions.context}" file="${test.case.fullname}.${parallel.num}" encoding="UTF-8" />
		<echo message="${js.context}" file="${test.case.fullname}.${parallel.num}" append="true" encoding="UTF-8" />
		<!-- end -->

		<tstamp>
			<format property="current.time" pattern="MM-dd-hh.mm.ss" />
		</tstamp>

		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" append="true" message="&lt;testcase classname=&quot;${test.suite.class.name}&quot; name=&quot;${test.case.name}&quot; time=&quot;${current.time}&quot;&gt;&#10;" />
    
    <tstamp>
    	<format property="start_time" pattern="mmss" offset="-5" unit="second" />
    </tstamp>
    
    
    <property name="CS_PRIX_TMP" value="${host.NAME}${parallel.num}${test.case.name}"/>
    <!--script language="javascript"><![CDATA[
       var before = project.getProperty("CS_PRIX_TMP");
       before = before.replaceAll("_", "");
       before = before.replaceAll("-", "");
       project.setProperty("CS_PRIX", before);
    ]]></script-->
    
    <!--set the property name="CS_PRIX" value="~~"-->
    <sdbprefix prefixName="CS_PRIX">
    	 <param name="${host.NAME}" value="${host.NAME}" />
    	 <param name="${parallel.num}" value="${parallel.num}" />
    	 <param name="${test.case.name}" value="${test.case.name}" />
    </sdbprefix>
    
		<!--property name="CS_PRIX" value="${host.NAME}${start_time}${test.case.name}" /-->
		<!--property name="CS_PRIX" value="${start_time}" /-->
		
		
		<!--propertyregex property="CS_PRIX_TMP" input="${host.NAME}${parallel.num}${test.case.name}" regexp="-" replace="" />
		<propertyregex property="CS_PRIX" input="${CS_PRIX_TMP}" regexp="_" replace="" /-->

		<property name="sdb.cmd.argument" value="-e &quot;var CSPREFIX='${CS_PRIX}'&quot; -f ${test.case.fullname}.${parallel.num}" />
		
		<echo message="Exec:${sdb.fullname} ${sdb.cmd.argument}" />
		<exec executable="${sdb.fullname}" dir="" timeout="1200000" outputproperty="screen.output" errorproperty="error.output" resultproperty="ret.code">
			<arg line="${sdb.cmd.argument}" />
		</exec>

		<echo message="the result = ${ret.code} after exec ant testcase." />
		<if>
			<not>
				<equals arg1="${ret.code}" arg2="0" />
			</not>
			<then>
				<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" append="true" message="&lt;failure type=&quot;junit.framework.AssertionFailedError&quot;&gt;&#10;&lt;![CDATA[command= ${sdb.fullname} ${sdb.cmd.argument}; return code=${ret.code}; time=${current.time}; error message=${error.output} &#10; screen=&#10; ${screen.output}]]&gt;&#10;
					&lt;/failure&gt;&#10;" />
					
				<if>
					<equals arg1="${to.copy.test.log} arg2="true" />
					<then>
						<echo message="to.copy.test.log is true , then copy all test log to ${save.testLog.hostname}:${sace.testLog.dir}"/>
					</then>
				</if>
					
				<!--sdbHaveMaster waitTime="20" propertyName="haveMaster" groupName="1" />
				<if>
					<equals arg1="${haveMaster}" arg2="true" />
					<then>
						<echo message="CS_PRIX is ${CS_PRIX}" />
						<sdbClearEnvCS hostName="localhost" port="50000" csprefix="${CS_PRIX}"/>
					</then>
				</if-->
				
				<sdbHaveMaster waitTime="10" propertyName="haveMaster" groupName="1" hostName="localhost"/>
				<echo message="${haveMaster}" />
				<if>
					<equals arg1="${haveMaster}" arg2="true"/>
					<then>
						<echo message="haveMaster is true"/>
						<sdbClearEnvCS hostName="localhost" port="50000" csprefix="${CS_PRIX}"/>
					</then>
				</if>
				
			</then>
		</if>

		<echo file="${reports.path}/TEST-${test.suite.class.name}.xml" append="true" message="&lt;/testcase&gt;&#10;" />
  
	</target>
</project>