<project name="Exec-SDV-Testcases" default="Exec-SDV-Testcases">
   <hostinfo prefix="host" />  
   <property file="${ci.properties.file}" />
   <property name="bin.dir" value="${install.path}/sequoiadb/bin" />
   <taskdef resource="com/sequoiadb/ant/ant-sdbtasks.xml">
      <classpath>
         <fileset dir="${antTask.jar.path}" includes="*.jar" />
      </classpath>
   </taskdef>

   <target name="Init" depends="">
      <echo message="yt">
      <echo message="Begin to clean report path: ${reports.path}" />
      <delete dir="${reports.path}" failonerror="false" />
      <mkdir dir="${reports.path}" />
           
      <exec command="/bin/sh -c 'eval echo $$$' " dir="" timeout="900000" outputproperty="pid" />
      <sdbprefix prefixName="CHANGEDSTRING">
         <param name="${begin.flag}" value="SDV" />
         <param name="${host.NAME}" value="${host.NAME}" />
         <param name="${pid}" value="${pid}" />
         <param name="${parallel.num}" value="${parallel.num}" />
         <param name="${end.flag}" value="END" />
      </sdbprefix>
      <echo message="Generate CHANGEDSTRING: ${CHANGEDSTRING}" />     
   </target>

   <target name="Exec-SDV-Testcases" depends="Init">
      <echo message="begin to test sdv testcases, testcase path: ${testcase.path}" />
      <tstamp>
         <format property="test.begin.time" pattern="yyyy-MM-dd-hh.mm.ss a" />
      </tstamp>
      
      <!-- main -->
      <antcall target="Exec-allprepare" inheritAll="true"/> 
        
      <foreach target="test-one-suite" param="test.suite.fullname" >
         <path>
            <dirset dir="${testcase.path}/js" includes="${includes.dir.patterns}" 
                                              excludes="${excludes.dir.patterns}" />
         </path>
         <param name="includes.case.patterns" value="*.js" />
         <param name="excludes.case.patterns" value="commlib.js" />
         <param name="CHANGEDSTRING" value="${CHANGEDSTRING}" />
      </foreach>  
                
      <antcall target="Exec-allclean" inheritAll="true"/> 
      <!-- end main -->
           
      <tstamp>
         <format property="test.end.time" pattern="yyyy-MM-dd-hh.mm.ss a" />
      </tstamp>
      <sdbTime beginTime="${test.begin.time}" endTime="${test.end.time}" output="test.total.time" />
      <echo message="**************************************************************************************************************************************************************" />
      <echo level="info" message="&lt;${test.type} test&gt; begin at ${test.begin.time}, end at ${test.end.time},total spends ${test.total.time}s." />
      <echo message="**************************************************************************************************************************************************************" />          
   </target> 
      
   <target name="test-one-suite" depends="">
      <basename property="test.suite.name" file="${test.suite.fullname}" />
      <basename property="deploy.mode" file="${deploy.case.fullname}" suffix=".xml" />
      <property name="testsuite.class.name" value="testcases-${test.type}.${deploy.mode}-${host.NAME}-${parallel.num}-${test.suite.name}" />            
      <property name="testsuite.report.name" value="TEST-${testsuite.class.name}" />      
      <tstamp>
         <format property="testsuite.begin.time" pattern="yyyy-MM-dd-hh.mm.ss a" />
      </tstamp>

      <echo message="Now testsuite ${test.suite.name} ..." />
      
      <echo file="${reports.path}/${testsuite.report.name}.xml" 
            message="&lt;?xml version=&quot;1.0&quot; encoding=&quot;UTF-8&quot; ?&gt;&#10;" />
      <echo file="${reports.path}/${testsuite.report.name}.xml" 
            message="&lt;testsuite name=&quot;${test.suite.name}&quot; type=&quot;${test.type}&quot; deploy=&quot;${deploy.mode}&quot; hostname=&quot;${host.NAME}&quot; tests=&quot;1&quot; failure=&quot;0&quot;&gt;&#10;" />

      <available property="commlib.exist" file="${test.suite.fullname}/commlib.js" />
      <if>
         <isset property="commlib.exist" />
         <then>
            <sdbProperty name="commlib.option" value="${test.suite.fullname}/commlib.js" />
         </then>
         <else>
            <sdbProperty name="commlib.option" value="" />
         </else>
      </if>
     
      <foreach target="test-one-case" param="testcase.fullname">
         <fileset dir="${test.suite.fullname}" includes="${includes.case.patterns}" 
                                               excludes="${excludes.case.patterns}" /> 
         <param name="testsuite.report.name" value="${testsuite.report.name}" /> 
         <param name="testsuite.class.name" value="${testsuite.class.name}" />                                           
      </foreach>

      <echo file="${reports.path}/${testsuite.report.name}.xml" 
            message="&lt;/testsuite&gt;&#10;" append="true" />
      
      <tstamp>
         <format property="testsuite.end.time" pattern="yyyy-MM-dd-hh.mm.ss a" />
      </tstamp>      
      <sdbTime beginTime="${testsuite.begin.time}" endTime="${testsuite.end.time}" output="testsuite.total.time" />
      <echo message="**************************************************************************************************************************************************************" />
      <echo level="info" message="The testsuite begin at &lt;${testsuite.begin.time}&gt;, end at &lt;${testsuite.end.time}&gt;,total spending ${testsuite.total.time}s." />
      <echo message="testsuite: ${test.suite.name}" />      
      <echo message="**************************************************************************************************************************************************************" />     
   </target>

   <target name="test-one-case" depends="">
      <exec executable="${bin.dir}/sdb" timeout="100000" dir="" outputproperty="SDB.VERSION.INFO" 
                                                                resultproperty="ret.sdb.version.exec">
         <arg line=" --version" />
      </exec>
      <if>
         <equals arg1="${os.arch}" arg2="ppc64" />
         <then>
            <property name="URL.download.pre" value="http://192.168.30.150:8080" />
         </then>
         <else>
            <property name="URL.download.pre" value="http://192.168.30.184:8080" />
         </else>
      </if>

      <tstamp>
         <format property="testcase.begin.time" pattern="yyyy-MM-dd-hh.mm.ss a" />
      </tstamp>

      <basename property="testcase.name" file="${testcase.fullname}" suffix=".js" />
      <exec executable="sed">
         <arg line="-i 's/^\xEF\xBB\xBF//g'  ${testcase.fullname}"/>
      </exec>
      <exec executable="sed">
         <arg line="-i 's/^\xEF\xBB\xBF//g'  ${testcase.path}/libs/func.js"/>
      </exec>
      <echo message="Now testcase ${testcase.name}.js begin with ${testcase.begin.time}"/>

      <property name="before.testcase.cmd" value=" -e &quot;var CHANGEDPREFIX='${CHANGEDSTRING}'; var COORDSVCNAME='${coord.service.port}' ;&quot; -f &quot;${testcase.path}/libs/func.js,${testcase.path}/libs/before_usecase.js&quot;" />
      <echo message="Exec: sdb${before.testcase.cmd}" />
      <exec executable="${bin.dir}/sdb"             
            outputproperty="before.testcase.output" 
            resultproperty="before.testcase.retcode"
            timeout="900000" >
         <arg line="${before.testcase.cmd}" />
      </exec>
      <echo message="${before.testcase.output}" />

      <property name="testcase.cmd" value=" -e &quot;var CHANGEDPREFIX='${CHANGEDSTRING}';var COORDSVCNAME='${coord.service.port}';&quot; -f &quot;${testcase.path}/libs/func.js,${commlib.option},${testcase.fullname}&quot;" />
      <echo message="Exec: sdb${testcase.cmd}" />
      <exec executable="${bin.dir}/sdb"
            outputproperty="testcase.output" 
            resultproperty="testcase.retcode"
            timeout="600000000" >
         <arg line="${testcase.cmd}" />
      </exec>
      <echo message="${testcase.output}" />

      <property name="after.testcase.cmd" value=" -e &quot;var CHANGEDPREFIX='${CHANGEDSTRING}'; var COORDSVCNAME='${coord.service.port}' ;&quot; -f &quot;${testcase.path}/libs/func.js,${testcase.path}/libs/after_usecase.js&quot;" />
      <echo message="Exec: sdb${after.testcase.cmd}" />
      <exec executable="${bin.dir}/sdb"
            outputproperty="after.testcase.output" 
            resultproperty="after.testcase.retcode"
            timeout="900000" >
         <arg line="${after.testcase.cmd}" />
      </exec>
      <echo message="${after.testcase.output}" />

      <tstamp>
         <format property="testcase.end.time" pattern="yyyy-MM-dd-hh.mm.ss a" />
      </tstamp>
      <sdbTime beginTime="${testcase.begin.time}" endTime="${testcase.end.time}" output="testcase.cost.time" />
      <if>
         <equals arg1="${testcase.retcode}" arg2="0" />
         <then>           
            <echo message="The result code is ${testcase.retcode} and it's succ ..." />
            <echo message="The testcase ${testcase.name}.js end with ${testcase.end.time} and cost ${testcase.cost.time}s in total..." />
            <echo file="${reports.path}/${testsuite.report.name}.xml" append="true" 
                  message="&lt;testcase classname=&quot;${testsuite.class.name}&quot; name=&quot;${testcase.name}&quot; begin_time=&quot;${testcase.begin.time}&quot; end_time=&quot;${testcase.end.time}&quot; time=&quot;${testcase.cost.time}&quot; path=&quot;${testcase.path}&quot; status=&quot;succ&quot;&gt;&#10;&lt;/testcase&gt;&#10;" />         
        </then>
         <else>
            <echo message="The result code is ${testcase.retcode} and it's fail ..." />
            <echo message="The testcase ${testcase.name}.js end with ${testcase.end.time} and cost ${testcase.cost.time}s in total..." />

            <echo file="${reports.path}/${testsuite.report.name}.xml" append="true" 
                  message="&lt;testcase classname=&quot;${testsuite.class.name}&quot; name=&quot;${testcase.name}&quot; begin_time=&quot;${testcase.begin.time}&quot; end_time=&quot;${testcase.end.time}&quot; time=&quot;${testcase.cost.time}&quot; path=&quot;${testcase.path}&quot; status=&quot;fail&quot;&gt;&#10;&lt;failure&gt;&#10;&lt;![CDATA[&#10;COMMAND : ${testcase.cmd}&#10;RETURNCODE : ${testcase.retcode}&#10;SDB VERSION : &#10; ${SDB.VERSION.INFO}&#10;&#10;ERROR MESSAGE : &#10;${testcase.output}&#10;&#10;Download the test log :&#10;${URL.download.pre}/${test.log}.tar.gz]]&gt;&#10;&lt;/failure&gt;&#10;&lt;/testcase&gt;&#10;" />                             
         </else>
      </if>           
   </target>



   <target name="Exec-allprepare" >
      <property name="cmd" 
                value=" -e &quot;var CHANGEDPREFIX='${CHANGEDSTRING}';var COORDSVCNAME=${coord.service.port};&quot; -f ${testcase.path}/libs/func.js,${testcase.path}/libs/all_prepare.js" />
      <echo message="exec: sdb ${cmd}" />    
      <exec executable="${bin.dir}/sdb" dir="" timeout="100000" outputproperty="output" >
         <arg line="${cmd}" />
      </exec>
      <echo message="${output}" />
   </target>  
   
   <target name="Exec-allclean" >
      <property name="cmd" 
                value=" -e &quot;var CHANGEDPREFIX='${CHANGEDSTRING}';var COORDSVCNAME=${coord.service.port};&quot; -f ${testcase.path}/libs/func.js,${testcase.path}/libs/all_clean.js" />
      <echo message="exec: sdb ${cmd}" />      
      <exec executable="${bin.dir}/sdb" dir="" timeout="100000" outputproperty="output" >
         <arg line="${cmd}" />
      </exec>
      <echo message="${output}" />
   </target> 
   
</project>
