<!--@param ${deploy.file.fullname} : The test deploy tar full file name -->
<!--@param ${deploy.host.name} :  The host name for deploy test scripts and install software-->

<!-- hostname:jenkins.master.ip -->
<!-- depends:${deploy.case.fullname} -->
<!-- call:install-test-in-host.xml -->

<project name="deploy-test-in-host" default="Deploy-Test-In-Host">
	<property file="ci.test.properties" />
	<target name="Clean-Deploy-In-Host" depends="">
		<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="rm -rf ${test.machine.deploy.path}" trust="true" failonerror="false" />
		<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="mkdir ${test.machine.deploy.path}" trust="true" failonerror="true" />
<!-- 		<stafTools workHost="${deploy.host.name}" workType="delete" fileName="${test.machine.deploy.path}" failonerror="true" />
		<stafTools workHost="${deploy.host.name}" workType="create" fileName="${test.machine.deploy.path}" failonerror="true"/> -->
	</target>
	<target name="Deploy-Test-In-Host" depends="Clean-Deploy-In-Host">
		<basename property="test.deploy.name" file="${deploy.file.fullname}" suffix=".gz" />
		<echo message="test.deploy.name = ${test.deploy.name}" />
		<scp file="${deploy.file.fullname}" todir="${remote.user}:${remote.password}@${deploy.host.name}:${test.machine.deploy.path}/${test.deploy.name}.gz" trust="true" failonerror="true" />
		<scp file="${basedir}/install-test-in-host.xml" todir="${remote.user}:${remote.password}@${deploy.host.name}:${test.machine.deploy.path}/install-test-in-host.xml" trust="true" failonerror="true" />
		<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="ant -l ${test.machine.deploy.path}/install-test-in-host.log -f ${test.machine.deploy.path}/install-test-in-host.xml -Dtest.basedir=${test.machine.deploy.path} -Ddeploy.tar.file.name=deploy.tar.gz" trust="true" failonerror="false" />
		<echo message="###############################################################################################################################" />
		<echo message="hostname=${deploy.host.name}:Deploy" />
		<sshexec host="${deploy.host.name}" username="${remote.user}" password="${remote.password}" command="cat ${test.machine.deploy.path}/install-test-in-host.log" trust="true" failonerror="true" />
		<echo message="###############################################################################################################################" />

		<!-- <stafTools workType="copy" workHost="LOCAL" fileName="${deploy.file.fullname}" saveDir="${test.machine.deploy.path}" toHost="${deploy.host.name}" failonerror="true"/>
		<stafTools workType="copy" workHost="LOCAL" fileName="${basedir}/install-test-in-host.xml" saveDir="${test.machine.deploy.path}" toHost="${deploy.host.name}" failonerror="true"/>
    	<stafTools workType="shell" workHost="${deploy.host.name}" workDir="${test.machine.deploy.path}" common="ant -l ${test.machine.deploy.path}/install-test-in-host.log -f ${test.machine.deploy.path}/install-test-in-host.xml -Dtest.basedir=${test.machine.deploy.path} -Ddeploy.tar.file.name=deploy.tar.gz" failonerror="true"/>
		<stafTools workType="get" workHost="${deploy.host.name}" fileName="${test.machine.deploy.path}/install-test-in-host.log" failonerror="true"/> -->    
	</target>
</project>

