	<target name="deploySoftwareInHost">
        <property name="addrTemp" value="tmp" />
        <for list="${machineList}" param="hostname">
            <sequential>
                <var name="addrTemp" value="@{hostname}:11803,${addrTemp}" />
           </sequential>
        </for>
        <basename property="catalog.addrs" file="${addrTemp}" suffix=",tmp" />
        <ant antfile="deploy-software-in-host.xml" dir="." inheritAll="false" output="${hostname}">
			<property name="install.package.fullname" value="${install.package.fullname}" />
			<property name="deploy.host.name" value="${hostname}" />
			<property name="is.standalone.mode" value="false" />
			<property name="is.coord.master" value="true"/>
			<property name="catalog.addrs" value="${catalog.addrs}" />
		</ant>
    </target>

