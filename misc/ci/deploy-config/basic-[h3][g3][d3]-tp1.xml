	<target name="Deploy-Software" depends="">
		<if>
		   	<equals arg1="${os.arch}" arg2="amd64" />
			<then>
			    <property name="fap.value" value="fapmongo" />
			</then>
			<else>
			    <property name="fap.value" value="" />
			</else>
		</if>
		<if>
		   	<equals arg1="${isTrunk}" arg2="true" />
			<then>
			    <property name="machineList" value="trunk_machine" />
			</then>
			<else>
			    <property name="machineList" value="branch_machine" />
			</else>
		</if>

		<for list="${machineList}" param="hostname">
            <sequential>
                <antcall target="deploySoftwareInHost" inheritAll="true" >
                    <param name="hostname" value="@{hostname}" />
                    <param name="machineList" value="${machineList}" />
                </antcall>
            </sequential>
        </for>

