        				<node host="@{hostname}" baseport="${cata.service.port}" dbpath="${install.path}/sequoiadb/database/cata/${cata.service.port}">
							<confitem name="diaglevel" value="5" />
							<confitem name="transactionon" value="true" />
							<confitem name="sharingbreak" value="30000" />
							<confitem name="fap" value="${fap.value}" />
							<confitem name="optimeout" value="60000" />
						</node>
					</sequential>
				</for>
    		</catagroup>
    	</sdbdeploy>
            

