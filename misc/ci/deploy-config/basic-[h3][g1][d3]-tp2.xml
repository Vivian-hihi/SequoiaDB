						<echo message="The copy.test.log is true , then copy all test log to ${save.testLog.hostname}:${save.testLog.dir}"/>
						<tstamp>
							<format property="current.time.log" pattern="yyyy-MM-dd-hh.mm.ss a" />
						</tstamp>

						<property name="test.log.path" value="${test.reports.path}/${test.environment}-${DEPLOY_WILDCARD}-${host.NAME}-${current.time.log}-${BUILD_NUMBER}" />
						<echo message="Mkdir ${test.log.path}" />
						<mkdir dir="${test.log.path}" />

						<echo message="It's the cluster mod..." />
						<if>
						   	<equals arg1="${os.arch}" arg2="amd64" />
							<then>
								<sdbCopyAndTar fileHostName="${test_machine_no1}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no2}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no3}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no4}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no5}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no6}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
							</then>
							<else>
								<sdbCopyAndTar fileHostName="${test_machine_no1}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no2}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no3}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
							</else>
						</if>
						
						<echo message="Tar ${test.log.path}.tar.gz..." />
						<tar basedir="${test.reports.path}" destfile="${test.log.path}.tar.gz" compression="gzip" includes="**/*" />

						<stafTools workType="copy" workHost="${host.NAME}" fileName="${test.log.path}.tar.gz"  toHost="${save.testLog.hostname}"  saveDir="${save.testLog.dir}" failonerror="true"/>
						<sdbProperty name="delete.diaglogFile" value="dir=$(find /opt/sequoiadb/database -name diaglog); for d in $dir ; do echo rm -f $d/* ; rm -f $d/* ; done" />

						<if>
						   	<equals arg1="${os.arch}" arg2="amd64" />
							<then>
								<stafTools workType="shell" workHost="${test_machine_no1}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="true"/>
								<stafTools workType="shell" workHost="${test_machine_no2}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="true"/>
								<stafTools workType="shell" workHost="${test_machine_no3}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="true"/>
								<stafTools workType="shell" workHost="${test_machine_no4}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="true"/>
								<stafTools workType="shell" workHost="${test_machine_no5}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="true"/>
								<stafTools workType="shell" workHost="${test_machine_no6}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="true"/>
							</then>
							<else>
								<stafTools workType="shell" workHost="${test_machine_no1}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="true"/>
								<stafTools workType="shell" workHost="${test_machine_no2}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="true"/>
								<stafTools workType="shell" workHost="${test_machine_no3}" workDir="${install.path}/sequoiadb/database" common="${delete.diaglogFile}" failonerror="true"/>
							</else>
						</if>

						<echo message="Delete ${test.log.path}.tar.gz and ${test.log.path} dir ..." />
						<delete file="${test.log.path}.tar.gz" failonerror="false" />
						<delete dir="${test.log.path}" failonerror="false"/>
					</then>
				</if>
			</try>
			<catch>
				<echo message="copy log for download code fail" />
			</catch>
			<finally>
			</finally>
		</trycatch>
	</target>
</project>
