<!--@param ${install.package.fullname}: The install package full file name --> 
<!--@param ${ant.sdb.tasks.path}:  The path where sdb's ant tasks jar files -->
<!--@param ${deploy.case.fullname}: The file name ( .xml )this file name is -->
<!--@param ${deploy.file.fullname}: The file full path where deploy file name for test -->
<!--@param ${deploy.path}: The path where deploy direcotry before tar -->
<!--@param ${test.reports.path}: The path where test reports directory. -->
<!--@param ${WORKSPACE}: where the working space is it-->
<!--@param ${properties.dir} : where the ci.test.properties file is it -->

<project name="deploy" default="test">
  
  <taskdef resource="net/sf/antcontrib/antlib.xml">
     <classpath>
        <pathelement location="/usr/share/java/ant-contrib.jar" />
     </classpath>
  </taskdef>
  
	<target name="deploy" depends="">
		<hostinfo prefix="host" />
		<property name="properties.dir" value="${basedir}/../ci.test.properties" />
		<property file="${properties.dir}" />
		<ant antfile="deploy-software-in-host.xml" dir="." inheritAll="false">
			<property name="install.package.fullname" value="${install.package.fullname}" />
			<property name="deploy.host.name" value="${test.machine.no2.basic}" />
			<property name="coord.service.port" value="${coord.service.port}" />
			<property name="is.standalone.mode" value="true" />
		</ant>

		
	</target>

	<target name="test" depends="">
		<parallel>
			<ant antfile="deploy-test-in-host.xml" dir="." inheritAll="false">
				<property name="deploy.file.fullname" value="${deploy.file.fullname}" />
				<property name="deploy.host.name" value="${test.machine.no2.basic}" />
			</ant>
		</parallel>
		
		<basename property="antFileName" file="${ant.file}" suffix=".xml" />
		<property name="test-type-list" value="basic,driver-java,driver-C,driver-CPP,driver-php" />
		<!--property name="test-type-list" value="driver-php" /-->
		<for list="${test-type-list}" param="test-type">
			<sequential>
				<ant antfile="${WORKSPACE}/sequoiadb/misc/ci/test-type.xml" dir="." inheritAll="false">
					<property name="test.machine.deploy.path" value="${test.machine.deploy.path}" />
					<property name="install.path" value="${install.path}" />
					<property name="deploy.case.fullname" value="${deploy.case.fullname}" />
					<property name="test.reports.path" value="${test.reports.path}" />
					<property name="test-type" value="@{test-type}" />
					<property name="antFileName" value="${antFileName}" />
				</ant>
			</sequential>
		</for>
		<mkdir dir="${WORKSPACE}/${host.NAME}-copy-log/${antFileName}" />
		<sdbCopyAndTar fileHostName="${test.machine.no2.basic}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${WORKSPACE}/${host.NAME}-copy-log/${antFileName}" />
		
		
    
    <!--echo message="... test the java driver ..." />                                                                                   
		<sdbtest host="${test.machine.no2}" testscript="${test.machine.deploy.path}/deploy/exec-driver-java-test.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/drivers_testcases/java/reports" masterreports="${test.reports.path}" timeout="30m">
			<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/drivers_testcases" />
			<param name="install.path" value="${install.path}" />
			<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
		</sdbtest>
		<echo message="... test java driver is over ..." />
			
		<echo message="... test the C driver ..." />
    <property name="testCcases" value="*-*sdbConnect_with_usr*:*sdbCreateCollection1_doubtful*:*sdbCreateUsr*:*sdbListReplicaGroups*:*sdbRemoveUsr*:*sdbResetSnapshot*:*sdbSplitCollection*" />     
		<sdbtest host="${test.machine.no2}" testscript="${test.machine.deploy.path}/deploy/exec-driver-C-test.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/drivers_testcases/C/reports" masterreports="${test.reports.path}" timeout="30m">
			<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/drivers_testcases" />
			<param name="test_name" value="${testCcases}"  />
			<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
		</sdbtest>
		<echo message="... test C driver is over ..." />
		
		<echo message="... test the CPP driver ..." />		
		<property name="testCPPcases" value="*-*create*:*drop*:*insert_with_iterator*:*rename*:*split*:*createCollection_with_Sharding_and_replSize*:*resetSnapshot*:*transactionBegin*:*transactionCommit*:*transactionRollback*:*getList_SDB_LIST_GROUPS*" />
		<sdbtest host="${test.machine.no2}" testscript="${test.machine.deploy.path}/deploy/exec-driver-CPP-test.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/drivers_testcases/CPP/reports" masterreports="${test.reports.path}" timeout="30m">
			<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/drivers_testcases" />
			<param name="test_name" value="${testCPPcases}"  />
			<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
		</sdbtest>
    <echo message="... test CPP driver is over ..." />
    
    
    
    <echo message="... test the client sample test ..." />
		<sdbtest host="${test.machine.no2}" testscript="${test.machine.deploy.path}/deploy/exec-samples-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/samples_testcases/CPP/reports" masterreports="${test.reports.path}" timeout="30m">
			<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/samples_testcases" />
			<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
		</sdbtest>
    <echo message="... client sample test is over ..." />
    
    

    <echo message="... test ant-testcases ..." />
    
		<sdbtest host="${test.machine.no2}" testscript="${test.machine.deploy.path}/deploy/exec-ant-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/ant_testcases/reports" masterreports="${test.reports.path}" timeout="30m">
			<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/ant_testcases/" />
			<param name="install.path" value="${install.path}" />
		</sdbtest>
				
		<echo message="... test ant-testcases is over ..." />
    
    
    <parallel failonany="true" >
    	
	    <echo message=" ...begin to test tpcc ..." />
	    <sdbtest host="${test.machine.no2}" testscript="${test.machine.deploy.path}/deploy/exec-tpcc-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/tpcc_testcases/reports" masterreports="${test.reports.path}" timeout="30m">
				<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/sql_testcases/" />
				<param name="install.path" value="${install.path}" />
				<param name="deploy.case.fullname" value="${deploy.case.fullname}" />
				<param name="antTask.jar.path" value="${test.machine.deploy.path}/deploy/ant-sdbtasks" />
			</sdbtest>
	    <echo message=" ... tpcc test over ..." />	
    	
	    <echo message="begin to test js tests ..." />
			<sdbtest host="${test.machine.no2}" testscript="${test.machine.deploy.path}/deploy/exec-basic-testcases.xml" remotereports="${test.machine.deploy.path}/deploy/hlt/js_testcases/reports" masterreports="${test.reports.path}" timeout="30m">
				<param name="testcase.path" value="${test.machine.deploy.path}/deploy/hlt/js_testcases/" />
				<param name="install.path" value="${install.path}" />
				<param name="excludes.dir.patterns" value="vote" />
				<param name="antTask.jar.path" value="${test.machine.deploy.path}/deploy/ant-sdbtasks" />
			</sdbtest>
	    <echo message="...test js tests are over ..." />	
    	
    </parallel-->

	</target>
	
</project>