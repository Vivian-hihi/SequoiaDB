					</ant>
					<ant antfile="deploy-software-in-host.xml" dir="." inheritAll="false">
						<property name="install.package.fullname" value="${install.package.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no4}" />
						<property name="is.standalone.mode" value="true" />
						<property name="is.coord.master" value="false"/>
						<property name="catalog.addrs" value="${test_machine_no1}:11803,${test_machine_no2}:11803,${test_machine_no3}:11803" />
					</ant>
					<ant antfile="deploy-software-in-host.xml" dir="." inheritAll="false">
						<property name="install.package.fullname" value="${install.package.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no5}" />
						<property name="is.standalone.mode" value="true" />
						<property name="is.coord.master" value="false"/>
						<property name="catalog.addrs" value="${test_machine_no1}:11803,${test_machine_no2}:11803,${test_machine_no3}:11803" />
					</ant>
					<ant antfile="deploy-software-in-host.xml" dir="." inheritAll="false">
						<property name="install.package.fullname" value="${install.package.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no6}" />
						<property name="is.standalone.mode" value="true" />
						<property name="is.coord.master" value="false"/>
						<property name="catalog.addrs" value="${test_machine_no1}:11803,${test_machine_no2}:11803,${test_machine_no3}:11803" />
					</ant>
<!-- 				</parallel> -->
				<tstamp>
					<format property="install_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
				</tstamp>
				<sdbTime beginTime="${install_begintime}" endTime="${install_endtime}" output="install_time" />
				<echo message="**************************************************************************************************************************************************************" />
				<echo level="info" message="The install-software part began at &lt;${install_begintime}&gt;, end at &lt;${install_endtime}&gt;,total spending ${install_time}s." />
				<echo message="**************************************************************************************************************************************************************" />
			</then>
			<else>
				<tstamp>
					<format property="install_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
				</tstamp>
<!-- 				<parallel> -->
					<ant antfile="deploy-software-in-host.xml" dir="." inheritAll="false">
						<property name="install.package.fullname" value="${install.package.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no1}" />
						<property name="is.standalone.mode" value="true" />
						<property name="is.coord.master" value="false"/>
						<property name="catalog.addrs" value="${test_machine_no1}:11803,${test_machine_no2}:11803,${test_machine_no3}:11803" />
					</ant>
					<ant antfile="deploy-software-in-host.xml" dir="." inheritAll="false">
						<property name="install.package.fullname" value="${install.package.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no2}" />
						<property name="is.standalone.mode" value="true" />
						<property name="is.coord.master" value="false"/>
						<property name="catalog.addrs" value="${test_machine_no1}:11803,${test_machine_no2}:11803,${test_machine_no3}:11803" />
					</ant>
					<ant antfile="deploy-software-in-host.xml" dir="." inheritAll="false">
						<property name="install.package.fullname" value="${install.package.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no3}" />
						<property name="is.standalone.mode" value="true" />
						<property name="is.coord.master" value="false"/>
						<property name="catalog.addrs" value="${test_machine_no1}:11803,${test_machine_no2}:11803,${test_machine_no3}:11803" />
					</ant>
<!-- 				</parallel> -->
				<tstamp>
					<format property="install_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
				</tstamp>
				<sdbTime beginTime="${install_begintime}" endTime="${install_endtime}" output="install_time" />
				<echo message="**************************************************************************************************************************************************************" />
				<echo level="info" message="The install-software part began at &lt;${install_begintime}&gt;, end at &lt;${install_endtime}&gt;,total spending ${install_time}s." />
				<echo message="**************************************************************************************************************************************************************" />
			</else>
		</if>	
	</target>

	<target name="Standalone" depends="">
		<hostinfo prefix="host" />
		<property name="copy.test.log" value="true"/>

		<if>
		   	<equals arg1="${os.arch}" arg2="amd64" />
			<then>
				<tstamp>
					<format property="deploy_test_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
				</tstamp>
				<parallel>
					<ant antfile="deploy-test-in-host.xml" dir="." inheritAll="false">
						<property name="deploy.file.fullname" value="${deploy.file.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no1}" />
					</ant>
					<ant antfile="deploy-test-in-host.xml" dir="." inheritAll="false">
						<property name="deploy.file.fullname" value="${deploy.file.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no2}" />
					</ant>
					<ant antfile="deploy-test-in-host.xml" dir="." inheritAll="false">
						<property name="deploy.file.fullname" value="${deploy.file.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no3}" />
					</ant>
					<ant antfile="deploy-test-in-host.xml" dir="." inheritAll="false">
						<property name="deploy.file.fullname" value="${deploy.file.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no4}" />
					</ant>
					<ant antfile="deploy-test-in-host.xml" dir="." inheritAll="false">
						<property name="deploy.file.fullname" value="${deploy.file.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no5}" />
					</ant>
					<ant antfile="deploy-test-in-host.xml" dir="." inheritAll="false">
						<property name="deploy.file.fullname" value="${deploy.file.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no6}" />
					</ant>
				</parallel>
				<tstamp>
					<format property="deploy_test_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
				</tstamp>
				<sdbTime beginTime="${deploy_test_begintime}" endTime="${deploy_test_endtime}" output="deploy_test_time" />
				<echo message="**************************************************************************************************************************************************************" />
				<echo level="info" message="The deploy-software part began at &lt;${deploy_test_begintime}&gt;, end at &lt;${deploy_test_endtime}&gt;,total spending ${deploy_test_time}s." />
				<echo message="**************************************************************************************************************************************************************" />
			</then>
			<else>
				<tstamp>
					<format property="deploy_test_begintime" pattern="yyyy-MM-dd-hh.mm.ss a" />
				</tstamp>
				<parallel>
					<ant antfile="deploy-test-in-host.xml" dir="." inheritAll="false">
						<property name="deploy.file.fullname" value="${deploy.file.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no1}" />
					</ant>
					<ant antfile="deploy-test-in-host.xml" dir="." inheritAll="false">
						<property name="deploy.file.fullname" value="${deploy.file.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no2}" />
					</ant>
					<ant antfile="deploy-test-in-host.xml" dir="." inheritAll="false">
						<property name="deploy.file.fullname" value="${deploy.file.fullname}" />
						<property name="deploy.host.name" value="${test_machine_no3}" />
					</ant>
				</parallel>
				<tstamp>
					<format property="deploy_test_endtime" pattern="yyyy-MM-dd-hh.mm.ss a" />
				</tstamp>
				<sdbTime beginTime="${deploy_test_begintime}" endTime="${deploy_test_endtime}" output="deploy_test_time" />
				<echo message="**************************************************************************************************************************************************************" />
				<echo level="info" message="The deploy-test part began at &lt;${deploy_test_begintime}&gt;, end at &lt;${deploy_test_endtime}&gt;,total spending ${deploy_test_time}s." />
				<echo message="**************************************************************************************************************************************************************" />
			</else>
		</if>

		<property name="test.log" value="${test.environment}-${BUILD_NUMBER}-Standalone" />
		<property name="test.log.path" value="${test.reports.path}/${test.log}" />

		<!-- <property name="test-type-list" value="basic" /> -->
		<property name="test-type" value="js" />
		<for list="${test-type}" param="Test-Type">
			<sequential>
				<ant antfile="${WORKSPACE}/sequoiadb/misc/ci/test-type.xml" dir="." inheritAll="false">
					<property name="deploy.case.fullname" value="${deploy.case.fullname}" />
					<property name="test.reports.path" value="${test.reports.path}" />
					<property name="Test-Type" value="@{Test-Type}" />
					<property name="parallel.flag" value="parallel" />
					<property name="WORKSPACE" value="${WORKSPACE}" />
					<property name="ci.script.file.path" value="${ci.script.file.path}" />
					<property name="parallel.count" value="1" />
					<property name="test.log" value="${test.log}" />
					<property name="test-type-list" value="${test-type-list}" />
					<property name="BUILD_NUMBER" value="${BUILD_NUMBER}" />
				</ant>
			</sequential>
		</for>

		<if>
		   	<equals arg1="${test-type-list}" arg2="js" />
			<then>
				<property name="test-driver-list-B" value="ant" />
				<property name="test-driver-list-C" value="driver-java,driver-C,driver-CPP,driver-php,driver-python,lob" />
				<if>
				   	<equals arg1="${os.arch}" arg2="amd64" />
					<then>
						<parallel>
							<for list="driver-mongoc,lob" param="Test-Type">
								<sequential>
									<ant antfile="${WORKSPACE}/sequoiadb/misc/ci/test-type.xml" dir="." inheritAll="false">
										<property name="test.host.NAME" value="${test_machine_no1}" />
										<property name="deploy.case.fullname" value="${deploy.case.fullname}" />
										<property name="test.reports.path" value="${test.reports.path}" />
										<property name="Test-Type" value="@{Test-Type}" />
										<property name="parallel.flag" value="parallel" />
										<property name="WORKSPACE" value="${WORKSPACE}" />
										<property name="ci.script.file.path" value="${ci.script.file.path}" />
										<property name="parallel.count" value="1" />
										<property name="test.log" value="${test.log}" />
										<property name="test-type-list" value="${test-type-list}" />
										<property name="BUILD_NUMBER" value="${BUILD_NUMBER}" />
									</ant>
								</sequential>
							</for>
							<for list="driver-java" param="Test-Type">
								<sequential>
									<ant antfile="${WORKSPACE}/sequoiadb/misc/ci/test-type.xml" dir="." inheritAll="false">
										<property name="test.host.NAME" value="${test_machine_no2}" />
										<property name="deploy.case.fullname" value="${deploy.case.fullname}" />
										<property name="test.reports.path" value="${test.reports.path}" />
										<property name="Test-Type" value="@{Test-Type}" />
										<property name="parallel.flag" value="parallel" />
										<property name="WORKSPACE" value="${WORKSPACE}" />
										<property name="ci.script.file.path" value="${ci.script.file.path}" />
										<property name="parallel.count" value="1" />
										<property name="test.log" value="${test.log}" />
										<property name="test-type-list" value="${test-type-list}" />
										<property name="BUILD_NUMBER" value="${BUILD_NUMBER}" />
									</ant>
								</sequential>
							</for>
							<for list="driver-php,driver-C" param="Test-Type">
								<sequential>
									<ant antfile="${WORKSPACE}/sequoiadb/misc/ci/test-type.xml" dir="." inheritAll="false">
										<property name="test.host.NAME" value="${test_machine_no3}" />
										<property name="deploy.case.fullname" value="${deploy.case.fullname}" />
										<property name="test.reports.path" value="${test.reports.path}" />
										<property name="Test-Type" value="@{Test-Type}" />
										<property name="parallel.flag" value="parallel" />
										<property name="WORKSPACE" value="${WORKSPACE}" />
										<property name="ci.script.file.path" value="${ci.script.file.path}" />
										<property name="parallel.count" value="1" />
										<property name="test.log" value="${test.log}" />
										<property name="test-type-list" value="${test-type-list}" />
										<property name="BUILD_NUMBER" value="${BUILD_NUMBER}" />
									</ant>
								</sequential>
							</for>
							<for list="driver-python,driver-CPP" param="Test-Type">
								<sequential>
									<ant antfile="${WORKSPACE}/sequoiadb/misc/ci/test-type.xml" dir="." inheritAll="false">
										<property name="test.host.NAME" value="${test_machine_no4}" />
										<property name="deploy.case.fullname" value="${deploy.case.fullname}" />
										<property name="test.reports.path" value="${test.reports.path}" />
										<property name="Test-Type" value="@{Test-Type}" />
										<property name="parallel.flag" value="parallel" />
										<property name="WORKSPACE" value="${WORKSPACE}" />
										<property name="ci.script.file.path" value="${ci.script.file.path}" />
										<property name="parallel.count" value="1" />
										<property name="test.log" value="${test.log}" />
										<property name="test-type-list" value="${test-type-list}" />
										<property name="BUILD_NUMBER" value="${BUILD_NUMBER}" />
									</ant>
								</sequential>
							</for>
							<for list="ant" param="Test-Type">
								<sequential>
									<ant antfile="${WORKSPACE}/sequoiadb/misc/ci/test-type.xml" dir="." inheritAll="false">
										<property name="test.host.NAME" value="${test_machine_no5}" />
										<property name="deploy.case.fullname" value="${deploy.case.fullname}" />
										<property name="test.reports.path" value="${test.reports.path}" />
										<property name="Test-Type" value="@{Test-Type}" />
										<property name="parallel.flag" value="parallel" />
										<property name="WORKSPACE" value="${WORKSPACE}" />
										<property name="ci.script.file.path" value="${ci.script.file.path}" />
										<property name="parallel.count" value="1" />
										<property name="test.log" value="${test.log}" />
										<property name="test-type-list" value="${test-type-list}" />
										<property name="BUILD_NUMBER" value="${BUILD_NUMBER}" />
									</ant>
								</sequential>
							</for>
						</parallel>
					</then>
					<else>
						<parallel>
							<for list="${test-driver-list-C}" param="Test-Type">
								<sequential>
									<ant antfile="${WORKSPACE}/sequoiadb/misc/ci/test-type.xml" dir="." inheritAll="false">
										<property name="test.host.NAME" value="${test_machine_no2}" />
										<property name="deploy.case.fullname" value="${deploy.case.fullname}" />
										<property name="test.reports.path" value="${test.reports.path}" />
										<property name="Test-Type" value="@{Test-Type}" />
										<property name="parallel.flag" value="parallel" />
										<property name="WORKSPACE" value="${WORKSPACE}" />
										<property name="ci.script.file.path" value="${ci.script.file.path}" />
										<property name="parallel.count" value="1" />
										<property name="test.log" value="${test.log}" />
										<property name="test-type-list" value="${test-type-list}" />
										<property name="BUILD_NUMBER" value="${BUILD_NUMBER}" />
									</ant>
								</sequential>
							</for>
							<for list="${test-driver-list-B}" param="Test-Type">
								<sequential>
									<ant antfile="${WORKSPACE}/sequoiadb/misc/ci/test-type.xml" dir="." inheritAll="false">
										<property name="test.host.NAME" value="${test_machine_no3}" />
										<property name="deploy.case.fullname" value="${deploy.case.fullname}" />
										<property name="test.reports.path" value="${test.reports.path}" />
										<property name="Test-Type" value="@{Test-Type}" />
										<property name="parallel.flag" value="parallel" />
										<property name="WORKSPACE" value="${WORKSPACE}" />
										<property name="ci.script.file.path" value="${ci.script.file.path}" />
										<property name="parallel.count" value="1" />
										<property name="test.log" value="${test.log}" />
										<property name="test-type-list" value="${test-type-list}" />
										<property name="BUILD_NUMBER" value="${BUILD_NUMBER}" />
									</ant>
								</sequential>
							</for>
						</parallel>
					</else>
				</if>
			</then>
		</if>
	
		<trycatch>
			<try>
				<if>
					<equals arg1="${copy.test.log}" arg2="true" />
					<then>
						<mkdir dir="${test.log.path}" />

						<if>
		   					<equals arg1="${os.arch}" arg2="amd64" />
							<then>
								<sdbCopyAndTar fileHostName="${test_machine_no1}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no2}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no3}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no4}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no5}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no6}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
							</then>
							<else>
								<sdbCopyAndTar fileHostName="${test_machine_no1}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no2}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
								<sdbCopyAndTar fileHostName="${test_machine_no3}" saveHostName="${host.NAME}" diaglogPath="${install.path}/sequoiadb/database" savePath="${test.log.path}" />
							</else>
						</if>

						<tar basedir="${test.reports.path}" destfile="${test.log.path}.tar.gz" compression="gzip" includes="**/*" />
						<stafTools workType="copy" workHost="${host.NAME}" fileName="${test.log.path}.tar.gz"  toHost="${save.testLog.hostname}"  saveDir="${save.testLog.dir}" failonerror="true"/>						
					</then>
				</if>
			</try>
			<catch>
				<echo message="Copy log for download code fail" />
			</catch>
			<finally>
				<delete file="${test.log.path}.tar.gz" failonerror="false" />
				<delete dir="${test.log.path}" failonerror="false"/>
			</finally>
		</trycatch>	

	</target>
</project>
