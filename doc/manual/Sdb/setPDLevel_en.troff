.\" Automatically generated by Pandoc 1.18
.\"
.TH "setPDLevel" "1" "" "SequoiaDB User Manuals" ""
.hy
.SH NAME
.PP
setPDLevel \- Set the node's diagnostic level and take effect.
.SH SYNOPSIS
.PP
\f[B]\f[I]db.setPDLevel(<level>,[options])\f[]\f[]
.SH CATEGORY
.PP
Sequoiadb
.SH "DESCRIPTION"

.sp 2
Set the node's diagnostic level and take effect.
.sp 2
\fBlevel (int)\fR
.br
       The diagnostic level, value 0~5. value means:
       0: SEVERE
       1: ERROR
       2: EVENT
       3: WARNING
       4: INFO
       5: DEBUG
.sp 2
\fBoptions (json object)\fR
.br
       Specify location params, such as NodeID, HostName, svcname, etc.
       It only takes effect on coordinate nodes. The local node in 
       default.
.sp 2
       \fBGlobal\fR
.br
              Specify the command's location which is local or global.
.br
              Global:false  : run on local
              Global:true   : run on global nodes
.sp 2
       \fBGroupID\fR
.br
              Specify the command's location by group ID.
.br
              GroupID:1000
              GroupID:[1000, 1001, ...]
.sp 2
       \fBGroupName\fR
.br
              Specify the command's location by group name.
.br
              GroupName:"db1"
              GroupName:["db1", "db2", ...]
.sp 2
       \fBNodeID\fR
.br
              Specify the command's location by node ID.
.br
              NodeID:1000
              NodeID:[1000, 1001, ...]
.sp 2
       \fBHostName\fR
.br
              Specify the command's location by node name.
              The param should be used with 'svcname'.
.br
              HostName:"host-01"
              HostName:[ "centos-01", "ubuntu-02", ... ]
.sp 2
       \fBsvcname\fR
.br
              Specify the command's location by svcname.
              The param should be used with 'HostName'.
.br
              svcname:"11820"
              svcname:[ "11780", "11810", ... ]
.sp 2
       \fBNodeSelect\fR
.br
              Specify the command's node select type for a group 
              without the node information. Value is "all", 
              "master", "any" or "secondary".
.br
              NodeSelect:"all"

.sp 2
\fBNote: \fR
.sp 2
   *  The setting does not persist.
.SH "Examples"

.sp 2
1. set all node's diagnostic level to WARNING.
.sp 2
   db.setPDLevel( 3, {Global:true} )
.sp 2
2. set the specified node 1001 's diagnostic level to EVENT.
.sp 2
   db.setPDLevel( 2, {NodeID:1001} )
.sp 2
3. set self node's diagnostic level to EVENT.
.sp 2
   db.setPDLevel( 2 )
