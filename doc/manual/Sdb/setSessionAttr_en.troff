.\" Automatically generated by Pandoc 1.18
.\"
.TH "setSessionAttr" "1" "" "SequoiaDB User Manuals" ""
.hy
.SH NAME
.PP
setSessionAttr \- Set session attributes.
.SH SYNOPSIS
.PP
\f[B]\f[I]db.setSessionAttr([options])\f[]\f[]
.SH CATEGORY
.PP
Sequoiadb
.SH "DESCRIPTION"

.sp 2
Set session attributes.
.sp 2
\fBoptions (json object)\fR
.br
       Session attributes' options.
.sp 2
       \fBPreferedInstance\fR
.br
              Preferred instance for read request in the current
              session. Could be single value in "M", "m", "S",
              "s", "A", "a", 1-255, or BSON Array to include
              multiple values.
              "M", "m": read and write instance( master instance ).
              If multiple numeric instances are given with "M",
              matched master instance will be chosen in higher
              priority. If multiple numeric instances are given
              with "M" or "m", master instance will be chosen if no
              numeric instance is matched.
              "S", "s": read only instance( slave instance ). If
              multiple numeric instances are given with "S",
              matched slave instances will be chosen in higher
              priority. If multiple numeric instances are given with
              "S" or "s", slave instance will be chosen if no
              numeric instance is matched.
              "A", "a": any instance.
              1-255: the instance with specified instance ID.
              If multiple alphabet instances are given, only first
              one will be used.
              If matched instance is not found, will choose instance
              by random.
.br
              PreferedInstance : "M"
              PreferedInstance : [ 1, 7 ]
.br
       \fBPreferedInstanceMode\fR
.br
              The mode to choose query instance when multiple
              preferred instances are found in the current
              session.
              "random": choose the instance from matched
              instances by random.
              "ordered": choose the instance from matched
              instances by the order of "PreferedInstance".
.br
              "PreferedInstanceMode : "random"
.br
       \fBPreferedStrict\fR
.br
              Specify whether the node selection is a strict
              mode, and when it is a strict mode, the node
              can only be selected from the specified IDs by
              "PreferedInstance".
              Default is FALSE.
.br
              "PreferedStrict : "true"
.br
       \fBTimeout\fR
.br
              The timeout (in ms) for operations in the current
              session. -1 means no timeout for operations. 
              Minimum value is 1000 ms.
.br
              "Timeout" : 10000
.br
       \fBTransIsolation\fR
.br
              The isolation level of transaction in the current
              session. 0 for RU, 1 for RC, 2 for RS.
.br
              "TransIsolation" : 1
.br
       \fBTransTimeout\fR
.br
              The timeout of waiting the transaction-lock(in second)
              in the current session.
              Only the TransTimeout can update in transaction, other
              transaction attributes should update outside of
              transaction.
.br
              "TransTimeout" : 10
.br
       \fBTransLockWait\fR
.br
              Specify the lock wait behavior within transaction under
              RC isolation level in current session.
.br
              "TransLockWait" : true
.br
       \fBTransUseRBS\fR
.br
              Specify whether use rollback segment or not in
              transaction in the current session.
.br
              "TransUseRBS" : true
.br
       \fBTransAutoCommit\fR
.br
              Specify whether enable automatic transaction or not
              in the current session.
.br
              "TransAutoCommit" : true
.br
       \fBTransAutoRollback\fR
.br
              Specify whether enable automatically rollback when
              transaction operation failed or not in the current
              session.
.br
              "TransAutoRollback" : true
.SH "Examples"

.sp 2
Set the preferred instance as master so that the session will
preferentially read the data from a master database instance.
.sp 2
db.setSessionAttr( { PreferedInstance : "M" } )
.sp 2
Set the preferred instance as instance 1 or instance 7 so that
the session will preferentially read the data from those
instances.
.sp 2
db.setSessionAttr( { PreferedInstance : [ 1, 7 ] } )
.sp 2
Set the operation timeout of the current session to 10 seconds
.sp 2
db.setSessionAttr( { Timeout : 10000 } )
