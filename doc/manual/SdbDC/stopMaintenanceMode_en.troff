.SH VERSION
.PP
v5.8.6 and above
.SH EXAMPLES
.PP
\f[B]Example 1:\f[] Stop cluster Maintenance mode
.IP
.nf
\f[C]
> var dc = db.getDC()
> dc.stopMaintenanceMode()
{
  "MatchedNum": 3,
  "SucceedNum": 3,
  "IgnoredNum": 0,
  "FailedNum": 0
}
\f[]
.fi
.PP
\f[B]Example 2:\f[] Stop Maintenance mode only for data groups in the specified
domain
.IP
.nf
\f[C]
> var dc = db.getDC()
> dc.stopMaintenanceMode({Domain: "mydomain"})
{
  "MatchedNum": 2,
  "SucceedNum": 2,
  "IgnoredNum": 0,
  "FailedNum": 0
}
\f[]
.fi
