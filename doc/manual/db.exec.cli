.TH COMMAND * 2014-04-08 "SequoiaDB" "Sequoiadb sdb's Manual"
.ad l.ll 72.ce 1000
\fBdb.exec()\fR
.ce 0
.sp 2

.SH "NAME"

.sp 2
exec - Executing SQL select statement.
.SH "SYNOPSIS"

.sp 2

.sp 2

.sp 2
db.exec(\fBselect sql\fR)
.SH "CATEGORY"

.sp 2

.sp 2
Sequoiadb
.SH "DESCRIPTION"

.sp 2
Executing SQL select statement.
.SH "Examples"

.sp 2
Check all "age = 20" records from the collection "my.my" in.
.sp 2
db.exec("select * from my.my where age = 20")